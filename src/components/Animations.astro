---
// Basalio GSAP Animation Setup
// High-performance scroll and interaction animations
---

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// Hero animations - fade in and slide up on load
	const heroP = document.querySelector('.hero p');
	const heroH1 = document.querySelector('.hero h1');
	const heroP2 = document.querySelector('.hero > div > p:last-of-type');
	const heroCTA = document.querySelector('.hero-cta');

	if (heroP && heroH1 && heroP2 && heroCTA) {
		const tl = gsap.timeline({ defaults: { duration: 0.8, ease: 'power2.out' } });

		tl.from(heroP, { opacity: 0, y: 20 }, 0)
			.from(heroH1, { opacity: 0, y: 40 }, 0.1)
			.from(heroP2, { opacity: 0, y: 30 }, 0.2)
			.from(heroCTA, { opacity: 0, y: 20 }, 0.3);
	}

	// Module cards - staggered scroll reveal
	const moduleRows = document.querySelectorAll('.module-row');

	moduleRows.forEach((row) => {
		const cards = row.querySelectorAll('.module-tile');

		cards.forEach((card, i) => {
			gsap.from(card, {
				opacity: 0,
				y: 60,
				duration: 0.8,
				ease: 'power2.out',
				scrollTrigger: {
					trigger: card,
					start: 'top 85%',
					end: 'top 50%',
					toggleActions: 'play none none reverse',
				},
				delay: i * 0.15, // Stagger effect
			});
		});
	});

	// Section headings - scroll reveal
	const sectionHeadings = document.querySelectorAll('h2');

	sectionHeadings.forEach((heading) => {
		gsap.from(heading, {
			opacity: 0,
			y: 40,
			duration: 0.8,
			ease: 'power2.out',
			scrollTrigger: {
				trigger: heading,
				start: 'top 80%',
				toggleActions: 'play none none reverse',
			},
		});
	});

	// Eyebrows (section labels) - subtle fade in
	const eyebrows = document.querySelectorAll('.eyebrow');

	eyebrows.forEach((eyebrow) => {
		gsap.from(eyebrow, {
			opacity: 0,
			y: 20,
			duration: 0.6,
			ease: 'power2.out',
			scrollTrigger: {
				trigger: eyebrow,
				start: 'top 85%',
				toggleActions: 'play none none reverse',
			},
		});
	});

	// Smooth navigation link scrolling
	const navLinks = document.querySelectorAll('nav a[href*="#"]');

	navLinks.forEach((link) => {
		link.addEventListener('click', (e) => {
			const href = link.getAttribute('href');
			if (href && href.startsWith('#')) {
				e.preventDefault();
				const target = document.querySelector(href);
				if (target) {
					gsap.to(window, {
						scrollTo: { y: target, autoKill: false },
						duration: 1,
						ease: 'power2.inOut',
					});
				}
			}
		});
	});

	// Button hover effect enhancement
	const buttons = document.querySelectorAll('.btn');

	buttons.forEach((button) => {
		button.addEventListener('mouseenter', () => {
			gsap.to(button, {
				scale: 1.05,
				duration: 0.3,
				ease: 'back.out',
				overwrite: 'auto',
			});
		});

		button.addEventListener('mouseleave', () => {
			gsap.to(button, {
				scale: 1,
				duration: 0.3,
				ease: 'back.out',
				overwrite: 'auto',
			});
		});
	});

	// Refresh ScrollTrigger on page load and resize
	window.addEventListener('load', () => {
		ScrollTrigger.refresh();
	});

	window.addEventListener('resize', () => {
		ScrollTrigger.refresh();
	});
</script>
