---
// Basalio GSAP Animation Setup
// Core animations for hero, modules, and navigation
---

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// ===== HERO ANIMATIONS =====
	const heroP = document.querySelector('.hero p');
	const heroH1 = document.querySelector('.hero h1');
	const heroP2 = document.querySelector('.hero > div > p:last-of-type');
	const heroCTA = document.querySelector('.hero-cta');

	if (heroP && heroH1 && heroP2 && heroCTA) {
		const tl = gsap.timeline({ defaults: { duration: 0.8, ease: 'power2.out' } });
		tl.from(heroP, { opacity: 0, y: 20 }, 0)
			.from(heroH1, { opacity: 0, y: 40 }, 0.1)
			.from(heroP2, { opacity: 0, y: 30 }, 0.2)
			.from(heroCTA, { opacity: 0, y: 20 }, 0.3);
	}

	// ===== MODULE CARDS REVEAL =====
	const moduleRows = document.querySelectorAll('.module-row');
	moduleRows.forEach((row) => {
		const cards = row.querySelectorAll('.module-tile');
		cards.forEach((card, i) => {
			gsap.from(card, {
				opacity: 0,
				y: 60,
				duration: 0.8,
				ease: 'power2.out',
				scrollTrigger: {
					trigger: card,
					start: 'top 85%',
					end: 'top 50%',
					toggleActions: 'play none none reverse',
				},
				delay: i * 0.15,
			});
		});
	});

	// ===== SECTION HEADINGS =====
	const sectionHeadings = document.querySelectorAll('h2');
	sectionHeadings.forEach((heading) => {
		gsap.from(heading, {
			opacity: 0,
			y: 40,
			duration: 0.8,
			ease: 'power2.out',
			scrollTrigger: {
				trigger: heading,
				start: 'top 80%',
				toggleActions: 'play none none reverse',
			},
		});
	});

	// ===== SCROLL SEQUENCE INTERACTIVE SLIDER =====
	const scrollSeqSlider = document.getElementById('scrollSeqSlider');
	const scrollSeqHandle = document.getElementById('scrollSeqHandle');
	const progressBars = [
		document.getElementById('scrollSeqProgress'),
		document.getElementById('scrollSeqProgress2'),
		document.getElementById('scrollSeqProgress3'),
	].filter(Boolean);

	if (scrollSeqSlider && scrollSeqHandle && progressBars.length > 0) {
		let isDragging = false;

		const updateProgressBars = (percentage) => {
			progressBars.forEach((bar, index) => {
				const staggeredPercent = Math.max(0, percentage - index * 15);
				bar.style.width = staggeredPercent + '%';
			});
			scrollSeqHandle.style.left = percentage + '%';
		};

		scrollSeqHandle.addEventListener('mousedown', () => {
			isDragging = true;
			scrollSeqHandle.style.transform = 'translateY(-50%) scale(1.2)';
		});

		document.addEventListener('mousemove', (e) => {
			if (!isDragging) return;
			const rect = scrollSeqSlider.getBoundingClientRect();
			const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
			const percentage = (x / rect.width) * 100;
			updateProgressBars(percentage);
		});

		document.addEventListener('mouseup', () => {
			isDragging = false;
			scrollSeqHandle.style.transform = 'translateY(-50%)';
		});

		scrollSeqSlider.addEventListener('click', (e) => {
			const rect = scrollSeqSlider.getBoundingClientRect();
			const x = Math.max(0, Math.min(e.clientX - rect.left, rect.width));
			const percentage = (x / rect.width) * 100;
			updateProgressBars(percentage);
		});
	}

	// ===== BUTTON HOVER EFFECTS =====
	const buttons = document.querySelectorAll('.btn');
	buttons.forEach((button) => {
		button.addEventListener('mouseenter', () => {
			gsap.to(button, { scale: 1.05, duration: 0.3, ease: 'back.out' });
		});
		button.addEventListener('mouseleave', () => {
			gsap.to(button, { scale: 1, duration: 0.3, ease: 'back.out' });
		});
	});

	// ===== SMOOTH SCROLL NAVIGATION =====
	const navLinks = document.querySelectorAll('nav a[href*="#"]');
	navLinks.forEach((link) => {
		link.addEventListener('click', (e) => {
			const href = link.getAttribute('href');
			if (href && href.startsWith('#')) {
				e.preventDefault();
				const target = document.querySelector(href);
				if (target) {
					gsap.to(window, {
						scrollTo: { y: target, autoKill: false },
						duration: 1,
						ease: 'power2.inOut',
					});
				}
			}
		});
	});

	// ===== SCROLLTRIGGER REFRESH =====
	window.addEventListener('load', () => ScrollTrigger.refresh());
	window.addEventListener('resize', () => ScrollTrigger.refresh());
</script>
