---
// Universal Button Component - Unified pill design
// Text and arrow in single container, arrow animates on hover
// Usage: <Button label="VIEW COURSE" href="/courses" />

interface Props {
  label: string;
  href?: string;
  onClick?: string;
  fontSize?: string;
  fontWeight?: string;
  letterSpacing?: string;
  uppercase?: boolean;
}

const {
  label,
  href,
  onClick,
  fontSize = "14px",
  fontWeight = "500",
  letterSpacing = "2.8px",
  uppercase = true
} = Astro.props;

const Component = href ? 'a' : 'button';
---

<Component href={href} class="btn-wrapper" {...(onClick && { onclick: onClick })}>
  <div class="btn-text">
    <p class="btn-label">{uppercase ? label.toUpperCase() : label}</p>
  </div>
  <div class="btn-arrow-container">
    <div class="btn-arrow btn-arrow-right">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
        <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
        <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
      </svg>
    </div>
    <div class="btn-arrow btn-arrow-left">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
        <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
        <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
      </svg>
    </div>
  </div>
</Component>

<style define:vars={{ fontSize, fontWeight, letterSpacing }}>
  .btn-wrapper {
    cursor: pointer;
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 43.6px;
    background: transparent;
    border: none;
    padding: 0;
    text-decoration: none;
    -webkit-font-smoothing: antialiased;
    border-radius: 8px;
    overflow: hidden;
  }

  .btn-text {
    background-color: #000000 !important;
    height: 100% !important;
    padding: 12px 24px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    flex-shrink: 0 !important;
    border-radius: 6px !important;
  }

  .btn-label {
    font-family: 'Azeret Mono', monospace;
    font-size: var(--fontSize);
    font-weight: var(--fontWeight);
    letter-spacing: var(--letterSpacing);
    line-height: 19.6px;
    text-transform: uppercase;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    white-space: nowrap;
  }

  .btn-arrow-container {
    background-color: #000000 !important;
    height: 100% !important;
    width: 43.6px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    position: relative !important;
    border-radius: 6px !important;
    margin-left: -8px !important;
    padding-left: 8px !important;
  }

  .btn-arrow {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 16px;
    width: 16px;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .btn-arrow-right {
    opacity: 1;
    transform: translateX(0);
  }

  .btn-arrow-left {
    opacity: 0;
    transform: translateX(-8px);
  }

  .btn-arrow svg {
    height: 100%;
    width: 100%;
    stroke: #FFFFFF;
    stroke-width: 1.5px;
    fill: none;
    stroke-miterlimit: 10;
  }

  .btn-wrapper:hover .btn-arrow-right {
    opacity: 0;
    transform: translateX(8px);
  }

  .btn-wrapper:hover .btn-arrow-left {
    opacity: 1;
    transform: translateX(0);
  }
</style>
