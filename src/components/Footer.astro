---
// Unified Footer Component for Basalio
interface Props {
	productsModulesHref?: string;
	productsPerformanceHref?: string;
	socialLinks?: Array<{
		href: string;
		label: string;
		icon: string;
	}>;
}

const {
	productsModulesHref = '/#exhibits',
	productsPerformanceHref = '/#bench',
	socialLinks = [
		{
			href: 'https://twitter.com',
			label: 'Basalio on X',
			icon: 'M18.9 2H22l-7.6 8.7L23.3 22h-6.9l-5.4-7-6.2 7H1.6l8.1-9.3L1 2h7.1l4.9 6.4L18.9 2Zm-1.2 18h1.9L7.4 4h-2l12.3 16Z'
		},
		{
			href: 'https://github.com',
			label: 'Basalio on GitHub',
			icon: 'M12 .5A11.5 11.5 0 0 0 .5 12c0 5.1 3.29 9.42 7.86 10.95.57.1.79-.25.79-.55v-2c-3.2.7-3.87-1.4-3.87-1.4-.52-1.34-1.28-1.7-1.28-1.7-1.04-.72.08-.7.08-.7 1.16.08 1.76 1.2 1.76 1.2 1.02 1.76 2.68 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.72 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a10.98 10.98 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.64 1.6.24 2.77.12 3.06.74.81 1.19 1.84 1.19 3.1 0 4.45-2.7 5.42-5.27 5.71.42.36.78 1.08.78 2.17v3.22c0 .3.21.66.8.55A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z'
		}
	]
} = Astro.props;
---

<footer style="position:relative;overflow:hidden;background:#1C1917;border-top:1px solid rgba(255,255,255,0.08);">
	<div style="max-width:1200px;margin:0 auto;padding:72px 32px 40px;">
		<div style="display:grid;grid-template-columns:1.3fr 0.8fr 0.8fr 1.1fr;gap:40px;">
			<div>
				<a href="/" style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;display:flex;align-items:center;gap:8px;color:#F6F4EF;">
					<svg width="14" height="14" viewBox="0 0 64 64" aria-hidden="true" style="flex:none;"><polygon points="8,56 56,56 46,44 18,44" fill="#F6F4EF"></polygon><rect x="23" y="20" width="18" height="24" fill="#DFFF00"></rect></svg>
					Basalio
				</a>
				<p style="font-size:14px;color:#D4CABE;margin:16px 0 0;max-width:32ch;line-height:1.5;">Nine curated interaction modules for WordPress portfolios. Nothing you'd need Framer for.</p>
				<div style="display:flex;gap:10px;margin-top:22px;">
					{socialLinks.map((link) => (
						<a href={link.href} aria-label={link.label} style="width:34px;height:34px;border-radius:50%;border:1px solid rgba(255,255,255,0.14);display:flex;align-items:center;justify-content:center;color:#D4CABE;transition:border-color .15s ease, color .15s ease;">
							<svg width={link.label.includes('GitHub') ? '15' : link.label.includes('WordPress') ? '15' : '14'} height={link.label.includes('GitHub') ? '15' : link.label.includes('WordPress') ? '15' : '14'} viewBox="0 0 24 24" fill="currentColor"><path d={link.icon}></path></svg>
						</a>
					))}
				</div>
			</div>
			<div>
				<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#C9BEB2;margin:0 0 16px;">Product</p>
				<div style="display:flex;flex-direction:column;gap:12px;">
					<a href={productsModulesHref} style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Modules</a>
					<a href={productsPerformanceHref} style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Performance</a>
					<a href="/pricing" style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Pricing</a>
					<a href="/roadmap" style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Roadmap</a>
				</div>
			</div>
			<div>
				<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#C9BEB2;margin:0 0 16px;">Support</p>
				<div style="display:flex;flex-direction:column;gap:12px;">
					<a href="/support" style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Help center</a>
					<a href="mailto:hello@basalio.so" style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Contact</a>
					<a href="/terms" style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Terms</a>
					<a href="/privacy" style="font-size:14px;color:#D4CABE;transition:color .15s ease;">Privacy</a>
				</div>
			</div>
			<div>
				<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#C9BEB2;margin:0 0 16px;">Stay in the loop</p>
				<p style="font-size:14px;color:#D4CABE;margin:0 0 16px;line-height:1.5;">Get notified when a new module ships.</p>
				<form style="display:flex;gap:8px;">
					<input type="email" placeholder="you@yourstudio.com" aria-label="Email address" style="flex:1;min-width:0;padding:11px 14px;border-radius:8px;border:1px solid rgba(255,255,255,0.14);background:rgba(255,255,255,0.04);color:#F6F4EF;font-family:'Inter',sans-serif;font-size:13px;">
					<button type="submit" style="flex:none;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:13px;padding:11px 16px;border:0;border-radius:8px;background:#DFFF00;color:#17171A;cursor:pointer;white-space:nowrap;">Sign up</button>
				</form>
			</div>
		</div>
		<div style="border-top:1px solid rgba(255,255,255,0.08);margin-top:52px;padding-top:22px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
			<p style="font-size:13px;color:#C9BEB2;margin:0;">&copy; 2026 Basalio. All rights reserved.</p>
			<p style="font-size:13px;color:#C9BEB2;margin:0;">Built for portfolios. Nothing else.</p>
		</div>
	</div>

	<div style="width:100%;padding:20px 0 0;overflow:hidden;">
		<div aria-hidden="true" style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:min(19vw,300px);line-height:1;color:#F6F4EF;text-align:center;letter-spacing:-0.03em;user-select:none;white-space:nowrap;">BASALIO</div>
	</div>
</footer>

<style>
	@media (max-width:768px){
		footer{padding:48px 16px 24px !important;}
		footer > div > div[style*="grid-template-columns"]{grid-template-columns:1fr !important;gap:32px !important;}
		footer form{flex-direction:column;}
	}
	@media (max-width:480px){
		footer{padding:40px 16px 24px !important;}
		footer > div > div[style*="grid-template-columns"]{gap:24px !important;}
	}
</style>
