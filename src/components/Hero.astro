---
// Hero Component - Full-width hero section
interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  cta_primary?: { text: string; href: string };
  cta_secondary?: { text: string; href: string };
}

const { eyebrow, title, subtitle, cta_primary, cta_secondary } = Astro.props;
---

<div class="hero">
  <div class="hero-content">
    {eyebrow && <p>{eyebrow}</p>}
    {title && <h1 set:html={title} />}
    {subtitle && <p>{subtitle}</p>}
    {(cta_primary || cta_secondary) && (
      <div class="hero-cta">
        {cta_primary && (
          <a href={cta_primary.href} class="btn btn-dark">
            {cta_primary.text}
          </a>
        )}
        {cta_secondary && (
          <a href={cta_secondary.href} class="btn btn-light">
            {cta_secondary.text}
          </a>
        )}
      </div>
    )}
  </div>
</div>
