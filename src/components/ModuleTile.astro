---
// ModuleTile Component - Individual module card
interface Props {
  title: string;
  description: string;
  bg?: 'light' | 'dark' | 'accent' | 'mid-dark';
  class?: string;
}

const { title, description, bg = 'light', class: className = '' } = Astro.props;
const bgClass = `bg-${bg}`;
---

<div class={`module-tile ${bgClass} ${className}`}>
  <div class="module-content">
    <h3>{title}</h3>
    <p set:html={description} />
  </div>
  <slot />
</div>
