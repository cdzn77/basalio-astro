---
// Ramp Courses - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions: 1791×971px, padding 200px 40px

interface Course {
  title: string;
  description: string;
  image?: string;
  link?: string;
}

interface Props {
  courses?: Course[];
}

const {
  courses = [
    {
      title: "Social Media Growth",
      description: "Learn the fundamentals of building a strong social media presence",
      image: "https://via.placeholder.com/420x300?text=Social+Media",
      link: "#"
    },
    {
      title: "Content Creation 101",
      description: "Teaches you how to create content that feels intentional and on-brand",
      image: "https://via.placeholder.com/420x300?text=Content+Creation",
      link: "#"
    },
    {
      title: "Branding 101",
      description: "Focus on positioning, messaging, and consistency across every touchpoint",
      image: "https://via.placeholder.com/420x300?text=Branding",
      link: "#"
    },
    {
      title: "Email Marketing 101",
      description: "Learn how to use email lists to actually support and grow your business",
      image: "https://via.placeholder.com/420x300?text=Email+Marketing",
      link: "#"
    }
  ]
} = Astro.props;
---

<section class="courses" id="courses">
  <div class="courses-header">
    <h2>Courses for Digital Creatives</h2>
    <a href="#" class="view-all">View all</a>
  </div>

  <div class="carousel-wrapper">
    <button class="carousel-arrow prev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 4L6 10L12 16"></path>
      </svg>
    </button>

    <div class="carousel-container">
      <div class="carousel-track">
        {courses.map((course) => (
          <a href={course.link || "#"} class="course-card">
            <div class="course-icon">
              {course.image && <img src={course.image} alt={course.title} class="course-image" />}
            </div>
            <h3 class="course-title">{course.title}</h3>
            <p class="course-description">{course.description}</p>
          </a>
        ))}
      </div>
    </div>

    <button class="carousel-arrow next" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M8 4L14 10L8 16"></path>
      </svg>
    </button>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - RESPONSIVE VERSION */
  .courses {
    background: #FFFFFF;
    width: 100%;
    max-width: 1791px;
    padding: 200px 40px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
    box-sizing: border-box;
  }

  .courses-header {
    width: 100%;
    max-width: 1711px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0 auto 40px;
    box-sizing: border-box;
  }

  .courses-header h2 {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
  }

  .view-all {
    font-size: 14px;
    font-weight: 600;
    color: #0000EE;
    text-decoration: none;
    cursor: pointer;
  }

  .carousel-wrapper {
    width: 100%;
    max-width: 1711px;
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .carousel-arrow {
    width: 70px;
    height: 70px;
    border-radius: 8px;
    background: #F0F0F0;
    color: #000000;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
    flex-shrink: 0;
  }

  .carousel-arrow:hover {
    background: #E0E0E0;
  }

  .carousel-container {
    flex: 1;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .course-card {
    flex: 0 0 500px;
    height: 571px;
    background: #FFEA00;
    border-radius: 12px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .course-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .course-icon {
    width: 420px;
    height: 300px;
    background: #000000;
    border-radius: 8px;
    overflow: hidden;
  }

  .course-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .course-title {
    font-size: 20px;
    font-weight: 600;
    color: #000000;
    margin: 0;
  }

  .course-description {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .courses {
      width: 100%;
      height: auto;
    }

    .carousel-wrapper {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .courses {
      width: 100%;
      padding: 80px 20px;
    }

    .carousel-wrapper {
      flex-direction: column;
    }

    .course-card {
      width: 100%;
    }
  }
</style>

<script>
  const track = document.querySelector('.carousel-track');
  const prevBtn = document.querySelector('.carousel-arrow.prev');
  const nextBtn = document.querySelector('.carousel-arrow.next');
  const cards = document.querySelectorAll('.course-card');

  if (track && prevBtn && nextBtn && cards.length > 0) {
    let currentScroll = 0;
    const cardWidth = 500; // flex: 0 0 500px
    const gap = 24;
    const stepSize = cardWidth + gap;
    const maxScroll = (cards.length - 2) * stepSize;

    const updateCarousel = () => {
      track.style.transform = `translateX(-${currentScroll}px)`;
    };

    prevBtn.addEventListener('click', () => {
      currentScroll = Math.max(0, currentScroll - stepSize);
      updateCarousel();
    });

    nextBtn.addEventListener('click', () => {
      currentScroll = Math.min(maxScroll, currentScroll + stepSize);
      updateCarousel();
    });
  }
</script>
