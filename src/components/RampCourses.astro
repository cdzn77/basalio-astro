---
// Ramp Courses - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions: 1791×971px, padding 200px 40px

interface Course {
  title: string;
  description: string;
}

interface Props {
  courses?: Course[];
}

const {
  courses = [
    { title: "Social Media Growth", description: "Learn the fundamentals of building a strong social media presence" },
    { title: "Content Creation 101", description: "Teaches you how to create content that feels intentional and on-brand" },
    { title: "Branding 101", description: "Focus on positioning, messaging, and consistency across every touchpoint" },
    { title: "Email Marketing 101", description: "Learn how to use email lists to actually support and grow your business" }
  ]
} = Astro.props;
---

<section class="courses" id="courses">
  <div class="courses-header">
    <h2>Courses for Digital Creatives</h2>
    <a href="#" class="view-all">View all</a>
  </div>

  <div class="carousel-wrapper">
    <button class="carousel-arrow prev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 4L6 10L12 16"></path>
      </svg>
    </button>

    <div class="carousel-container">
      <div class="carousel-track">
        {courses.map((course) => (
          <div class="course-card">
            <div class="course-icon"></div>
            <h3 class="course-title">{course.title}</h3>
            <p class="course-description">{course.description}</p>
          </div>
        ))}
      </div>
    </div>

    <button class="carousel-arrow next" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M8 4L14 10L8 16"></path>
      </svg>
    </button>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS */
  .courses {
    background: #FFFFFF;
    width: 1791px;
    height: 971px;
    padding: 200px 40px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .courses-header {
    width: 1711px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .courses-header h2 {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
  }

  .view-all {
    font-size: 14px;
    font-weight: 600;
    color: #0000EE;
    text-decoration: none;
    cursor: pointer;
  }

  .carousel-wrapper {
    width: 1711px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .carousel-arrow {
    width: 70px;
    height: 70px;
    border-radius: 8px;
    background: #F0F0F0;
    color: #000000;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
    flex-shrink: 0;
  }

  .carousel-arrow:hover {
    background: #E0E0E0;
  }

  .carousel-container {
    flex: 1;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .course-card {
    flex: 0 0 500px;
    height: 571px;
    background: #FFEA00;
    border-radius: 12px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .course-icon {
    width: 420px;
    height: 300px;
    background: #000000;
    border-radius: 8px;
  }

  .course-title {
    font-size: 20px;
    font-weight: 600;
    color: #000000;
    margin: 0;
  }

  .course-description {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .courses {
      width: 100%;
      height: auto;
    }

    .carousel-wrapper {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .courses {
      width: 100%;
      padding: 80px 20px;
    }

    .carousel-wrapper {
      flex-direction: column;
    }

    .course-card {
      width: 100%;
    }
  }
</style>
