---
// Ramp FAQ - Multi-open accordion with black cards, 35%/65% header layout

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs?: FAQItem[];
}

const {
  faqs = [
    {
      question: "What is Basalio?",
      answer: "Basalio is a plugin for WordPress that provides nine carefully designed interaction modules for portfolio and case-study sites. Each module solves a specific problem—grid reveals, case study transitions, scroll sequences, and more—without bloat or learning curve. Built only for creatives, not page builders."
    },
    {
      question: "Do I need to know how to code?",
      answer: "No. Each module is ready to use out of the box. If you want to customize interactions, we provide code templates and documentation. But for most uses, setup is drag-and-drop with no coding required."
    },
    {
      question: "What WordPress theme do I need?",
      answer: "Basalio works with any WordPress theme. It's not a page builder, and it doesn't lock you into a specific theme or platform. Use your own theme, or use one of the recommended partners. Nine blocks, infinite possibilities."
    },
    {
      question: "Can I use Basalio on multiple sites?",
      answer: "Yes. The Founder Lifetime plan includes unlimited sites, plus you keep every block and hack forever. Scale your portfolio sites without renewal or per-site limits."
    },
    {
      question: "What's included in the free tier?",
      answer: "All nine blocks—the full plugin, any theme. Plus four free Hacks you can copy-paste and keep. The free tier is production-ready. Paid tier unlocks the full Hacks vault and Pro control center for fine-tuning every interaction live."
    },
    {
      question: "Is there support?",
      answer: "Yes. We provide module documentation, code templates, integration guides, and a performance checklist. All customers get access to the full resource library and community support."
    }
  ]
} = Astro.props;
---

<section class="faq">
  <!-- HEADER ROW: eyebrow (35%) + description (65%) -->
  <div class="faq-header">
    <!-- LEFT: Title -->
    <h2 class="faq-title">FAQ</h2>

    <!-- RIGHT: Description -->
    <div class="faq-header-right">
      <p class="faq-description">Explore our most commonly asked questions about Basalio, setup, pricing, and how the modules work.</p>
    </div>
  </div>

  <!-- FAQ LIST WRAPPER: Spacer + List aligned to right column -->
  <div class="faq-list-wrapper">
    <!-- Spacer matching eyebrow column width (35%) -->
    <div class="faq-list-spacer"></div>

    <!-- FAQ list aligned under header-right (65%) -->
    <div class="faq-list">
      {faqs.map((item, index) => (
        <div class="faq-item" data-index={index} data-open="false">
          <div class="faq-card">
            <!-- Question row: entire div is clickable -->
            <div class="faq-question-row" data-index={index}>
              <span class="faq-question-text">{item.question}</span>
              <div class="faq-icon">
                <!-- Plus icon (shown when closed) -->
                <svg class="faq-icon-plus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="rgb(255, 255, 255)">
                  <path fill-rule="evenodd" d="M 8 2 A 0.5 0.5 0 0 1 8.5 2.5 V 7.5 H 13.5 A 0.5 0.5 0 0 1 13.5 8.5 H 8.5 V 13.5 A 0.5 0.5 0 0 1 7.5 13.5 V 8.5 H 2.5 A 0.5 0.5 0 0 1 2.5 7.5 H 7.5 V 2.5 A 0.5 0.5 0 0 1 8 2"/>
                </svg>
                <!-- X icon (shown when open) -->
                <svg class="faq-icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="rgb(255, 255, 255)" style="display: none;">
                  <path fill-rule="evenodd" d="M 13.854 2.854 a 0.5 0.5 0 0 0 -0.708 0 L 8 8.293 L 2.854 2.854 a 0.5 0.5 0 1 0 -0.708 0.708 L 7.293 9 l -5.147 5.146 a 0.5 0.5 0 0 0 0.708 0.708 L 8 9.707 l 5.146 5.147 a 0.5 0.5 0 0 0 0.708 -0.708 L 8.707 9 l 5.147 -5.146 a 0.5 0.5 0 0 0 0 -0.708 Z"/>
                </svg>
              </div>
            </div>

            <!-- Answer: conditionally rendered when open -->
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* SECTION SHELL */
  .faq {
    align-content: flex-start;
    align-items: flex-start;
    background-color: rgb(0, 0, 0);
    border-bottom-left-radius: 40px;
    border-bottom-right-radius: 40px;
    box-shadow: rgba(0, 0, 0, 0.25) 0px 1px 2px 0px;
    box-sizing: border-box;
    column-gap: 40px;
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    justify-content: flex-start;
    opacity: 1;
    overflow-x: visible;
    overflow-y: visible;
    padding-bottom: 200px;
    padding-left: 40px;
    padding-right: 40px;
    padding-top: 40px;
    position: relative;
    row-gap: 40px;
    width: 100%;
    -webkit-font-smoothing: antialiased;
  }

  /* HEADER ROW: 35%/65% split */
  .faq-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 40px;
  }

  /* Title (left, 35%) */
  .faq-title {
    font-family: Switzer, "Switzer Placeholder", sans-serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 48px;
    letter-spacing: -0.8px;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    height: 48px;
    display: block;
    background-color: transparent;
    -webkit-font-smoothing: antialiased;
    flex: 1 1 0%;
    max-width: 35%;
  }

  /* Description (right, 65%) */
  .faq-header-right {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    flex: 1;
    max-width: 65%;
    gap: 40px;
  }

  .faq-description {
    font-family: Switzer, "Switzer Placeholder", sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.4px;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    height: 28px;
    display: block;
    background-color: transparent;
    font-feature-settings: "blwf", "cv03", "cv04", "cv09", "cv11";
    -webkit-font-smoothing: antialiased;
  }

  /* FAQ LIST WRAPPER: Spacer + List aligned to right column */
  .faq-list-wrapper {
    display: flex;
    flex-direction: row;
    width: 100%;
    gap: 40px;
  }

  /* Spacer: matches eyebrow column width (35%) */
  .faq-list-spacer {
    flex: 1 1 0%;
    max-width: 35%;
  }

  /* FAQ LIST: flex column, gap 12px, aligned under header-right (65%) */
  .faq-list {
    align-content: flex-start;
    align-items: flex-start;
    box-sizing: border-box;
    column-gap: 12px;
    display: flex;
    flex-basis: 0px;
    flex-direction: column;
    flex-grow: 1;
    flex-shrink: 0;
    flex-wrap: nowrap;
    justify-content: flex-start;
    max-width: 65%;
    opacity: 1;
    overflow-x: visible;
    overflow-y: visible;
    padding-bottom: 0px;
    padding-left: 0px;
    padding-right: 0px;
    padding-top: 0px;
    position: relative;
    row-gap: 12px;
    transform: none;
    width: 100%;
    will-change: transform;
    -webkit-font-smoothing: antialiased;
  }

  /* FAQ ITEM: wrapper */
  .faq-item {
    box-sizing: border-box;
    display: block;
    flex-basis: auto;
    flex-grow: 0;
    flex-shrink: 0;
    height: auto;
    opacity: 1;
    position: relative;
    width: 100%;
    -webkit-font-smoothing: antialiased;
  }

  /* FAQ CARD: black background, rounded corners, padding */
  .faq-card {
    background: rgb(0, 0, 0);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    box-sizing: border-box;
    display: block;
    flex-basis: auto;
    flex-grow: 0;
    flex-shrink: 0;
    height: auto;
    opacity: 1;
    padding: 20px;
    position: relative;
    width: 100%;
    -webkit-font-smoothing: antialiased;
  }

  /* QUESTION ROW: flex row, entire row clickable */
  .faq-question-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    cursor: pointer;
    width: 100%;
  }

  /* Question text: flex-grow, white */
  .faq-question-text {
    font-size: 18px;
    font-weight: 500;
    line-height: 25.2px;
    letter-spacing: -0.36px;
    color: #FFFFFF;
    flex-grow: 1;
  }

  /* Icon button: 40x40px square with hover background */
  .faq-icon {
    aspect-ratio: 1 / 1;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
    transform: none;
    transform-origin: 20px 20px;
    box-sizing: border-box;
    flex-basis: auto;
    flex-grow: 0;
    flex-shrink: 0;
    padding: 10px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
    font-size: 24px;
    font-weight: 400;
    color: #FFFFFF;
    -webkit-font-smoothing: antialiased;
  }

  /* SVG icon styling */
  .faq-icon svg {
    width: 24px !important;
    height: 24px !important;
    min-width: 24px;
    max-width: 24px;
    flex-shrink: 0;
    display: block;
    cursor: pointer;
    box-sizing: border-box;
    overflow-x: hidden;
    overflow-y: hidden;
    fill: rgb(255, 255, 255);
    font-family: sans-serif;
    font-size: 12px;
    fill-rule: evenodd;
    transform-origin: 0px 0px;
    -webkit-font-smoothing: antialiased;
    transition: fill 0.2s ease;
  }

  /* Icon button hover state */
  .faq-icon:hover {
    background-color: #FFED4E !important;
    border-radius: 4px;
  }

  .faq-icon:hover svg {
    fill: rgb(0, 0, 0);
  }

</style>

<script>
  // Multi-open accordion: track each item's open state independently
  const openItems = new Set();

  document.querySelectorAll('.faq-question-row').forEach((row) => {
    row.addEventListener('click', () => {
      const index = parseInt(row.getAttribute('data-index'));
      const card = row.closest('.faq-card');
      const item = row.closest('.faq-item');
      const iconPlus = item.querySelector('.faq-icon-plus');
      const iconClose = item.querySelector('.faq-icon-close');

      if (openItems.has(index)) {
        // Close this item
        openItems.delete(index);
        item.setAttribute('data-open', 'false');
        // Remove answer if it exists
        const existingAnswer = card.querySelector('.faq-answer');
        if (existingAnswer) {
          existingAnswer.remove();
        }
        // Swap icons: show +, hide X
        iconPlus.style.display = 'block';
        iconClose.style.display = 'none';
      } else {
        // Open this item
        openItems.add(index);
        item.setAttribute('data-open', 'true');
        // Add answer to DOM
        const faqData = {
          0: "Basalio is a plugin for WordPress that provides nine carefully designed interaction modules for portfolio and case-study sites. Each module solves a specific problem—grid reveals, case study transitions, scroll sequences, and more—without bloat or learning curve. Built only for creatives, not page builders.",
          1: "No. Each module is ready to use out of the box. If you want to customize interactions, we provide code templates and documentation. But for most uses, setup is drag-and-drop with no coding required.",
          2: "Basalio works with any WordPress theme. It's not a page builder, and it doesn't lock you into a specific theme or platform. Use your own theme, or use one of the recommended partners. Nine blocks, infinite possibilities.",
          3: "Yes. The Founder Lifetime plan includes unlimited sites, plus you keep every block and hack forever. Scale your portfolio sites without renewal or per-site limits.",
          4: "All nine blocks—the full plugin, any theme. Plus four free Hacks you can copy-paste and keep. The free tier is production-ready. Paid tier unlocks the full Hacks vault and Pro control center for fine-tuning every interaction live.",
          5: "Yes. We provide module documentation, code templates, integration guides, and a performance checklist. All customers get access to the full resource library and community support."
        };

        const answerDiv = document.createElement('p');
        answerDiv.className = 'faq-answer';
        answerDiv.textContent = faqData[index] || '';
        // Apply inline styles matching Ramp template design
        answerDiv.style.cssText = `
          font-family: Switzer, "Switzer Placeholder", sans-serif;
          font-size: 16px;
          font-weight: 400;
          line-height: 22.4px;
          color: rgb(122, 122, 122);
          margin: 0;
          padding: 0;
          display: block;
          width: 750px;
          background-color: transparent;
          text-decoration: none;
          letter-spacing: normal;
          text-transform: none;
          user-select: none;
        `;
        card.appendChild(answerDiv);
        // Swap icons: hide +, show X
        iconPlus.style.display = 'none';
        iconClose.style.display = 'block';
      }
    });
  });
</script>
