---
// Ramp FAQ - Multi-open accordion with black cards, 35%/65% header layout

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs?: FAQItem[];
}

const {
  faqs = [
    {
      question: "What does Ramp Studio do?",
      answer: "Ramp Studio helps brands build momentum through practical marketing education, hands-on execution, and reusable resources.  We offer self-paced courses, a subscription-based marketing retainer, and tools designed to help teams move faster, stay consistent, and make smarter decisions without overcomplicating things."
    },
    {
      question: "Who is Ramp Studio for?",
      answer: "Ramp is built for founders, small teams, and growing companies who want marketing that actually works—not just looks good.  If you're tired of one-off projects, unclear strategy, or starting from scratch every month, Ramp is for you."
    },
    {
      question: "How do your courses work?",
      answer: "Our courses are self-paced, practical, and designed to be applied immediately.  They focus on real-world marketing problems—systems, content, positioning, and execution—so you can learn once and reuse the knowledge across campaigns, clients, or teams."
    },
    {
      question: "What is the subscription marketing retainer?",
      answer: "The subscription retainer gives you ongoing access to marketing support without the friction of traditional contracts.  Instead of hiring full-time or briefing a new agency every month, you get consistent execution, iterative improvement, and a long-term partner who understands your business."
    },
    {
      question: "Do I need to choose between courses, resources, or the retainer?",
      answer: "Not at all.  Many clients start with courses or resources to build internal clarity, then move into a subscription when they want execution support. Others use everything together—learning, doing, and scaling at the same time."
    },
    {
      question: "What makes Ramp Studio different from other marketing agencies?",
      answer: "Ramp Studio is built around momentum.  We focus on clarity, systems, and repeatable outcomes—not buzzwords or one-off wins. Everything we offer is designed to reduce friction, save time, and help marketing compound over time."
    }
  ]
} = Astro.props;
---

<section class="faq">
  <!-- HEADER ROW: eyebrow (35%) + description (65%) -->
  <div class="faq-header">
    <!-- LEFT: Title -->
    <h2 class="faq-title">FAQ</h2>

    <!-- RIGHT: Description -->
    <div class="faq-header-right">
      <p class="faq-description">Explore our most commonly asked questions about our agency, podcast, and product launch resources.</p>
    </div>
  </div>

  <!-- FAQ LIST WRAPPER: Spacer + List aligned to right column -->
  <div class="faq-list-wrapper">
    <!-- Spacer matching eyebrow column width (35%) -->
    <div class="faq-list-spacer"></div>

    <!-- FAQ list aligned under header-right (65%) -->
    <div class="faq-list">
      {faqs.map((item, index) => (
        <div class="faq-item" data-index={index}>
          <div class="faq-card">
            <!-- Question row: entire div is clickable -->
            <div class="faq-question-row" data-index={index}>
              <span class="faq-question-text">{item.question}</span>
              <span class="faq-icon">+</span>
            </div>

            <!-- Answer: conditionally rendered when open -->
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* SECTION SHELL */
  .faq {
    display: flex;
    flex-flow: column;
    gap: 40px;
    padding: 40px 40px 200px 40px;
    background: rgb(0, 0, 0);
    width: 100%;
    box-sizing: border-box;
    border-bottom-left-radius: 40px;
    border-bottom-right-radius: 40px;
    box-shadow: rgba(0, 0, 0, 0.25) 0px 1px 2px 0px;
    place-content: flex-start;
    align-items: flex-start;
    height: min-content;
    overflow: visible;
  }

  /* HEADER ROW: 35%/65% split */
  .faq-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 40px;
  }

  /* Title (left, 35%) */
  .faq-title {
    font-family: Switzer, "Switzer Placeholder", sans-serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 48px;
    letter-spacing: -0.8px;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    height: 48px;
    display: block;
    background-color: transparent;
    -webkit-font-smoothing: antialiased;
    flex: 1 1 0%;
    max-width: 35%;
  }

  /* Description (right, 65%) */
  .faq-header-right {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    flex: 1;
    max-width: 65%;
    gap: 40px;
  }

  .faq-description {
    font-family: Switzer, "Switzer Placeholder", sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.4px;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    height: 28px;
    display: block;
    background-color: transparent;
    font-feature-settings: "blwf", "cv03", "cv04", "cv09", "cv11";
    -webkit-font-smoothing: antialiased;
  }

  /* FAQ LIST WRAPPER: Spacer + List aligned to right column */
  .faq-list-wrapper {
    display: flex;
    flex-direction: row;
    width: 100%;
    gap: 40px;
  }

  /* Spacer: matches eyebrow column width (35%) */
  .faq-list-spacer {
    flex: 1 1 0%;
    max-width: 35%;
  }

  /* FAQ LIST: flex column, gap 12px, aligned under header-right (65%) */
  .faq-list {
    display: flex;
    flex-direction: column;
    flex: 1 1 0%;
    max-width: 65%;
    gap: 12px;
  }

  /* FAQ ITEM: wrapper */
  .faq-item {
    width: 100%;
  }

  /* FAQ CARD: black background, rounded corners, padding */
  .faq-card {
    background: rgb(0, 0, 0);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    padding: 20px;
    display: block;
    position: relative;
    box-sizing: border-box;
    opacity: 1;
    height: auto;
    -webkit-font-smoothing: antialiased;
  }

  /* QUESTION ROW: flex row, entire row clickable */
  .faq-question-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    cursor: pointer;
    width: 100%;
  }

  /* Question text: flex-grow, white */
  .faq-question-text {
    font-size: 18px;
    font-weight: 500;
    line-height: 25.2px;
    letter-spacing: -0.36px;
    color: #FFFFFF;
    flex-grow: 1;
  }

  /* Icon button: 40x40px square with hover background */
  .faq-icon {
    aspect-ratio: 1 / 1;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
    transform: none;
    transform-origin: 20px 20px;
    box-sizing: border-box;
    flex-basis: auto;
    flex-grow: 0;
    flex-shrink: 0;
    padding: 10px;
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
    font-size: 24px;
    font-weight: 400;
    color: #FFFFFF;
    -webkit-font-smoothing: antialiased;
  }

  /* SVG icon styling */
  .faq-icon svg {
    width: auto;
    height: auto;
    display: inline;
    cursor: pointer;
    box-sizing: border-box;
    overflow-x: hidden;
    overflow-y: hidden;
    fill: rgb(255, 255, 255);
    font-family: sans-serif;
    font-size: 12px;
    fill-rule: evenodd;
    transform-origin: 0px 0px;
    -webkit-font-smoothing: antialiased;
  }

</style>

<script>
  // Multi-open accordion: track each item's open state independently
  const openItems = new Set();

  document.querySelectorAll('.faq-question-row').forEach((row) => {
    row.addEventListener('click', () => {
      const index = parseInt(row.getAttribute('data-index'));
      const card = row.closest('.faq-card');
      const item = row.closest('.faq-item');

      if (openItems.has(index)) {
        // Close this item
        openItems.delete(index);
        // Remove answer if it exists
        const existingAnswer = card.querySelector('.faq-answer');
        if (existingAnswer) {
          existingAnswer.remove();
        }
      } else {
        // Open this item
        openItems.add(index);
        // Add answer to DOM
        const faqData = {
          0: "Ramp Studio helps brands build momentum through practical marketing education, hands-on execution, and reusable resources.  We offer self-paced courses, a subscription-based marketing retainer, and tools designed to help teams move faster, stay consistent, and make smarter decisions without overcomplicating things.",
          1: "Ramp is built for founders, small teams, and growing companies who want marketing that actually works—not just looks good.  If you're tired of one-off projects, unclear strategy, or starting from scratch every month, Ramp is for you.",
          2: "Our courses are self-paced, practical, and designed to be applied immediately.  They focus on real-world marketing problems—systems, content, positioning, and execution—so you can learn once and reuse the knowledge across campaigns, clients, or teams.",
          3: "The subscription retainer gives you ongoing access to marketing support without the friction of traditional contracts.  Instead of hiring full-time or briefing a new agency every month, you get consistent execution, iterative improvement, and a long-term partner who understands your business.",
          4: "Not at all.  Many clients start with courses or resources to build internal clarity, then move into a subscription when they want execution support. Others use everything together—learning, doing, and scaling at the same time.",
          5: "Ramp Studio is built around momentum.  We focus on clarity, systems, and repeatable outcomes—not buzzwords or one-off wins. Everything we offer is designed to reduce friction, save time, and help marketing compound over time."
        };

        const answerDiv = document.createElement('p');
        answerDiv.className = 'faq-answer';
        answerDiv.textContent = faqData[index] || '';
        // Apply inline styles matching Ramp template design
        answerDiv.style.cssText = `
          font-family: Switzer, "Switzer Placeholder", sans-serif;
          font-size: 16px;
          font-weight: 400;
          line-height: 22.4px;
          color: rgb(122, 122, 122);
          margin: 0;
          padding: 0;
          display: block;
          width: 750px;
          background-color: transparent;
          text-decoration: none;
          letter-spacing: normal;
          text-transform: none;
          user-select: none;
        `;
        card.appendChild(answerDiv);
      }
    });
  });
</script>
