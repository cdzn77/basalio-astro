---
// Ramp FAQ - EXACT SPECIFICATIONS
// Background: #000000 (Black), White text, Accordion with first item expanded

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs?: FAQItem[];
}

const {
  faqs = [
    {
      question: "What does Ramp Studio do?",
      answer: "Ramp Studio helps brands build momentum through practical marketing education, hands-on execution, and ongoing support. We offer courses, resources, and retainer services designed specifically for digital creatives and entrepreneurs."
    },
    {
      question: "Who is Ramp Studio for?",
      answer: "We serve marketers, founders, content creators, and small business owners who want to build scalable marketing systems without feeling overwhelmed. Our content is accessible to beginners while remaining valuable for experienced professionals."
    },
    {
      question: "How do your courses work?",
      answer: "Our courses are self-paced, comprehensive programs that combine video lessons, worksheets, templates, and community support. You get lifetime access to course materials and can work through them at your own pace."
    },
    {
      question: "What is the subscription marketing retainer?",
      answer: "Our retainer service provides ongoing support including design updates, content creation, strategy calls, and email support. We offer Essentials and Premium tiers depending on your needs."
    },
    {
      question: "Do I need to choose between courses, resources, or the retainer?",
      answer: "No! Many clients use a combination of our offerings. You might take a course to learn fundamentals, use resources to accelerate your work, and hire us for retainer support for ongoing execution."
    },
    {
      question: "What makes Ramp Studio different from other marketing agencies?",
      answer: "We combine education with execution. Rather than just doing the work for you, we teach you how to build sustainable systems. Plus, we're transparent about our pricing and focused on serving creative entrepreneurs specifically."
    }
  ]
} = Astro.props;
---

<section class="faq" id="faq">
  <div class="container">
    <div class="faq-header">
      <h2>FAQ</h2>
      <p class="faq-intro">Explore our most commonly asked questions about our agency, podcast, and product launch resources.</p>
    </div>

    <div class="faq-list">
      {faqs.map((item, index) => (
        <div class="faq-item" data-index={index} data-expanded={index === 0}>
          <button class="faq-toggle" aria-expanded={index === 0}>
            <span class="faq-question">{item.question}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer-wrapper">
            <p class="faq-answer">{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const item = button.closest('.faq-item');
      const isExpanded = button.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.faq-item').forEach(el => {
        if (el !== item) {
          el.classList.remove('expanded');
          el.querySelector('.faq-toggle').setAttribute('aria-expanded', 'false');
        }
      });

      button.setAttribute('aria-expanded', !isExpanded);
      item.classList.toggle('expanded');
    });
  });

  // Expand first item by default
  document.querySelector('.faq-item')?.classList.add('expanded');
</script>

<style>
  .faq {
    background: #000000;
    color: #FFFFFF;
    padding: 80px 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .faq-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .faq-header h2 {
    color: #FFFFFF;
    margin: 0 0 16px;
  }

  .faq-intro {
    font-size: 18px;
    line-height: 1.6;
    color: #CCCCCC;
    max-width: 700px;
    margin: 0 auto;
  }

  .faq-list {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .faq-item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 28px 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
  }

  .faq-toggle:hover {
    opacity: 0.8;
  }

  .faq-question {
    font-size: 18px;
    font-weight: 600;
    color: #FFFFFF;
    flex: 1;
  }

  .faq-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    font-size: 20px;
    font-weight: 400;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .faq-item.expanded .faq-icon {
    transform: rotate(45deg);
  }

  .faq-answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.3s ease;
  }

  .faq-item.expanded .faq-answer-wrapper {
    grid-template-rows: 1fr;
  }

  .faq-answer {
    font-size: 16px;
    line-height: 1.7;
    color: #AAAAAA;
    margin: 0;
    padding: 0 0 28px 0;
    min-height: 0;
  }

  @media (max-width: 768px) {
    .faq {
      padding: 60px 0;
    }

    .container {
      padding: 0 20px;
    }

    .faq-header {
      margin-bottom: 40px;
    }

    .faq-toggle {
      padding: 20px 0;
    }

    .faq-question {
      font-size: 16px;
    }

    .faq-answer {
      font-size: 14px;
    }
  }
</style>
