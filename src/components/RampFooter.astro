---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  description?: string;
  productLinks?: NavLink[];
  supportLinks?: NavLink[];
  brandWords?: string[];
}

const {
  description = "Nine curated interaction modules for WordPress portfolios. Nothing you'd need Framer for.",
  productLinks = [
    { label: "Modules", href: "/modules" },
    { label: "Performance", href: "/performance" },
    { label: "Pricing", href: "/pricing" },
    { label: "Roadmap", href: "/roadmap" }
  ],
  supportLinks = [
    { label: "Help center", href: "/help" },
    { label: "Contact", href: "/contact" },
    { label: "Terms of Service", href: "/terms" },
    { label: "Privacy Policy", href: "/privacy" }
  ],
  brandWords = ["BASALIO"]
} = Astro.props;
---

<footer class="footer">
  <div class="footer-inner">
    <!-- Main Content Row -->
    <div class="footer-content-row">
      <!-- LEFT: Logo, Description, Social Icons -->
      <div class="footer-left-section">
        <div class="footer-logo-block">
          <h3 class="footer-logo">🔺 Basalio</h3>
          <p class="footer-description">{description}</p>
        </div>

        <!-- Social Icons -->
        <div class="footer-social-icons">
          <a href="https://x.com/basalio" class="footer-social-link" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.514l-5.106-6.666-5.829 6.666H2.423l7.723-8.835L2.25 2.25h6.514l4.882 6.465L18.244 2.25zM17.41 20.452h1.828L6.282 3.97H4.344l13.066 16.482z"/>
            </svg>
          </a>
          <a href="https://github.com/basalio" class="footer-social-link" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.603-3.369-1.343-3.369-1.343-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.547 2.914 1.186.092-.923.35-1.548.636-1.903-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
          <a href="https://wordpress.org" class="footer-social-link" aria-label="WordPress">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15H8v-6h2v6zm3-10c-.83 0-1.5-.67-1.5-1.5S11.17 4 12 4s1.5.67 1.5 1.5S12.83 7 12 7zm3 10h-2v-6h2v6z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- MIDDLE: Link Columns -->
      <div class="footer-links-section">
        <!-- Product Column -->
        <nav class="footer-link-column">
          <h4 class="footer-column-label">PRODUCT</h4>
          {productLinks.map((link) => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </nav>

        <!-- Support Column -->
        <nav class="footer-link-column">
          <h4 class="footer-column-label">SUPPORT</h4>
          {supportLinks.map((link) => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- RIGHT: Newsletter Section -->
      <div class="footer-right-section">
        <h4 class="footer-column-label">STAY IN THE LOOP</h4>
        <p class="footer-newsletter-text">Get notified when a new module ships. No spam, unsubscribe anytime.</p>
        <div class="footer-newsletter-form">
          <input type="email" placeholder="Email" class="footer-email-input" />
          <button class="footer-subscribe-btn">Subscribe</button>
        </div>
      </div>
    </div>

    <!-- Copyright Row -->
    <div class="footer-copyright-row">
      <p class="footer-copyright-left">© 2026 Basalio. All rights reserved.</p>
      <p class="footer-copyright-right">Built for portfolios. Nothing else.</p>
    </div>

    <!-- BASALIO Branding Row -->
    <div class="footer-branding-row">
      <div class="footer-brand-container">
        <div class="footer-brand-row">
          {brandWords.map((word) => (
            <h2 class="footer-brand-word">{word}</h2>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* FOOTER SHELL */
  .footer {
    background-color: #FFEA00;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  /* FOOTER INNER */
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding: 60px 40px;
    max-width: 1400px;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  /* MAIN CONTENT ROW */
  .footer-content-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 60px;
    align-items: flex-start;
  }

  /* LEFT SECTION: Logo, Description, Social Icons */
  .footer-left-section {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-logo-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-logo {
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
    padding: 0;
  }

  .footer-description {
    font-size: 14px;
    font-weight: 400;
    line-height: 19.6px;
    color: #333333;
    margin: 0;
    padding: 0;
  }

  /* Social Icons */
  .footer-social-icons {
    display: flex;
    flex-direction: row;
    gap: 12px;
    align-items: center;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: #000000;
    text-decoration: none;
    transition: opacity 200ms ease;
  }

  .footer-social-link:hover {
    opacity: 0.6;
  }

  .footer-social-link svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  /* MIDDLE SECTION: Link Columns */
  .footer-links-section {
    display: flex;
    flex-direction: row;
    gap: 80px;
  }

  .footer-link-column {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-column-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #666666;
    margin: 0 0 8px 0;
    padding: 0;
  }

  /* Navigation Links */
  .footer-link {
    font-size: 14px;
    font-weight: 400;
    line-height: 19.6px;
    color: #000000;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 200ms ease;
  }

  .footer-link:hover {
    opacity: 0.6;
  }

  /* RIGHT SECTION: Newsletter */
  .footer-right-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-newsletter-text {
    font-size: 13px;
    font-weight: 400;
    line-height: 18.2px;
    color: #333333;
    margin: 0;
    padding: 0;
  }

  .footer-newsletter-form {
    display: flex;
    flex-direction: row;
    gap: 8px;
    margin-top: 8px;
  }

  .footer-email-input {
    flex: 1;
    padding: 10px 12px;
    border: 1px solid #999999;
    border-radius: 6px;
    background-color: #ffffff;
    color: #000000;
    font-size: 14px;
    font-family: inherit;
  }

  .footer-email-input::placeholder {
    color: #999999;
  }

  .footer-subscribe-btn {
    padding: 10px 16px;
    background-color: #000000;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 200ms ease;
    text-transform: uppercase;
    letter-spacing: 0.7px;
  }

  .footer-subscribe-btn:hover {
    opacity: 0.8;
  }

  /* COPYRIGHT ROW */
  .footer-copyright-row {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
  }

  .footer-copyright-left {
    font-size: 12px;
    font-weight: 400;
    color: #333333;
    margin: 0;
    padding: 0;
  }

  .footer-copyright-right {
    font-size: 12px;
    font-weight: 400;
    color: #333333;
    margin: 0;
    padding: 0;
  }

  /* BRANDING ROW */
  .footer-branding-row {
    margin: 60px -40px -40px -40px;
    padding: 60px 40px;
  }

  .footer-brand-container {
    width: 100%;
  }

  .footer-brand-row {
    display: flex;
    flex-direction: row;
    gap: 0;
    white-space: nowrap;
    width: 100vw;
    justify-content: center;
    align-items: center;
    margin-left: calc(-50vw + 50%);
  }

  .footer-brand-word {
    font-size: clamp(100px, 18vw, 380px);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: #000000;
    margin: 0;
    padding: 0;
    display: inline-block;
    white-space: nowrap;
    line-height: 1;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .footer-content-row {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .footer-links-section {
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .footer-inner {
      padding: 40px 20px;
    }

    .footer-content-row {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .footer-links-section {
      flex-direction: column;
      gap: 30px;
    }

    .footer-newsletter-form {
      flex-direction: column;
    }

    .footer-copyright-row {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }

    .footer-branding-row {
      margin: 40px -20px -20px -20px;
      padding: 40px 20px;
    }

    .footer-brand-word {
      font-size: 80px;
      letter-spacing: -3px;
    }
  }
</style>
