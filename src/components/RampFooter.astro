---
// Ramp Footer - Structural skeleton
// Row 1: Address (26px, 35% left) + Navigation (16px, 65% right)
// Row 2: Four brand words (170px, -8.5px letter-spacing, static - no marquee animation yet)

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  address?: string;
  column1Links?: NavLink[];
  column2Links?: NavLink[];
  brandWords?: string[];
}

const {
  address = "Østerbrogade 45, 2100 København Ø, Copenhagen, Denmark",
  column1Links = [
    { label: "Courses", href: "/courses" },
    { label: "Subscription", href: "/subscription" },
    { label: "Resources", href: "/resources" },
    { label: "Contact", href: "/contact" }
  ],
  column2Links = [
    { label: "Terms & Conditions", href: "/terms" },
    { label: "Privacy Policy", href: "/privacy" }
  ],
  brandWords = ["Ramp", "Studio.", "Creative.", "Collective."]
} = Astro.props;
---

<footer class="footer">
  <div class="footer-inner">
    <!-- ROW 1: Address + Navigation -->
    <div class="footer-row-1">
      <!-- LEFT: Address (35%) -->
      <div class="footer-address-block">
        <p class="footer-address">{address}</p>
      </div>

      <!-- RIGHT: Navigation (65%) -->
      <div class="footer-nav-block">
        <!-- Nav Column 1 -->
        <nav class="footer-nav-column">
          {column1Links.map((link) => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </nav>

        <!-- Nav Column 2 -->
        <nav class="footer-nav-column">
          {column2Links.map((link) => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </nav>
      </div>
    </div>

    <!-- ROW 2: Brand Statement (Static - No Animation Yet) -->
    <div class="footer-row-2">
      <div class="footer-brand-container">
        <div class="footer-brand-row">
          {brandWords.map((word) => (
            <h2 class="footer-brand-word">{word}</h2>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* FOOTER SHELL */
  .footer {
    background: #FFEA00;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }


  /* FOOTER INNER: Padding wrapper, two rows with 40px gap */
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding: 80px 40px;
    max-width: 1400px;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  /* ROW 1: Address + Navigation */
  .footer-row-1 {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 40px;
    align-items: flex-start;
  }

  /* LEFT: Address (35%) */
  .footer-address-block {
    flex: 0 1 35%;
    min-width: 0;
  }

  .footer-address {
    font-size: 26px;
    font-weight: 400;
    line-height: 32.5px;
    color: var(--color-text, #000000);
    margin: 0;
    padding: 0;
  }

  /* RIGHT: Navigation (65%) */
  .footer-nav-block {
    flex: 0 1 65%;
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    gap: 60px;
  }

  /* Navigation Column */
  .footer-nav-column {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Navigation Links - SIMPLE HOVER STATE: opacity shift (not crossfade) */
  .footer-link {
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    color: var(--color-text, #000000);
    text-decoration: none;
    cursor: pointer;
    transition: opacity 200ms ease;
  }

  .footer-link:hover {
    opacity: 0.6;
  }

  /* ROW 2: Brand Statement Container */
  .footer-row-2 {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Brand Statement Container */
  .footer-brand-container {
    width: 100%;
  }

  /* Brand Word Row (STATIC VERSION - fills full width) */
  .footer-brand-row {
    display: flex;
    flex-direction: row;
    gap: 0;
    white-space: nowrap;
    width: 100%;
  }

  /* Brand Words: responsive sizing to fill width */
  .footer-brand-word {
    font-size: clamp(120px, 25vw, 600px);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--color-text, #000000);
    margin: 0;
    padding: 0;
    display: inline-block;
    white-space: nowrap;
    line-height: 1;
  }

  /* Responsive: mobile stacking and scaled-down branding */
  @media (max-width: 768px) {
    .footer-inner {
      padding: 60px 20px;
    }

    .footer-row-1 {
      flex-direction: column;
      gap: 40px;
    }

    .footer-address-block,
    .footer-nav-block {
      flex: 1;
      max-width: 100%;
    }

    .footer-nav-block {
      justify-content: flex-start;
    }

    .footer-address {
      font-size: 18px;
      line-height: 24px;
    }

    .footer-link {
      font-size: 14px;
      line-height: 20px;
    }

    .footer-brand-word {
      font-size: 80px;
      letter-spacing: -4px;
    }
  }
</style>
