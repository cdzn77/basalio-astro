---
// Ramp Header - EXACT SPECIFICATIONS
// Logo: Manrope 30px 600, Menu button: black bg, white text

interface Props {
  brand?: string;
}

const { brand = "Ramp Studio." } = Astro.props;
---

<div class="header-container">
  <a href="/index-ramp-rebuild" class="brand-logo">{brand}</a>
  <div class="menu-wrapper">
    <button id="menu-toggle" class="menu-btn" aria-label="Toggle menu">
      <span>MENU</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" class="plus-icon">
        <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
      </svg>
    </button>

    <!-- Menu Dropdown -->
    <div class="menu-dropdown" id="menu-dropdown">
      <a href="/index-ramp-rebuild" class="menu-item">HOME</a>
      <a href="/courses" class="menu-item">COURSES</a>
      <a href="/subscription" class="menu-item">SUBSCRIPTION</a>
      <a href="/resources" class="menu-item">RESOURCES</a>
      <a href="/contact" class="menu-item">CONTACT</a>
    </div>
  </div>
</div>

<script>
  // Add scroll handler for header background change
  const header = document.querySelector('.ramp-header');

  function handleScroll() {
    if (window.scrollY > 100) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });

  // Menu toggle functionality
  const menuToggle = document.getElementById('menu-toggle');
  const menuDropdown = document.getElementById('menu-dropdown');

  if (menuToggle && menuDropdown) {
    // Toggle menu on button click
    menuToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      menuDropdown.classList.toggle('active');
    });

    // Close menu when clicking on a menu item
    menuDropdown.querySelectorAll('.menu-item').forEach(item => {
      item.addEventListener('click', () => {
        menuDropdown.classList.remove('active');
      });
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (!menuToggle.contains(e.target) && !menuDropdown.contains(e.target)) {
        menuDropdown.classList.remove('active');
      }
    });
  }
</script>

<style>
  .header-container {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    box-sizing: border-box;
  }

  .brand-logo {
    background-color: rgba(0, 0, 0, 0);
    box-sizing: border-box;
    color: rgb(0, 0, 0);
    cursor: pointer;
    display: inline;
    font-family: Manrope, "Manrope Placeholder", sans-serif;
    font-size: 30px;
    font-weight: 600;
    height: auto;
    letter-spacing: -1.5px;
    line-height: 30px;
    padding: 0;
    text-align: start;
    text-decoration: none;
    text-wrap-mode: nowrap;
    transition: color 0.3s cubic-bezier(0, 0, 1, 1);
    width: auto;
    -webkit-font-smoothing: antialiased;
  }

  .brand-logo:hover {
    color: rgb(0, 0, 0);
  }

  .menu-btn {
    background: #000000;
    color: #FFFFFF;
    border: none;
    padding: 0px 16px;
    border-radius: 6px;
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 182px;
    height: 41px;
  }

  .menu-btn:hover {
    opacity: 0.8;
  }

  .plus-icon {
    flex-shrink: 0;
  }

  /* MENU DROPDOWN */
  .menu-wrapper {
    position: relative;
  }

  .menu-dropdown {
    position: absolute;
    top: 36px;
    right: 0;
    width: 182px;
    height: auto;
    background: #000000;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
    box-shadow: rgba(0, 0, 0, 0.05) 0px 10px 20px 0px;
    display: flex;
    flex-direction: column;
    align-items: center;
    align-content: center;
    justify-content: center;
    padding: 8px 16px;
    box-sizing: border-box;
    row-gap: 1px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 10;
  }

  .menu-dropdown.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .menu-item {
    width: 150px;
    height: 40px;
    background: rgba(255, 222, 222, 0);
    border-radius: 15px;
    display: flex;
    flex-direction: row;
    align-items: center;
    align-content: center;
    justify-content: flex-start;
    padding: 10px 0px;
    column-gap: 15px;
    row-gap: 15px;
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #FFFFFF;
    text-decoration: none;
    cursor: pointer;
    box-sizing: border-box;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .menu-item:hover {
    color: #FFEA00;
  }

  @media (max-width: 768px) {
    .header-container {
      padding: 0 20px;
      height: 60px;
    }

    .brand-logo {
      font-size: 24px;
    }

    .menu-btn {
      width: 160px;
      height: 36px;
      padding: 0px 12px;
      font-size: 12px;
    }

    .menu-dropdown {
      width: 160px;
      height: auto;
    }
  }
</style>
