---
// Ramp Hero - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions from original: 1791×914px
// Hero container: 1791×840px with 74px course teaser

interface Props {
  courseLabel?: string;
  courseText?: string;
  courseButton?: string;
  courseLink?: string;
  heroImage?: string;
}

const {
  courseLabel = "COACHING OFFERS 101",
  courseText = "This course helps you design clear, compelling offers that people actually understand and want to buy.",
  courseButton = "VIEW COURSE",
  courseLink = "#courses",
  heroImage = "https://framerusercontent.com/images/WAxIIZFwFsal6BUSuk7mft7nN7U.png"
} = Astro.props;
---

<section class="hero" id="hero">
  <!-- IMAGE WRAPPER: Multi-layer carousel expanding from portrait to landscape -->
  <div class="hero-image-wrapper">
    <!-- Layer 1: Portrait (20% width) -->
    <div class="image-layer layer-1" data-layer="1">
      <img src={heroImage} alt="Hero layer 1" class="hero-image-bg" />
    </div>
    <!-- Layer 2: Expanding (40% width) -->
    <div class="image-layer layer-2" data-layer="2">
      <img src={heroImage} alt="Hero layer 2" class="hero-image-bg" />
    </div>
    <!-- Layer 3: Expanding (60% width) -->
    <div class="image-layer layer-3" data-layer="3">
      <img src={heroImage} alt="Hero layer 3" class="hero-image-bg" />
    </div>
    <!-- Layer 4: Expanding (80% width) -->
    <div class="image-layer layer-4" data-layer="4">
      <img src={heroImage} alt="Hero layer 4" class="hero-image-bg" />
    </div>
    <!-- Layer 5: Full width (100%+) -->
    <div class="image-layer layer-5" data-layer="5">
      <img src={heroImage} alt="Hero layer 5" class="hero-image-bg" />
    </div>
  </div>

  <!-- HEADER: Logo + Menu Button -->
  <div class="hero-header">
    <a href="/" class="brand-logo">Ramp Studio.</a>
    <div class="menu-wrapper">
      <button class="menu-btn" id="menu-toggle">
        <span>MENU</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" class="plus-icon">
          <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
        </svg>
      </button>

      <!-- Menu Dropdown -->
      <div class="menu-dropdown" id="menu-dropdown">
        <a href="#courses" class="menu-item">COURSES</a>
        <a href="#subscription" class="menu-item">SUBSCRIPTION</a>
        <a href="#resources" class="menu-item">RESOURCES</a>
        <a href="#about" class="menu-item">ABOUT</a>
        <a href="#contact" class="menu-item">CONTACT</a>
      </div>
    </div>
  </div>

  <div class="hero-container">
    <!-- Empty container - image fills the space -->
  </div>

  <!-- BOTTOM: Course Teaser (74px height) -->
  <div class="course-teaser">
    <div class="course-left">
      <p class="course-label">{courseLabel}</p>
      <p class="course-description">{courseText}</p>
    </div>
    <a href={courseLink} class="btn-view-course">
      <span class="btn-text">{courseButton}</span>
      <span class="btn-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 8H15M15 8L8 1M15 8L8 15"></path>
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - RESPONSIVE VERSION */
  .hero {
    background: #FFEA00;
    width: 100%;
    max-width: 1791px;
    height: 100vh;
    padding: 0;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: hidden;
    position: relative;
  }

  /* HEADER: Logo + Menu Button - Positioned at top of hero */
  .hero-header {
    width: 100%;
    height: 80px;
    padding: 16px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #FFEA00;
    box-sizing: border-box;
    position: relative;
    z-index: 3;
  }

  .brand-logo {
    font-family: 'Manrope', sans-serif;
    font-size: 30px;
    font-weight: 600;
    color: #000000;
    text-decoration: none;
    margin: 0;
    padding: 0;
  }

  .brand-logo:hover {
    opacity: 0.7;
  }

  .menu-btn {
    background: #000000;
    color: #FFFFFF;
    border: none;
    padding: 0px 16px;
    border-radius: 6px;
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 182px;
    height: 41px;
  }

  .plus-icon {
    flex-shrink: 0;
  }

  .hero-container {
    width: 100%;
    max-width: 1791px;
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  /* Image wrapper - carousel container, expands from portrait to landscape */
  .hero-image-wrapper {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 20%;
    height: auto;
    aspect-ratio: 0.4;
    overflow: visible;
    z-index: 0;
    pointer-events: none;
    border-radius: 1.67975% / 1.25982%;
    will-change: width;
  }

  /* Image layers - carousel effect (opacity controlled by JavaScript) */
  .image-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    will-change: opacity, transform;
  }

  /* Hero image - fills the layer container */
  .hero-image-bg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: sepia(0.15) saturate(1.3);
    opacity: 0.95;
    border-radius: inherit;
  }

  .hero-left {
    width: 50%;
    padding: 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .hero-heading {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.44px;
    color: #000000;
    margin: 0;
    padding: 0;
    margin-top: 0;
  }


  /* COURSE TEASER CARD - Positioned at bottom of hero with semi-transparent background */
  .course-teaser {
    width: 100%;
    max-width: 1791px;
    padding: 40px 40px;
    background: rgba(255, 234, 0, 0.65);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    z-index: 2;
    backdrop-filter: blur(3px);
  }

  .course-left {
    flex: 0 1 auto;
    max-width: 365px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .course-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    line-height: 19.6px;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    display: block;
    width: auto;
    height: auto;
    margin: 0 0 12px 0;
    padding: 0;
    cursor: pointer;
    transition: color 0.3s cubic-bezier(0, 0, 1, 1);
    text-wrap-style: balance;
  }

  .course-description {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    color: #000000;
    width: 500px;
    margin: 0;
    padding: 0;
    text-wrap-style: balance;
  }

  .btn-view-course {
    background: transparent;
    color: #FFFFFF;
    padding: 0;
    border-radius: 0;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
    text-decoration: none;
    cursor: pointer;
    border: none;
    height: 44px;
    transition: opacity 0.3s ease;
    font-family: 'Azeret Mono', monospace;
    overflow: visible;
  }

  .btn-text {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    border-radius: 8px;
    background: #000000;
    height: 44px;
    flex: 0 0 auto;
    box-sizing: border-box;
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0px;
    border-radius: 8px;
    background: #000000;
    width: 40px;
    height: 44px;
    flex: 0 0 auto;
  }

  .btn-icon svg {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .btn-view-course:hover .btn-icon svg {
    transform: translateX(8px);
  }

  .btn-view-course:hover {
    opacity: 0.8;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .hero {
      width: 100%;
      height: auto;
    }

    .hero-container {
      width: 100%;
      height: auto;
      flex-direction: column;
    }

    .hero-left, .hero-right {
      width: 100%;
    }

    .course-teaser {
      width: 100%;
      flex-direction: column;
      height: auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      width: 100%;
    }

    .hero-heading {
      font-size: 48px;
      line-height: 48px;
    }

    .hero-image {
      width: 100%;
      height: auto;
    }
  }

  /* MENU DROPDOWN */
  .menu-wrapper {
    position: relative;
  }

  .menu-dropdown {
    position: absolute;
    top: 36px;
    right: 0;
    width: 182px;
    height: 218px;
    background: #000000;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
    box-shadow: rgba(0, 0, 0, 0.05) 0px 10px 20px 0px;
    display: flex;
    flex-direction: column;
    align-items: center;
    align-content: center;
    justify-content: center;
    padding: 8px 16px;
    box-sizing: border-box;
    row-gap: 1px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 10;
  }

  .menu-dropdown.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .menu-item {
    width: 150px;
    height: 40px;
    background: rgba(255, 222, 222, 0);
    border-radius: 15px;
    display: flex;
    flex-direction: row;
    align-items: center;
    align-content: center;
    justify-content: flex-start;
    padding: 10px 0px;
    column-gap: 15px;
    row-gap: 15px;
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #FFFFFF;
    text-decoration: none;
    cursor: pointer;
    box-sizing: border-box;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .menu-item:hover {
    color: #FFEA00;
  }
</style>

<script>
  // Menu toggle functionality
  const menuToggle = document.getElementById('menu-toggle');
  const menuDropdown = document.getElementById('menu-dropdown');

  if (menuToggle && menuDropdown) {
    // Toggle menu on button click
    menuToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      menuDropdown.classList.toggle('active');
    });

    // Close menu when clicking on a menu item
    menuDropdown.querySelectorAll('.menu-item').forEach(item => {
      item.addEventListener('click', () => {
        menuDropdown.classList.remove('active');
      });
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (!menuToggle.contains(e.target) && !menuDropdown.contains(e.target)) {
        menuDropdown.classList.remove('active');
      }
    });
  }

  // Scroll-driven multi-layer carousel animation
  const heroSection = document.getElementById('hero');
  const imageWrapper = document.querySelector('.hero-image-wrapper');
  const imageLayers = document.querySelectorAll('.image-layer');

  if (imageWrapper && heroSection && imageLayers.length > 0) {
    let animationFrameId;

    const updateCarousel = () => {
      const heroRect = heroSection.getBoundingClientRect();
      const distanceTraveled = -heroRect.top;
      const viewportHeight = window.innerHeight;

      // Scroll progress: 0 at top, 1 when hero exits
      const scrollProgress = Math.max(0, Math.min(1, distanceTraveled / (viewportHeight * 0.25)));

      // Expand width from 20% to 120% (portrait to full width + overflow)
      const width = 20 + (scrollProgress * 100);
      imageWrapper.style.width = `${width}%`;

      // Carousel effect: show different layers as expansion progresses
      // Divide progress into 5 stages (0-0.2, 0.2-0.4, 0.4-0.6, 0.6-0.8, 0.8-1.0)
      imageLayers.forEach((layer, index) => {
        const layerStart = index * 0.2;
        const layerEnd = (index + 1) * 0.2;
        const layerMid = (layerStart + layerEnd) / 2;

        // Calculate opacity for smooth fade transition
        let opacity = 0;

        // Layer 1 (index 0) starts fully visible
        if (index === 0) {
          if (scrollProgress < layerEnd - 0.1) {
            opacity = 1;
          } else if (scrollProgress < layerEnd) {
            opacity = (layerEnd - scrollProgress) / 0.1;
          }
        } else {
          // Other layers fade in and out
          if (scrollProgress >= layerStart && scrollProgress < layerEnd) {
            if (scrollProgress < layerStart + 0.1) {
              opacity = (scrollProgress - layerStart) / 0.1;
            } else if (scrollProgress > layerEnd - 0.1) {
              opacity = (layerEnd - scrollProgress) / 0.1;
            } else {
              opacity = 1;
            }
          }
        }

        layer.style.opacity = Math.max(0, Math.min(1, opacity));
      });
    };

    const handleScroll = () => {
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
      }
      animationFrameId = requestAnimationFrame(updateCarousel);
    };

    window.addEventListener('scroll', handleScroll, { passive: true });

    // Initialize all layers with 0 opacity
    imageLayers.forEach((layer, index) => {
      layer.style.opacity = index === 0 ? '1' : '0';
    });

    // Initial call
    updateCarousel();
  }
</script>
