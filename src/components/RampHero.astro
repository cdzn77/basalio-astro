---
// Ramp Hero - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions from original: 1791×914px
// Hero container: 1791×840px with 74px course teaser

interface Props {
  courseLabel?: string;
  courseText?: string;
  courseButton?: string;
  courseLink?: string;
  heroImage?: string;
}

const {
  courseLabel = "COACHING OFFERS 101",
  courseText = "This course helps you design clear, compelling offers that people actually understand and want to buy.",
  courseButton = "VIEW COURSE",
  courseLink = "#courses",
  heroImage = "https://framerusercontent.com/images/WAxIIZFwFsal6BUSuk7mft7nN7U.png"
} = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero-container">
    <!-- LEFT: Heading -->
    <div class="hero-left">
      <h1 class="hero-heading">We turn<br/>strategy<br/>into growth</h1>
    </div>

    <!-- RIGHT: Image -->
    <div class="hero-right">
      <img src={heroImage} alt="Hero" class="hero-image" />
    </div>
  </div>

  <!-- BOTTOM: Course Teaser (74px height) -->
  <div class="course-teaser">
    <div class="course-left">
      <p class="course-label">{courseLabel}</p>
      <p class="course-description">{courseText}</p>
    </div>
    <a href={courseLink} class="btn-view-course">
      {courseButton}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 8H15M15 8L8 1M15 8L8 15"></path>
      </svg>
    </a>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS */
  .hero {
    background: #FFEA00;
    width: 1791px;
    height: 914px;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .hero-container {
    width: 1791px;
    height: 840px;
    display: flex;
    flex-direction: row;
    gap: 0;
  }

  .hero-left {
    width: 50%;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-heading {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.44px;
    color: #000000;
    margin: 0;
    padding: 0;
  }

  .hero-right {
    width: 50%;
    padding: 80px 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image {
    width: 326px;
    height: 434px;
    object-fit: cover;
    display: block;
  }

  /* COURSE TEASER CARD - Exact 74px height */
  .course-teaser {
    width: 1791px;
    height: 74px;
    padding: 24px 40px;
    background: #FFEA00;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }

  .course-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .course-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #575757;
    margin: 0;
    line-height: 12px;
  }

  .course-description {
    font-size: 12px;
    font-weight: 400;
    color: #000000;
    margin: 0;
    line-height: 12px;
  }

  .btn-view-course {
    background: #000000;
    color: #FFFFFF;
    padding: 12px 20px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    text-decoration: none;
    cursor: pointer;
    border: none;
    height: 41px;
    transition: opacity 0.3s ease;
  }

  .btn-view-course:hover {
    opacity: 0.8;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .hero {
      width: 100%;
      height: auto;
    }

    .hero-container {
      width: 100%;
      height: auto;
      flex-direction: column;
    }

    .hero-left, .hero-right {
      width: 100%;
    }

    .course-teaser {
      width: 100%;
      flex-direction: column;
      height: auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      width: 100%;
    }

    .hero-heading {
      font-size: 48px;
      line-height: 48px;
    }

    .hero-image {
      width: 100%;
      height: auto;
    }
  }
</style>
