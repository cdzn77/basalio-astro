---
// Ramp Hero - EXACT SPECIFICATIONS
// Height: 858px, Parallax via overflow:clip
// Heading: Switzer 72px, -1.44px letter-spacing, 3 lines
// Course card: Absolutely positioned at top 744px

interface Props {
  courseLabel?: string;
  courseText?: string;
  courseButton?: string;
  courseLink?: string;
  heroImages?: string[];
}

const {
  courseLabel = "COACHING OFFERS 101",
  courseText = "This course helps you design clear, compelling offers that people actually understand and want to buy.",
  courseButton = "VIEW COURSE",
  courseLink = "#courses",
  heroImages = [
    "https://via.placeholder.com/1791x2388",
    "https://via.placeholder.com/1791x2388"
  ]
} = Astro.props;
---

<header class="hero" id="hero">
  <div class="hero-inner">
    <!-- Heading Container (Left side, fixed relative to hero) -->
    <div class="heading-container">
      <h1 class="hero-heading">We turn</h1>
      <h1 class="hero-heading">strategy</h1>
      <h1 class="hero-heading">into growth</h1>
    </div>

    <!-- Images Container (Large, for parallax effect via overflow:clip) -->
    <div class="images-container">
      {heroImages.map((image) => (
        <img src={image} alt="hero section placeholder image" class="hero-image" />
      ))}
    </div>

    <!-- Course Teaser Card (Absolutely positioned at bottom of hero) -->
    <div class="course-teaser">
      <p class="course-label">{courseLabel}</p>
      <p class="course-description">{courseText}</p>
      <a href={courseLink} class="btn btn-view-course">
        {courseButton}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 7H13M13 7L7 1M13 7L7 13"></path>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .hero {
    background: #FFEA00;
    height: 858px;
    position: relative;
    overflow: clip;
    padding: 0;
    margin: 0;
  }

  .hero-inner {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: row;
  }

  /* HEADING CONTAINER - Left side, absolutely positioned */
  .heading-container {
    position: absolute;
    top: 110px;
    left: 40px;
    width: 600px;
    height: 254px;
    display: flex;
    flex-direction: column;
    gap: 0;
    z-index: 10;
  }

  .hero-heading {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.44px;
    color: #000000;
    margin: 0;
    padding: 0;
  }

  /* IMAGES CONTAINER - Static flow but large (2388px) to create parallax */
  .images-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: auto;
  }

  .hero-image {
    width: 100%;
    height: 2388px;
    display: block;
    object-fit: cover;
    object-position: 50% 50%;
  }

  /* COURSE TEASER CARD - Absolutely positioned at bottom of hero, overlapping section boundary */
  .course-teaser {
    position: absolute;
    top: 744px;
    left: 40px;
    right: 40px;
    width: calc(100% - 80px);
    max-width: 1711px;
    height: 74px;
    background: #FFFFFF;
    border-radius: 6px;
    padding: 16px 24px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    z-index: 15;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .course-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #575757;
    margin: 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .course-description {
    font-size: 12px;
    font-weight: 400;
    color: #000000;
    margin: 0;
    line-height: 1.4;
    flex: 1;
  }

  .btn-view-course {
    background: #000000;
    color: #FFFFFF;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .btn-view-course:hover {
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .course-teaser {
      height: auto;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      top: 700px;
    }

    .course-label {
      font-size: 12px;
    }

    .course-description {
      font-size: 11px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 600px;
      overflow: hidden;
    }

    .heading-container {
      top: 80px;
      left: 20px;
      width: calc(100% - 40px);
      height: auto;
    }

    .hero-heading {
      font-size: 48px;
      line-height: 48px;
      letter-spacing: -0.96px;
    }

    .hero-image {
      height: 1200px;
    }

    .course-teaser {
      top: 500px;
      left: 20px;
      right: 20px;
      width: calc(100% - 40px);
      height: auto;
      padding: 12px 16px;
      flex-direction: column;
      align-items: flex-start;
    }

    .btn-view-course {
      align-self: flex-start;
      padding: 10px 14px;
      font-size: 11px;
    }
  }
</style>
