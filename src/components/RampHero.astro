---
// Ramp Hero - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions from original: 1791×914px
// Hero container: 1791×840px with 74px course teaser

interface Props {
  courseLabel?: string;
  courseText?: string;
  courseButton?: string;
  courseLink?: string;
  heroImage?: string;
}

const {
  courseLabel = "COACHING OFFERS 101",
  courseText = "This course helps you design clear, compelling offers that people actually understand and want to buy.",
  courseButton = "VIEW COURSE",
  courseLink = "#courses",
  heroImage = "https://framerusercontent.com/images/WAxIIZFwFsal6BUSuk7mft7nN7U.png"
} = Astro.props;
---

<section class="hero" id="hero">
  <!-- HERO IMAGE: Static centered image -->
  <div class="hero-image-wrapper">
    <img src={heroImage} alt="Hero" class="hero-image-bg" />
  </div>

  <div class="hero-container">
    <!-- LEFT: Heading overlaid on image -->
    <div class="hero-left">
      <h1 class="hero-heading">We turn<br/>strategy<br/>into growth</h1>
    </div>
  </div>

  <!-- BOTTOM: Course Teaser (74px height) -->
  <div class="course-teaser">
    <div class="course-left">
      <p class="course-label">{courseLabel}</p>
      <p class="course-description">{courseText}</p>
    </div>
    <a href={courseLink} class="btn-view-course">
      <div class="btn-text-box">
        <div class="btn-text-wrapper">
          <p class="btn-text-content">{courseButton}</p>
        </div>
      </div>
      <div class="btn-arrow-box">
        <div class="btn-arrow btn-arrow-left">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
            <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
            <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
          </svg>
        </div>
        <div class="btn-arrow btn-arrow-right">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
            <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
            <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
          </svg>
        </div>
      </div>
    </a>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - RESPONSIVE VERSION */
  .hero {
    background: #FFEA00;
    width: 100%;
    max-width: 1791px;
    min-height: 100vh;
    padding: 0;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: visible;
    position: relative;
  }

  /* Hero uses layout's universal header via slot */

  .hero-container {
    width: 100%;
    max-width: 1791px;
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    overflow: visible;
    z-index: 1;
  }

  /* Image wrapper - static centered image */
  .hero-image-wrapper {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 28%;
    max-width: 400px;
    aspect-ratio: 0.7;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
    border-radius: 8px;
  }

  /* Hero image - fills the wrapper */
  .hero-image-bg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: sepia(0.25) saturate(1.1) hue-rotate(-15deg);
    opacity: 0.95;
  }

  .hero-left {
    width: 50%;
    padding: 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .hero-heading {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.44px;
    color: #000000;
    margin: 0;
    padding: 0;
    margin-top: 80px;
  }


  /* COURSE TEASER CARD - Transparent, shows image behind */
  .course-teaser {
    width: 100%;
    max-width: 1791px;
    padding: 40px 40px;
    background: transparent;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .course-left {
    flex: 0 1 auto;
    max-width: 365px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .course-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    line-height: 19.6px;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    display: block;
    width: auto;
    height: auto;
    margin: 0 0 12px 0;
    padding: 0;
    cursor: pointer;
    transition: color 0.3s cubic-bezier(0, 0, 1, 1);
    text-wrap-style: balance;
  }

  .course-description {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    color: #000000;
    width: 500px;
    margin: 0;
    padding: 0;
    text-wrap-style: balance;
  }

  .btn-view-course {
    display: flex;
    flex-direction: row;
    height: 43.6px;
    cursor: pointer;
    position: relative;
    opacity: 1;
    background: transparent;
    border: none;
    padding: 0;
    text-decoration: none;
    -webkit-font-smoothing: antialiased;
  }

  .btn-text-box {
    background-color: #000000;
    border-radius: 8px;
    height: 43.6px;
    padding: 12px 16px;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    column-gap: 10px;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .btn-text-wrapper {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    box-sizing: border-box;
  }

  .btn-text-content {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    line-height: 19.6px;
    text-transform: uppercase;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    white-space: nowrap;
    height: 19.6px;
  }

  .btn-arrow-box {
    background-color: #000000;
    border-radius: 8px;
    height: 43.6px;
    width: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    column-gap: 10px;
    flex-shrink: 0;
    position: relative;
  }

  .btn-arrow {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 16px;
    width: 16px;
    position: absolute;
    will-change: transform;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .btn-arrow-left {
    opacity: 0;
    transform: translateX(-8px);
  }

  .btn-arrow-right {
    opacity: 1;
    transform: translateX(0);
  }

  .btn-arrow svg {
    height: 100%;
    width: 100%;
    stroke: #FFFFFF;
    stroke-width: 1.5px;
    fill: none;
    stroke-miterlimit: 10;
  }

  .btn-view-course:hover .btn-arrow-left {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }

  .btn-view-course:hover .btn-arrow-right {
    opacity: 0 !important;
    transform: translateX(8px) !important;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .hero {
      width: 100%;
      height: auto;
    }

    .hero-container {
      width: 100%;
      height: auto;
      flex-direction: column;
    }

    .hero-left, .hero-right {
      width: 100%;
    }

    .course-teaser {
      width: 100%;
      flex-direction: column;
      height: auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      width: 100%;
    }

    .hero-heading {
      font-size: 48px;
      line-height: 48px;
    }

    .hero-image {
      width: 100%;
      height: auto;
    }
  }

  /* Menu dropdown is now in RampHeader component */
</style>

<!-- Menu functionality is now in RampHeader component -->
