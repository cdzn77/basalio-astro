---
// Ramp Hero - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions from original: 1791×914px
// Hero container: 1791×840px with 74px course teaser

interface Props {
  courseLabel?: string;
  courseText?: string;
  courseButton?: string;
  courseLink?: string;
  heroImage?: string;
}

const {
  courseLabel = "COACHING OFFERS 101",
  courseText = "This course helps you design clear, compelling offers that people actually understand and want to buy.",
  courseButton = "VIEW COURSE",
  courseLink = "#courses",
  heroImage = "https://framerusercontent.com/images/WAxIIZFwFsal6BUSuk7mft7nN7U.png"
} = Astro.props;
---

<section class="hero" id="hero">
  <!-- HEADER: Logo + Menu Button -->
  <div class="hero-header">
    <a href="/" class="brand-logo">Ramp Studio.</a>
    <div class="menu-wrapper">
      <button class="menu-btn" id="menu-toggle">
        <span>MENU</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" class="plus-icon">
          <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
        </svg>
      </button>

      <!-- Menu Dropdown -->
      <div class="menu-dropdown" id="menu-dropdown">
        <a href="#courses" class="menu-item">COURSES</a>
        <a href="#subscription" class="menu-item">SUBSCRIPTION</a>
        <a href="#resources" class="menu-item">RESOURCES</a>
        <a href="#about" class="menu-item">ABOUT</a>
        <a href="#contact" class="menu-item">CONTACT</a>
      </div>
    </div>
  </div>

  <div class="hero-container">
    <!-- CENTERED IMAGE with overlay (absolute positioning) -->
    <img src={heroImage} alt="Hero" class="hero-image-bg" />

    <!-- LEFT: Heading (overlaid on top of image) -->
    <div class="hero-left">
      <h1 class="hero-heading">We turn<br/>strategy<br/>into growth</h1>
    </div>
  </div>

  <!-- BOTTOM: Course Teaser (74px height) -->
  <div class="course-teaser">
    <div class="course-left">
      <p class="course-label">{courseLabel}</p>
      <p class="course-description">{courseText}</p>
    </div>
    <a href={courseLink} class="btn-view-course">
      <span class="btn-text">{courseButton}</span>
      <span class="btn-icon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 8H15M15 8L8 1M15 8L8 15"></path>
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - RESPONSIVE VERSION */
  .hero {
    background: #FFEA00;
    width: 100%;
    max-width: 1791px;
    height: 914px;
    padding: 0;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* HEADER: Logo + Menu Button - Positioned at top of hero */
  .hero-header {
    width: 100%;
    height: 80px;
    padding: 16px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #FFEA00;
    box-sizing: border-box;
  }

  .brand-logo {
    font-family: 'Manrope', sans-serif;
    font-size: 30px;
    font-weight: 600;
    color: #000000;
    text-decoration: none;
    margin: 0;
    padding: 0;
  }

  .brand-logo:hover {
    opacity: 0.7;
  }

  .menu-btn {
    background: #000000;
    color: #FFFFFF;
    border: none;
    padding: 0px 16px;
    border-radius: 6px;
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 182px;
    height: 41px;
  }

  .plus-icon {
    flex-shrink: 0;
  }

  .hero-container {
    width: 100%;
    max-width: 1791px;
    height: 760px;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  /* CENTERED HERO IMAGE with yellow overlay */
  .hero-image-bg {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: auto;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: sepia(0.15) saturate(1.3);
    opacity: 0.95;
    z-index: 0;
  }

  .hero-left {
    width: 50%;
    padding: 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .hero-heading {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.44px;
    color: #000000;
    margin: 0;
    padding: 0;
    margin-top: 0;
  }


  /* COURSE TEASER CARD - Exact 74px height */
  .course-teaser {
    width: 100%;
    max-width: 1791px;
    height: 74px;
    padding: 24px 40px 50px 40px;
    background: #FFEA00;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .course-left {
    flex: 0 1 auto;
    max-width: 365px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .course-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
    line-height: 13px;
  }

  .course-description {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    margin: 0;
    line-height: 1.4;
  }

  .btn-view-course {
    background: transparent;
    color: #FFFFFF;
    padding: 0;
    border-radius: 0;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
    text-decoration: none;
    cursor: pointer;
    border: none;
    height: 44px;
    transition: opacity 0.3s ease;
    font-family: 'Azeret Mono', monospace;
    overflow: visible;
  }

  .btn-text {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    border-radius: 8px;
    background: #000000;
    height: 44px;
    flex: 0 0 auto;
    box-sizing: border-box;
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0px;
    border-radius: 8px;
    background: #000000;
    width: 40px;
    height: 44px;
    flex: 0 0 auto;
  }

  .btn-icon svg {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .btn-view-course:hover .btn-icon svg {
    transform: translateX(8px);
  }

  .btn-view-course:hover {
    opacity: 0.8;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .hero {
      width: 100%;
      height: auto;
    }

    .hero-container {
      width: 100%;
      height: auto;
      flex-direction: column;
    }

    .hero-left, .hero-right {
      width: 100%;
    }

    .course-teaser {
      width: 100%;
      flex-direction: column;
      height: auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      width: 100%;
    }

    .hero-heading {
      font-size: 48px;
      line-height: 48px;
    }

    .hero-image {
      width: 100%;
      height: auto;
    }
  }

  /* MENU DROPDOWN */
  .menu-wrapper {
    position: relative;
  }

  .menu-dropdown {
    position: absolute;
    top: 36px;
    right: 0;
    width: 182px;
    height: 218px;
    background: #000000;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
    box-shadow: rgba(0, 0, 0, 0.05) 0px 10px 20px 0px;
    display: flex;
    flex-direction: column;
    align-items: center;
    align-content: center;
    justify-content: center;
    padding: 8px 16px;
    box-sizing: border-box;
    row-gap: 1px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 10;
  }

  .menu-dropdown.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .menu-item {
    width: 150px;
    height: 40px;
    background: rgba(255, 222, 222, 0);
    border-radius: 15px;
    display: flex;
    flex-direction: row;
    align-items: center;
    align-content: center;
    justify-content: flex-start;
    padding: 10px 0px;
    column-gap: 15px;
    row-gap: 15px;
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #FFFFFF;
    text-decoration: none;
    cursor: pointer;
    box-sizing: border-box;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .menu-item:hover {
    color: #FFEA00;
  }
</style>

<script>
  // Menu toggle functionality
  const menuToggle = document.getElementById('menu-toggle');
  const menuDropdown = document.getElementById('menu-dropdown');

  if (menuToggle && menuDropdown) {
    // Toggle menu on button click
    menuToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      menuDropdown.classList.toggle('active');
    });

    // Close menu when clicking on a menu item
    menuDropdown.querySelectorAll('.menu-item').forEach(item => {
      item.addEventListener('click', () => {
        menuDropdown.classList.remove('active');
      });
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (!menuToggle.contains(e.target) && !menuDropdown.contains(e.target)) {
        menuDropdown.classList.remove('active');
      }
    });
  }
</script>
