---
// Ramp Hero - EXACT 2-COLUMN LAYOUT
// Left: 3-line heading (Switzer 72px)
// Right: Hero image (portrait, visible)
// Bottom: Course teaser card

interface Props {
  courseLabel?: string;
  courseText?: string;
  courseButton?: string;
  courseLink?: string;
  heroImage?: string;
}

const {
  courseLabel = "COACHING OFFERS 101",
  courseText = "This course helps you design clear, compelling offers that people actually understand and want to buy.",
  courseButton = "VIEW COURSE",
  courseLink = "#courses",
  heroImage = "https://framerusercontent.com/images/WAxIIZFwFsal6BUSuk7mft7nN7U.png?width=3000&height=1681"
} = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero-container">
    <!-- LEFT: Heading -->
    <div class="hero-left">
      <h1 class="hero-heading">We turn<br/>strategy<br/>into growth</h1>
    </div>

    <!-- RIGHT: Image -->
    <div class="hero-right">
      <img src={heroImage} alt="Hero" class="hero-image" />
    </div>
  </div>

  <!-- BOTTOM: Course Teaser -->
  <div class="course-teaser">
    <div class="course-left">
      <p class="course-label">{courseLabel}</p>
      <p class="course-description">{courseText}</p>
    </div>
    <a href={courseLink} class="btn btn-view-course">
      {courseButton}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 8H15M15 8L8 1M15 8L8 15"></path>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero {
    background: #FFEA00;
    padding: 80px 40px 120px;
    position: relative;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 60px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
  }

  .hero-heading {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1.44px;
    color: #000000;
    margin: 0;
  }

  .hero-right {
    width: 100%;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image {
    width: 100%;
    height: auto;
    max-width: 500px;
    display: block;
    object-fit: contain;
  }

  /* COURSE TEASER - Full width at bottom */
  .course-teaser {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    padding: 0 40px;
  }

  .course-left {
    flex: 1;
  }

  .course-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #575757;
    margin: 0 0 8px 0;
  }

  .course-description {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    margin: 0;
    line-height: 1.5;
  }

  .btn-view-course {
    background: #000000;
    color: #FFFFFF;
    padding: 12px 20px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 12px;
    white-space: nowrap;
    flex-shrink: 0;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease;
  }

  .btn-view-course:hover {
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .course-teaser {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 60px 20px 80px;
    }

    .hero-container {
      margin-bottom: 40px;
    }

    .hero-heading {
      font-size: 48px;
    }

    .course-teaser {
      padding: 0 20px;
      flex-direction: column;
      align-items: flex-start;
    }

    .btn-view-course {
      width: 100%;
      justify-content: center;
    }
  }
</style>
