---
// Ramp Hero - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions from original: 1791×914px
// Hero container: 1791×840px with 74px course teaser

interface Props {
  courseLabel?: string;
  courseText?: string;
  courseButton?: string;
  courseLink?: string;
  heroImage?: string;
}

const {
  courseLabel = "COACHING OFFERS 101",
  courseText = "This course helps you design clear, compelling offers that people actually understand and want to buy.",
  courseButton = "VIEW COURSE",
  courseLink = "#courses",
  heroImage = "https://framerusercontent.com/images/WAxIIZFwFsal6BUSuk7mft7nN7U.png"
} = Astro.props;
---

<section class="hero" id="hero">
  <!-- HEADER: Logo + Menu Button -->
  <div class="hero-header">
    <a href="/" class="brand-logo">Ramp Studio.</a>
    <button class="menu-btn">
      <span>MENU</span>
      <span class="plus">+</span>
    </button>
  </div>

  <div class="hero-container">
    <!-- CENTERED IMAGE with overlay (absolute positioning) -->
    <img src={heroImage} alt="Hero" class="hero-image-bg" />

    <!-- LEFT: Heading (overlaid on top of image) -->
    <div class="hero-left">
      <h1 class="hero-heading">We turn<br/>strategy<br/>into growth</h1>
    </div>
  </div>

  <!-- BOTTOM: Course Teaser (74px height) -->
  <div class="course-teaser">
    <div class="course-left">
      <p class="course-label">{courseLabel}</p>
      <p class="course-description">{courseText}</p>
    </div>
    <a href={courseLink} class="btn-view-course">
      {courseButton}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 8H15M15 8L8 1M15 8L8 15"></path>
      </svg>
    </a>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - RESPONSIVE VERSION */
  .hero {
    background: #FFEA00;
    width: 100%;
    max-width: 1791px;
    height: 914px;
    padding: 0;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* HEADER: Logo + Menu Button - Positioned at top of hero */
  .hero-header {
    width: 100%;
    height: 80px;
    padding: 16px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #FFEA00;
    box-sizing: border-box;
  }

  .brand-logo {
    font-family: 'Manrope', sans-serif;
    font-size: 30px;
    font-weight: 600;
    color: #000000;
    text-decoration: none;
    margin: 0;
    padding: 0;
  }

  .brand-logo:hover {
    opacity: 0.7;
  }

  .menu-btn {
    background: #000000;
    color: #FFFFFF;
    border: none;
    padding: 0px 16px;
    border-radius: 6px;
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 182px;
    height: 41px;
  }

  .menu-btn:hover {
    opacity: 0.8;
  }

  .plus {
    font-weight: 400;
    font-size: 14px;
  }

  .hero-container {
    width: 100%;
    max-width: 1791px;
    height: 760px;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0;
    margin: 0 auto;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  /* CENTERED HERO IMAGE with yellow overlay */
  .hero-image-bg {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: auto;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: sepia(0.15) saturate(1.3);
    opacity: 0.95;
    z-index: 0;
  }

  .hero-left {
    width: 50%;
    padding: 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }

  .hero-heading {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 72px;
    letter-spacing: -1.44px;
    color: #000000;
    margin: 0;
    padding: 0;
    margin-top: 0;
  }


  /* COURSE TEASER CARD - Exact 74px height */
  .course-teaser {
    width: 100%;
    max-width: 1791px;
    height: 74px;
    padding: 24px 40px;
    background: #FFEA00;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .course-left {
    flex: 0 1 auto;
    max-width: 365px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .course-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
    line-height: 13px;
  }

  .course-description {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    margin: 0;
    line-height: 1.4;
  }

  .btn-view-course {
    background: #000000;
    color: #FFFFFF;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    text-decoration: none;
    cursor: pointer;
    border: none;
    height: 48px;
    transition: opacity 0.3s ease;
    font-family: 'Manrope', sans-serif;
  }

  .btn-view-course:hover {
    opacity: 0.8;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .hero {
      width: 100%;
      height: auto;
    }

    .hero-container {
      width: 100%;
      height: auto;
      flex-direction: column;
    }

    .hero-left, .hero-right {
      width: 100%;
    }

    .course-teaser {
      width: 100%;
      flex-direction: column;
      height: auto;
    }
  }

  @media (max-width: 768px) {
    .hero {
      width: 100%;
    }

    .hero-heading {
      font-size: 48px;
      line-height: 48px;
    }

    .hero-image {
      width: 100%;
      height: auto;
    }
  }
</style>
