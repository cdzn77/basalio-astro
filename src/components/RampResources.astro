---
// Ramp Resources - EXACT SPECIFICATIONS
// Background: White, Accordion items with expandable content

interface Resource {
  title: string;
  description?: string;
}

interface Props {
  resources?: Resource[];
}

const {
  resources = [
    { title: "Client Onboarding", description: "Complete onboarding templates and frameworks for smooth client integration" },
    { title: "Branding Framework", description: "Step-by-step framework for building and maintaining cohesive brand identity" },
    { title: "AI Prompts for Marketing", description: "Ready-to-use AI prompts optimized for marketing tasks and content creation" }
  ]
} = Astro.props;
---

<section class="resources" id="resources">
  <div class="container">
    <div class="resources-header">
      <h2>Our Resources</h2>
      <p class="resources-intro">Kickstart your campaigns with free templates and resources because smart marketing should be accessible to everyone.</p>
      <a href="#" class="btn">View all</a>
    </div>

    <div class="resources-list">
      {resources.map((resource, index) => (
        <div class="resource-item" data-index={index}>
          <button class="resource-toggle" aria-expanded="false">
            <span class="resource-title">{resource.title}</span>
            <span class="resource-icon">+</span>
          </button>
          {resource.description && (
            <div class="resource-content">
              <p>{resource.description}</p>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.resource-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const item = button.closest('.resource-item');
      const isExpanded = button.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.resource-item').forEach(el => {
        if (el !== item) {
          el.classList.remove('expanded');
          el.querySelector('.resource-toggle').setAttribute('aria-expanded', 'false');
        }
      });

      button.setAttribute('aria-expanded', !isExpanded);
      item.classList.toggle('expanded');
    });
  });
</script>

<style>
  .resources {
    background: #FFFFFF;
    padding: 80px 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .resources-header {
    text-align: center;
    margin-bottom: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .resources-header h2 {
    margin: 0;
  }

  .resources-intro {
    font-size: 16px;
    line-height: 1.6;
    color: #575757;
    max-width: 600px;
    margin: 0;
  }

  .resources-list {
    max-width: 800px;
    margin: 0 auto;
  }

  .resource-item {
    border-top: 1px solid #E0E0E0;
    transition: all 0.3s ease;
  }

  .resource-item:last-child {
    border-bottom: 1px solid #E0E0E0;
  }

  .resource-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 28px 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
  }

  .resource-toggle:hover {
    opacity: 0.7;
  }

  .resource-title {
    font-size: 18px;
    font-weight: 600;
    color: #000000;
    flex: 1;
  }

  .resource-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    font-size: 20px;
    font-weight: 400;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .resource-item.expanded .resource-icon {
    transform: rotate(45deg);
  }

  .resource-content {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.3s ease;
  }

  .resource-item.expanded .resource-content {
    grid-template-rows: 1fr;
  }

  .resource-content p {
    font-size: 16px;
    line-height: 1.6;
    color: #575757;
    margin: 0;
    padding: 0 0 28px 0;
    min-height: 0;
  }

  @media (max-width: 768px) {
    .resources {
      padding: 60px 0;
    }

    .container {
      padding: 0 20px;
    }

    .resources-header {
      margin-bottom: 40px;
    }

    .resource-toggle {
      padding: 20px 0;
    }

    .resource-title {
      font-size: 16px;
    }
  }
</style>
