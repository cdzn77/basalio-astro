---
// Ramp Resources - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions: 1791×707px, padding 0 40px 200px

interface Resource {
  title: string;
  description: string;
}

interface Props {
  resources?: Resource[];
}

const {
  resources = [
    { title: "Client Onboarding", description: "Complete onboarding templates and frameworks for smooth client integration" },
    { title: "Branding Framework", description: "Step-by-step framework for building and maintaining cohesive brand identity" },
    { title: "AI Prompts for Marketing", description: "Ready-to-use AI prompts optimized for marketing tasks and content creation" }
  ]
} = Astro.props;
---

<section class="resources" id="resources">
  <div class="container">
    <div class="resources-header">
      <h2>Our Resources</h2>
      <p class="resources-intro">Kickstart your campaigns with free templates and resources because smart marketing should be accessible to everyone.</p>
      <a href="#" class="view-all">View all</a>
    </div>

    <div class="resources-list">
      {resources.map((resource) => (
        <div class="resource-item">
          <h3 class="resource-title">{resource.title}</h3>
          <p class="resource-description">{resource.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS */
  .resources {
    background: #FFFFFF;
    width: 100%;
    max-width: 1791px;
    height: 707px;
    padding: 0 40px 200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 100px;
  }

  .container {
    max-width: 1711px;
    width: 100%;
    margin: 0 auto;
    padding: 0;
  }

  .resources-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .resources-header h2 {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0 auto;
  }

  .resources-intro {
    font-size: 16px;
    line-height: 1.6;
    color: #575757;
    max-width: 700px;
    margin: 0 auto;
  }

  .view-all {
    font-size: 14px;
    font-weight: 600;
    color: #0000EE;
    text-decoration: none;
  }

  .resources-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
    width: 1711px;
  }

  .resource-item {
    padding: 24px 0;
    border-bottom: 1px solid #E0E0E0;
  }

  .resource-item:last-child {
    border-bottom: none;
  }

  .resource-title {
    font-size: 18px;
    font-weight: 600;
    color: #000000;
    margin: 0 0 12px;
  }

  .resource-description {
    font-size: 16px;
    line-height: 1.6;
    color: #575757;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .resources {
      width: 100%;
    }

    .resources-list {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .resources {
      width: 100%;
      padding: 40px 20px 100px;
    }
  }
</style>
