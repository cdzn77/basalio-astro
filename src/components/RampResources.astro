---
// Ramp Resources - Structural skeleton
// Two-part header: LEFT (eyebrow) | RIGHT (description + View All link)
// Resource list with dividers and icon buttons

interface Resource {
  title: string;
  description?: string;
  link?: string;
}

interface Props {
  resources?: Resource[];
  sectionLabel?: string;
  sectionDescription?: string;
  ctaLabel?: string;
  ctaLink?: string;
}

const {
  resources = [
    { title: "[RESOURCE_TITLE_1]", description: "Placeholder description" },
    { title: "[RESOURCE_TITLE_2]", description: "Placeholder description" },
    { title: "[RESOURCE_TITLE_3]", description: "Placeholder description" }
  ],
  sectionLabel = "OUR RESOURCES",
  sectionDescription = "Kickstart your campaigns with free templates and resources because smart marketing should be accessible to everyone.",
  ctaLabel = "View all",
  ctaLink = "#"
} = Astro.props;
---

<section class="resources">
  <!-- HEADER ROW: eyebrow + description + View All -->
  <div class="resources-header">
    <!-- LEFT: Eyebrow label -->
    <p class="resources-eyebrow">{sectionLabel}</p>

    <!-- RIGHT: Description + View All -->
    <div class="resources-header-right">
      <!-- Description paragraph -->
      <p class="resources-description">{sectionDescription}</p>

      <!-- View All link (reused component styling) -->
      <a href={ctaLink} class="view-all-link">
        <span class="view-all-text">{ctaLabel}</span>
        <span class="view-all-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 2L12 8L6 14"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>

  <!-- RESOURCE LIST: dividers + rows -->
  <div class="resources-list">
    <div class="divider"></div>
    {resources.map((resource) => (
      <>
        <div class="resource-row">
          <h3 class="resource-title">{resource.title}</h3>
          <button class="resource-icon-button" aria-label="View resource" type="button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"></path>
              <path d="M12 5v14"></path>
            </svg>
          </button>
        </div>
        <div class="divider"></div>
      </>
    ))}
  </div>
</section>

<style>
  /* SECTION SHELL: flex column, center, padding bottom 200px */
  .resources {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 40px 200px 40px;
    gap: 100px;
    background: var(--basalio-paper, #FFFFFF);
    width: 100%;
    box-sizing: border-box;
  }

  /* HEADER ROW: flex row, space-between, eyebrow + description + CTA */
  .resources-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 40px;
  }

  /* Eyebrow label (left side) */
  .resources-eyebrow {
    font-size: 14px;
    font-weight: 500;
    line-height: 19.6px;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: var(--basalio-ink, #000000);
    margin: 0;
    flex: 0 0 auto;
  }

  /* Right side: description + View All */
  .resources-header-right {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    flex: 1;
    gap: 40px;
  }

  /* Description paragraph */
  .resources-description {
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    color: var(--basalio-ink, #000000);
    margin: 0;
    max-width: 750px;
  }

  /* View All link (reused from Courses section) */
  .view-all-link {
    display: flex;
    flex-direction: row;
    gap: 0;
    text-decoration: none;
    width: fit-content;
    flex: 0 0 auto;
  }

  .view-all-text {
    background: var(--basalio-ink, #000000);
    color: var(--basalio-paper, #FFFFFF);
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .view-all-icon {
    background: var(--basalio-ink, #000000);
    color: var(--basalio-paper, #FFFFFF);
    border-radius: 8px;
    width: 40px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 40px;
    transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .view-all-link:hover .view-all-icon {
    transform: translateX(4px);
  }

  /* RESOURCE LIST: dividers + rows */
  .resources-list {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 0;
  }

  /* Divider: 1px line */
  .divider {
    height: 1px;
    width: 100%;
    background-color: rgba(0, 0, 0, 0.1);
  }

  /* Resource row: title + icon button */
  .resource-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    padding: 20px 0;
    width: 100%;
  }

  /* Resource title (h3) */
  .resource-title {
    font-size: 22px;
    font-weight: 400;
    line-height: 26.4px;
    color: var(--basalio-ink, #000000);
    margin: 0;
    flex-grow: 1;
  }

  /* Icon button: 50x50px, light neutral background */
  .resource-icon-button {
    width: 50px;
    height: 50px;
    border-radius: 4px;
    background: var(--basalio-stone, #F5F5F5);
    color: var(--basalio-ink, #000000);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 50px;
    transition: opacity 200ms ease;
  }

  .resource-icon-button:hover {
    opacity: 0.8;
  }
</style>
