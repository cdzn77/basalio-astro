---
// Ramp Resources - Accordion with click-triggered expansion
// Two-part header: LEFT (eyebrow) | RIGHT (description + View All link)
// Resource rows: icon-button click triggers height animation, multi-open independent state

import TwoPillButton from './TwoPillButton.astro';

interface Resource {
  title: string;
  description: string;
  slug: string;
}

interface Props {
  resources?: Resource[];
  sectionLabel?: string;
  sectionDescription?: string;
  ctaLabel?: string;
  ctaLink?: string;
}

const {
  resources = [
    {
      title: "Client Onboarding",
      description: "[RESOURCE_DESCRIPTION_1] - A comprehensive guide to streamline client intake and setup processes.",
      slug: "client-onboarding"
    },
    {
      title: "Branding Framework",
      description: "[RESOURCE_DESCRIPTION_2] - Essential principles and templates for building consistent brand identity.",
      slug: "branding-framework"
    },
    {
      title: "AI Prompts for Marketing",
      description: "[RESOURCE_DESCRIPTION_3] - Ready-to-use prompts to accelerate content creation and strategy.",
      slug: "ai-prompts-marketing"
    }
  ],
  sectionLabel = "OUR RESOURCES",
  sectionDescription = "Kickstart your campaigns with free templates and resources because smart marketing should be accessible to everyone.",
  ctaLabel = "View all",
  ctaLink = "#"
} = Astro.props;
---

<section class="resources">
  <!-- HEADER ROW: eyebrow + description + View All -->
  <div class="resources-header">
    <!-- LEFT: Eyebrow label -->
    <p class="resources-eyebrow">{sectionLabel}</p>

    <!-- RIGHT: Description + View All -->
    <div class="resources-header-right">
      <!-- Description paragraph -->
      <p class="resources-description">{sectionDescription}</p>

      <!-- View All link: Shared two-pill component -->
      <TwoPillButton label={ctaLabel} href={ctaLink} />
    </div>
  </div>

  <!-- RESOURCE LIST WRAPPER: Spacer + List aligned to right column -->
  <div class="resources-list-wrapper">
    <!-- Spacer matching eyebrow column width (35%) -->
    <div class="resources-list-spacer"></div>

    <!-- Resource list aligned under header-right (65%) -->
    <div class="resources-list">
      <div class="divider"></div>
      {resources.map((resource, index) => (
        <>
          <div class="resource-item" data-index={index} data-open="false">
            <div class="resource-row">
              <h3 class="resource-title">{resource.title}</h3>
              <button class="resource-icon-button" aria-label="View resource" type="button">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14"></path>
                  <path d="M12 5v14"></path>
                </svg>
              </button>
            </div>
            <!-- Expanded content container -->
            <div class="resource-content" style="height: 0; overflow: hidden;">
              <div class="resource-content-inner">
                <p class="resource-body">{resource.description}</p>
                <a href={`/resources/${resource.slug}`} class="resource-link">learn more</a>
              </div>
            </div>
          </div>
          <div class="divider"></div>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  /* SECTION SHELL: flex column, center, padding bottom 200px */
  .resources {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 40px 200px 40px;
    gap: 100px;
    background: var(--basalio-paper, #FFFFFF);
    width: 100%;
    box-sizing: border-box;
  }

  /* HEADER ROW: flex row, space-between, eyebrow + description + CTA */
  .resources-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 40px;
  }

  /* Eyebrow label (left side) */
  .resources-eyebrow {
    font-size: 14px;
    font-weight: 500;
    line-height: 19.6px;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: var(--basalio-ink, #000000);
    margin: 0;
    flex: 1 1 0%;
    max-width: 35%;
  }

  /* Right side: description + View All */
  .resources-header-right {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    flex: 1;
    max-width: 65%;
    gap: 40px;
  }

  /* Description paragraph */
  .resources-description {
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    color: var(--basalio-ink, #000000);
    margin: 0;
    max-width: 750px;
  }

  /* TwoPillButton component handles styling */
  :global(.two-pill-button) {
    flex: 0 0 auto;
  }

  /* RESOURCE LIST WRAPPER: Spacer + List aligned to right column */
  .resources-list-wrapper {
    display: flex;
    flex-direction: row;
    width: 100%;
    gap: 40px;
  }

  /* Spacer: matches eyebrow column width (35%) */
  .resources-list-spacer {
    flex: 1 1 0%;
    max-width: 35%;
  }

  /* RESOURCE LIST: dividers + rows, aligned under header-right (65%) */
  .resources-list {
    display: flex;
    flex-direction: column;
    flex: 1 1 0%;
    max-width: 65%;
    gap: 0;
  }

  /* Divider: 1px line */
  .divider {
    height: 1px;
    width: 100%;
    background-color: rgba(0, 0, 0, 0.1);
  }

  /* Resource row: title + icon button */
  .resource-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    padding: 20px 0;
    width: 100%;
  }

  /* Resource title (h3) */
  .resource-title {
    font-size: 22px;
    font-weight: 400;
    line-height: 26.4px;
    color: var(--basalio-ink, #000000);
    margin: 0;
    flex-grow: 1;
  }

  /* Icon button: 50x50px, light neutral background */
  .resource-icon-button {
    width: 50px;
    height: 50px;
    border-radius: 4px;
    background: var(--basalio-stone, #F5F5F5);
    color: var(--basalio-ink, #000000);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 50px;
    transition: opacity 200ms ease;
  }

  .resource-icon-button:hover {
    opacity: 0.8;
  }

  /* Resource item: accordion wrapper with expanded content */
  .resource-item {
    display: flex;
    flex-direction: column;
  }

  /* Expanded content container: animated height */
  .resource-content {
    transition: height 300ms cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  /* Inner wrapper for content sizing */
  .resource-content-inner {
    padding: 4px 0 28px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Resource body text: 16px, weight 400, line-height 22.4px, rgb(87,87,87) */
  .resource-body {
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    color: rgb(87, 87, 87);
    margin: 0;
    padding: 0;
  }

  /* "Learn more" button: styled to match Ramp template button specs */
  .resource-link {
    /* Button dimensions and positioning */
    width: 151px;
    height: 41px;
    display: flex;
    position: relative;
    flex-basis: auto;
    flex-grow: 0;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;

    /* Text inside button: Azeret Mono 14px, uppercase, 2.8px letter-spacing */
    font-family: "Azeret Mono", monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: var(--basalio-ink, #000000);
    text-decoration: none;
    white-space: nowrap;

    /* Box model */
    box-sizing: border-box;
    padding: 0;
    border: 1px solid var(--basalio-ink, #000000);
    border-radius: 6px;
    background: transparent;

    /* Interaction */
    cursor: pointer;
    transition: all 200ms ease;

    /* Transform */
    transform: none;
    transform-origin: 75.5px 20.5px;
    -webkit-font-smoothing: antialiased;
  }

  .resource-link:hover {
    background: var(--basalio-ink, #000000);
    color: var(--basalio-paper, #FFFFFF);
  }
</style>

<script>
  // Multi-open accordion: track each resource's open state independently
  const openResources = new Set();

  document.querySelectorAll('.resource-row').forEach((row) => {
    const button = row.querySelector('.resource-icon-button');

    if (button) {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const item = row.closest('.resource-item');
        const index = parseInt(item.getAttribute('data-index'));
        const contentContainer = item.querySelector('.resource-content');
        const contentInner = item.querySelector('.resource-content-inner');

        if (openResources.has(index)) {
          // Close this resource
          openResources.delete(index);
          item.setAttribute('data-open', 'false');
          contentContainer.style.height = '0px';
        } else {
          // Open this resource
          openResources.add(index);
          item.setAttribute('data-open', 'true');
          // Calculate actual height of content with buffer for proper display
          const height = contentInner.getBoundingClientRect().height;
          contentContainer.style.height = `${height + 4}px`;
        }
      });
    }
  });
</script>
