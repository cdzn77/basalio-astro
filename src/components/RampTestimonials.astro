---
// Ramp Testimonials - Page-based carousel with hover-zones and visible arrow buttons
// Two-column layout: LEFT (500px text/button) | RIGHT (carousel 1109px)

interface Testimonial {
  image: string;
  quote: string;
  name: string;
  results: string;
}

interface Props {
  testimonials?: Testimonial[];
  sectionHeading?: string;
}

const {
  testimonials = [
    {
      image: "/assets/l4gfk0yuorz9j7rwu2ebwwxpw.jpg",
      quote: "I stopped explaining hover states to developers. I just build them.",
      name: "UX/UI Designer",
      results: "No handoff docs needed"
    },
    {
      image: "/assets/jjmc0ozsfy0hhnmbr8w4de17pw.jpg",
      quote: "My reel finally scrolls the way it plays — frame by frame, not just fading in.",
      name: "Videographer",
      results: "Scroll Sequence, no video embed"
    },
    {
      image: "/assets/k54odknaj7dnpcqlcqviskrrxay.jpg",
      quote: "Case studies that morph from the grid instead of just... linking to a new page.",
      name: "Director",
      results: "One shared-element transition, zero page reload"
    },
    {
      image: "/assets/l4gfk0yuorz9j7rwu2ebwwxpw.jpg",
      quote: "Every client site gets the same polish — without rebuilding it every time.",
      name: "Agency",
      results: "Nine blocks, unlimited client sites"
    }
  ],
  sectionHeading = "Built for people who\nactually make things."
} = Astro.props;
---

<section class="testimonials" id="testimonials">
  <div class="testimonials-inner">
    <!-- LEFT COLUMN: 500px, eyebrow + heading + pagination -->
    <div class="testimonials-left">
      <div class="testimonials-header">
        <p class="testimonials-eyebrow">WHO IT'S FOR</p>
        <h2 class="testimonials-heading">{sectionHeading}</h2>
      </div>

      <!-- PAGINATION CONTROLS: Below the button on the left side -->
      <div class="pagination-controls">
        <button class="carousel-button carousel-button-prev" aria-label="Previous testimonial" data-direction="prev">
          <div class="button-icon-wrapper">
            <svg width="100%" height="100%" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <line x1="2.5" y1="12" x2="23.5" y2="12" fill="none" stroke="currentColor" stroke-miterlimit="10" stroke-width="1.5"></line>
              <polyline points="10.14 4.36 2.5 12 10.14 19.64" fill="none" stroke="currentColor" stroke-miterlimit="10" stroke-width="1.5"></polyline>
            </svg>
          </div>
        </button>
        <button class="carousel-button carousel-button-next" aria-label="Next testimonial" data-direction="next">
          <div class="button-icon-wrapper">
            <svg width="100%" height="100%" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <line x1="21.5" y1="12" x2="0.5" y2="12" fill="none" stroke="currentColor" stroke-miterlimit="10" stroke-width="1.5"></line>
              <polyline points="13.86 4.36 21.5 12 13.86 19.64" fill="none" stroke="currentColor" stroke-miterlimit="10" stroke-width="1.5"></polyline>
            </svg>
          </div>
        </button>
      </div>
    </div>

    <!-- RIGHT COLUMN: Carousel (1109px, or fill remaining) -->
    <div class="testimonials-right">
      <!-- Invisible left hover zone -->
      <div class="carousel-zone carousel-zone-left" data-direction="prev"></div>

      <!-- Carousel viewport (overflow clip) -->
      <div class="carousel-viewport">
        <!-- Track: position absolute, flex row, gap 20px, overflowing -->
        <div class="carousel-track">
          {testimonials.map((testimonial, index) => {
            const testimonialImages = [
              '/assets/l4gfk0yuorz9j7rwu2ebwwxpw.jpg',
              '/assets/jjmc0ozsfy0hhnmbr8w4de17pw.jpg',
              '/assets/k54odknaj7dnpcqlcqviskrrxay.jpg',
              '/assets/l4gfk0yuorz9j7rwu2ebwwxpw.jpg'
            ];
            return (
              <div class="testimonial-card">
                <img src={testimonialImages[index] || testimonialImages[0]} alt={testimonial.name} class="testimonial-image" />
                <blockquote class="testimonial-quote">{testimonial.quote}</blockquote>
                <span class="testimonial-label">ROLE</span>
                <p class="testimonial-name">{testimonial.name}</p>
                <span class="testimonial-label">RESULTS</span>
                <p class="testimonial-results">{testimonial.results}</p>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Invisible right hover zone -->
      <div class="carousel-zone carousel-zone-right" data-direction="next"></div>
    </div>
  </div>
</section>

<style>
  /* SECTION SHELL: flex column, center alignment, padding 200px 40px, gap 40px */
  .testimonials {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 200px 40px;
    gap: 40px;
    background: var(--basalio-paper, #FFFFFF);
    width: 100%;
    box-sizing: border-box;
  }

  /* INNER ROW: flex row, space-between, align-items flex-start, two columns */
  .testimonials-inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 20px;
  }

  /* LEFT COLUMN: 500px wide, flex column, match carousel height (571px) */
  .testimonials-left {
    flex: 0 0 500px;
    display: flex;
    flex-direction: column;
    height: 571px;
  }

  /* Eyebrow + heading block (natural document flow spacing) */
  .testimonials-header {
    display: flex;
    flex-direction: column;
  }

  .testimonials-eyebrow {
    font-size: 14px;
    font-weight: 500;
    line-height: 19.6px;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: var(--basalio-ink, #000000);
    margin: 0 0 12px 0;
  }

  .testimonials-heading {
    font-size: 40px;
    font-weight: 400;
    line-height: 48px;
    letter-spacing: -0.8px;
    color: var(--basalio-ink, #000000);
    margin: 0 0 40px 0;
    white-space: pre-line;
  }

  /* PAGINATION CONTROLS: At bottom of left column with spacing */
  .pagination-controls {
    display: flex;
    flex-direction: row;
    gap: 12px;
    margin-top: auto;
  }

  /* Icon wrapper for SVG centering */
  .button-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  /* Visible navigation buttons (white by default, invert on hover) */
  .carousel-button {
    width: 70px;
    height: 70px;
    border-radius: 8px;
    background: #FFFFFF;
    color: var(--basalio-ink, #000000);
    border: 1px solid #E8E8E8;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 20;
    transition: all 200ms ease;
    flex: 0 0 70px;
  }

  .carousel-button:disabled {
    pointer-events: none;
    opacity: 0.5;
  }

  .carousel-button:hover:not(:disabled) {
    background: #000000;
    color: #FFFFFF;
    border-color: #000000;
  }

  /* RIGHT COLUMN: Carousel (1109px wide, or fill remaining space) */
  .testimonials-right {
    flex: 1;
    position: relative;
    overflow: clip;
    min-height: 571px;
  }

  /* Invisible hover zones (left and right edges) */
  .carousel-zone {
    position: absolute;
    top: 0;
    height: 100%;
    width: 15%;
    opacity: 0;
    cursor: pointer;
    z-index: 10;
  }

  .carousel-zone-left {
    left: 0;
  }

  .carousel-zone-right {
    right: 0;
  }

  .carousel-zone:disabled,
  .carousel-zone[data-disabled] {
    pointer-events: none;
  }

  /* Carousel viewport (overflow clip, position relative for absolute track) */
  .carousel-viewport {
    position: relative;
    overflow: clip;
    width: 100%;
    height: 571px;
  }

  /* Track: position absolute, flex row, gap 20px, width = sum of cards + gaps */
  .carousel-track {
    position: absolute;
    left: 0;
    top: 0;
    display: flex;
    flex-direction: row;
    gap: 20px;
    transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Testimonial cards: fixed size 500x571px */
  .testimonial-card {
    flex: 0 0 500px;
    height: 571px;
    background: #FFFFFF;
    border: 1px solid #E8E8E8;
    border-radius: 6px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    box-sizing: border-box;
  }

  .testimonial-image {
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center;
    border-radius: 8px;
    display: block;
  }

  .testimonial-quote {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 22px;
    color: #000000;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .testimonial-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    color: #999999;
    margin: 0;
    padding: 0;
    display: block;
  }

  .testimonial-name {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 14px;
    font-weight: 600;
    line-height: 19.6px;
    color: #000000;
    margin: 0;
    padding: 0;
  }

  .testimonial-results {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 13px;
    font-weight: 400;
    line-height: 18.2px;
    color: #666666;
    margin: 0;
    padding: 0;
    display: block;
  }
</style>

<script is:inline>
  // PAGE-BASED CAROUSEL NAVIGATION
  // Paging logic: calculate how many cards fit in viewport, advance by one page per action

  const track = document.querySelector('.carousel-track');
  const viewport = document.querySelector('.carousel-viewport');
  const cards = document.querySelectorAll('.testimonial-card');
  const prevBtn = document.querySelector('.carousel-button-prev');
  const nextBtn = document.querySelector('.carousel-button-next');
  const leftZone = document.querySelector('.carousel-zone-left');
  const rightZone = document.querySelector('.carousel-zone-right');

  if (track && viewport && cards.length > 0) {
    const GAP = 20;
    const CARD_WIDTH = 500; // FIXED: Match CSS flex: 0 0 500px
    const CARD_PLUS_GAP = CARD_WIDTH + GAP; // 520px total per card

    let currentPage = 0;
    let totalPages = 1;

    // Calculate paging based on FIXED card width
    const calculatePaging = () => {
      const cardsPerView = 2; // Always show 2 cards per view
      totalPages = Math.max(1, Math.ceil(cards.length / cardsPerView));
      return cardsPerView;
    };

    // Update track position based on current page
    const updateTrackPosition = () => {
      const offset = currentPage * CARD_PLUS_GAP; // Use fixed 520px per page
      track.style.transform = `translateX(-${offset}px)`;
      updateButtonStates();
    };

    // Enable/disable buttons based on boundary logic
    const updateButtonStates = () => {
      const isFirstPage = currentPage === 0;
      const isLastPage = currentPage === totalPages - 1;

      prevBtn.disabled = isFirstPage;
      nextBtn.disabled = isLastPage;
      leftZone.style.pointerEvents = isFirstPage ? 'none' : 'auto';
      rightZone.style.pointerEvents = isLastPage ? 'none' : 'auto';

      if (isFirstPage) {
        leftZone.setAttribute('data-disabled', 'true');
      } else {
        leftZone.removeAttribute('data-disabled');
      }

      if (isLastPage) {
        rightZone.setAttribute('data-disabled', 'true');
      } else {
        rightZone.removeAttribute('data-disabled');
      }
    };

    // Navigate to next or previous page
    const navigate = (direction) => {
      if (direction === 'next' && currentPage < totalPages - 1) {
        currentPage++;
        updateTrackPosition();
      } else if (direction === 'prev' && currentPage > 0) {
        currentPage--;
        updateTrackPosition();
      }
    };

    // Initialize paging
    calculatePaging();
    updateButtonStates();

    // Attach click handlers to visible buttons
    prevBtn?.addEventListener('click', () => navigate('prev'));
    nextBtn?.addEventListener('click', () => navigate('next'));

    // Attach mouseenter handlers to invisible hover zones
    leftZone?.addEventListener('mouseenter', () => navigate('prev'));
    rightZone?.addEventListener('mouseenter', () => navigate('next'));

    // Recalculate paging on window resize
    window.addEventListener('resize', () => {
      calculatePaging();
      currentPage = Math.min(currentPage, totalPages - 1);
      updateTrackPosition();
    });
  }
</script>
