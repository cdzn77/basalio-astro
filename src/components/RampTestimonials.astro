---
// Ramp Testimonials - COMPLETE REDESIGN
// Reference-accurate styling: typography, layout, spacing, card design, navigation

interface Testimonial {
  image: string;
  quote: string;
  name: string;
  title: string;
  results: string;
}

interface Props {
  testimonials?: Testimonial[];
}

const {
  testimonials = [
    { image: "/assets/mtgtbdnjaof929atjpy1noqquia.jpeg", quote: "Template helped us launch a polished website that feels premium and scales with you.", name: "Maya Thompson", title: "Wellness Coach", results: "18x email sign ups" },
    { image: "/assets/mtgtbdnjaof929atjpy1noqquia.jpeg", quote: "Every resource feels intentional, from free step-by-step workflows to paid resources.", name: "Priya Desai", title: "Shopify Store Owner", results: "2x quarterly revenue" },
    { image: "/assets/mtgtbdnjaof929atjpy1noqquia.jpeg", quote: "We saved weeks of design time and launched a high-end website that feels premium.", name: "Lucas Martinez", title: "Café Owner", results: "20% increased conversion" }
  ]
} = Astro.props;
---

<section class="testimonials" id="testimonials">
  <div class="container">
    <div class="testimonials-header">
      <p class="testimonials-label">TESTIMONIALS</p>
      <h2 class="testimonials-title">Learner Stories</h2>
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-arrow prev" aria-label="Previous testimonial">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 19L8 12L15 5"></path>
        </svg>
      </button>

      <div class="carousel-container">
        <div class="carousel-track">
          {testimonials.map((testimonial) => (
            <div class="testimonial-card">
              <div class="testimonial-image">
                <img src={testimonial.image} alt={testimonial.name} loading="lazy" />
              </div>
              <p class="testimonial-quote">{testimonial.quote}</p>
              <div class="testimonial-info">
                <p class="testimonial-name">{testimonial.name}</p>
                <p class="testimonial-title">{testimonial.title}</p>
              </div>
              <div class="testimonial-results">
                <span class="results-label">RESULTS</span>
                <span class="results-value">{testimonial.results}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <button class="carousel-arrow next" aria-label="Next testimonial">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 5L16 12L9 19"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* TESTIMONIALS SECTION - REFERENCE DESIGN */
  .testimonials {
    width: 100%;
    max-width: 1792px;
    padding: 100px 40px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .container {
    width: 100%;
    margin: 0 auto;
  }

  /* HEADER SECTION */
  .testimonials-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .testimonials-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #999999;
    display: block;
    margin-bottom: 16px;
  }

  .testimonials-title {
    font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 64px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--basalio-ink, #000000);
    margin: 0;
    padding: 0;
  }

  /* CAROUSEL WRAPPER */
  .carousel-wrapper {
    display: flex;
    align-items: center;
    gap: 32px;
    justify-content: center;
  }

  /* NAVIGATION ARROWS */
  .carousel-arrow {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #F0F0F0;
    color: var(--basalio-ink, #000000);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 200ms ease;
    padding: 0;
  }

  .carousel-arrow:hover {
    background: #E0E0E0;
    transform: scale(1.05);
  }

  .carousel-arrow:active {
    transform: scale(0.98);
  }

  /* CAROUSEL CONTAINER */
  .carousel-container {
    flex: 1;
    overflow: hidden;
    min-width: 0;
  }

  .carousel-track {
    display: flex;
    gap: 40px;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* TESTIMONIAL CARD */
  .testimonial-card {
    flex: 0 0 420px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* IMAGE STYLING */
  .testimonial-image {
    width: 160px;
    height: 160px;
    border-radius: 12px;
    overflow: hidden;
    background: #F5F5F5;
    flex-shrink: 0;
  }

  .testimonial-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* QUOTE STYLING */
  .testimonial-quote {
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--basalio-ink, #000000);
    margin: 0;
    padding: 0;
    font-style: italic;
  }

  /* NAME & TITLE */
  .testimonial-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .testimonial-name {
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--basalio-ink, #000000);
    margin: 0;
    padding: 0;
  }

  .testimonial-title {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    color: #575757;
    margin: 0;
    padding: 0;
  }

  /* RESULTS SECTION */
  .testimonial-results {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 20px;
    border-top: 1px solid #E0E0E0;
  }

  .results-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #999999;
  }

  .results-value {
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--basalio-ink, #000000);
  }

  /* RESPONSIVE DESIGN */
  @media (max-width: 1024px) {
    .testimonials {
      padding: 80px 40px;
    }

    .testimonials-title {
      font-size: 48px;
    }

    .testimonial-card {
      flex: 0 0 380px;
    }

    .carousel-wrapper {
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .testimonials {
      padding: 60px 20px;
    }

    .testimonials-header {
      margin-bottom: 60px;
    }

    .testimonials-title {
      font-size: 36px;
    }

    .carousel-wrapper {
      gap: 16px;
    }

    .carousel-arrow {
      width: 44px;
      height: 44px;
    }

    .testimonial-card {
      flex: 0 0 320px;
      gap: 20px;
    }

    .testimonial-image {
      width: 120px;
      height: 120px;
    }
  }
</style>
