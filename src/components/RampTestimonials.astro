---
// Ramp Testimonials - Shared component for homepage and courses page
// 35-65 split layout: left column (header + arrows), right column (carousel)
// Reuses carousel paging logic from RampCourses component

interface Testimonial {
  image: string;
  quote: string;
  name: string;
  title: string;
  results: string;
}

interface Props {
  testimonials?: Testimonial[];
  sectionHeading?: string;
}

const {
  sectionHeading = "Built by Creatives",
  testimonials = [
    {
      image: "/assets/l4gfk0yuorz9j7rwu2ebwwxpw.jpg",
      quote: '"Template helped us launch a polished website that feels premium and scales with you."',
      name: "Maya Thompson",
      title: "Wellness Coach",
      results: "18x email sign ups"
    },
    {
      image: "/assets/jjmc0ozsfy0hhnmbr8w4de17pw.jpg",
      quote: '"Every resource feels intentional, from free step-by-step workflows to paid resources."',
      name: "Priya Desai",
      title: "Shopify Store Owner",
      results: "2x quaterly revenue"
    },
    {
      image: "/assets/k54odknaj7dnpcqlcqviskrrxay.jpg",
      quote: '"We saved weeks of design time and launched a high-end website that feels premium."',
      name: "Lucas Martinez",
      title: "Café Owner",
      results: "20% increased conversion"
    },
    {
      image: "/assets/l4gfk0yuorz9j7rwu2ebwwxpw.jpg",
      quote: '"The platform made it incredibly easy to manage our workflow and scale our operations."',
      name: "Sarah Johnson",
      title: "Startup Founder",
      results: "5x team productivity"
    },
    {
      image: "/assets/jjmc0ozsfy0hhnmbr8w4de17pw.jpg",
      quote: '"We went from scattered tools to a unified system that actually works for us."',
      name: "David Chen",
      title: "Agency Director",
      results: "3x client retention"
    },
    {
      image: "/assets/k54odknaj7dnpcqlcqviskrrxay.jpg",
      quote: '"The learning curve was minimal and the results were immediate and measurable."',
      name: "Emma Wilson",
      title: "Marketing Manager",
      results: "12x ROI improvement"
    },
    {
      image: "/assets/l4gfk0yuorz9j7rwu2ebwwxpw.jpg",
      quote: '"This transformed how we think about our business and customer relationships."',
      name: "James Rodriguez",
      title: "E-commerce Owner",
      results: "8x sales growth"
    },
    {
      image: "/assets/jjmc0ozsfy0hhnmbr8w4de17pw.jpg",
      quote: '"The support and resources provided made all the difference in our success."',
      name: "Lisa Anderson",
      title: "Consultant",
      results: "50+ client projects"
    },
    {
      image: "/assets/k54odknaj7dnpcqlcqviskrrxay.jpg",
      quote: '"Exceeded all our expectations and delivered results beyond what we imagined."',
      name: "Michael Park",
      title: "Digital Director",
      results: "10x engagement rate"
    }
  ]
} = Astro.props;
---

<section class="testimonials">
  <div class="testimonials-inner">
    <!-- LEFT COLUMN: 35% - Header + Navigation -->
    <div class="testimonials-left">
      <div class="testimonials-header">
        <p class="testimonials-eyebrow">WHO IT'S FOR</p>
        <h3 class="testimonials-heading">{sectionHeading}</h3>
      </div>

      <!-- Navigation Arrows -->
      <div class="pagination-controls">
        <button class="carousel-button carousel-button-prev" aria-label="Previous testimonial" data-direction="prev">
          <div class="button-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <line x1="2.5" y1="12" x2="23.5" y2="12"></line>
              <polyline points="10.14 4.36 2.5 12 10.14 19.64"></polyline>
            </svg>
          </div>
        </button>
        <button class="carousel-button carousel-button-next" aria-label="Next testimonial" data-direction="next">
          <div class="button-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
              <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
            </svg>
          </div>
        </button>
      </div>
    </div>

    <!-- RIGHT COLUMN: 65% - Carousel -->
    <div class="testimonials-right">
      <!-- Invisible hover zones for carousel control -->
      <div class="carousel-zone carousel-zone-left" data-direction="prev"></div>

      <!-- Carousel viewport -->
      <div class="carousel-viewport">
        <!-- Track: flex row with cards -->
        <div class="carousel-track">
          {testimonials.map((testimonial, index) => (
            <div class="testimonial-card" data-card-index={index}>
              <!-- Background image -->
              <div class="card-image">
                <img
                  src={testimonial.image}
                  alt={testimonial.name}
                  loading="lazy"
                />
              </div>

              <!-- Overlay: Quote text (animated), name, role, results -->
              <div class="card-content">
                <blockquote class="card-quote">{testimonial.quote}</blockquote>

                <div class="card-footer">
                  <div class="card-info">
                    <span class="card-client-label">ROLE</span>
                    <p class="card-name">{testimonial.name}</p>
                  </div>

                  <div class="card-results">
                    <span class="results-label">RESULTS</span>
                    <span class="results-value">{testimonial.results}</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Invisible right hover zone -->
      <div class="carousel-zone carousel-zone-right" data-direction="next"></div>
    </div>
  </div>
</section>

<style>
  /* SECTION CONTAINER */
  .testimonials {
    padding: 80px 40px;
    background: var(--basalio-paper, #FFFFFF);
    width: 100%;
    box-sizing: border-box;
  }

  /* INNER ROW: 35-65 split */
  .testimonials-inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: stretch;
    width: 100%;
    gap: 40px;
  }

  /* LEFT COLUMN: 35% */
  .testimonials-left {
    flex: 0 0 35%;
    max-width: 35%;
    display: flex;
    flex-direction: column;
    gap: 40px;
    min-height: 288px;
  }

  /* HEADER: Eyebrow + Heading */
  .testimonials-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .testimonials-eyebrow {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2.8px;
    color: #575757;
    margin: 0;
    padding: 0;
  }

  .testimonials-heading {
    font-family: 'Manrope', sans-serif;
    font-size: 28px;
    font-weight: 600;
    line-height: 1.3;
    color: #000000;
    margin: 0;
    padding: 0;
    white-space: pre-line;
  }

  /* PAGINATION CONTROLS: Arrow buttons */
  .pagination-controls {
    display: flex;
    flex-direction: row;
    gap: 12px;
    margin-top: auto;
  }

  .button-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  /* Arrow buttons: 70x70px circular */
  .carousel-button {
    width: 70px;
    height: 70px;
    border-radius: 6px;
    background: #FAFAFA;
    color: #9C9C9C;
    border: 1px solid #EBEBEB;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 20;
    transition: all 200ms ease;
    flex: 0 0 70px;
  }

  /* Disabled state (start/end) */
  .carousel-button:disabled {
    pointer-events: none;
    background: #FAFAFA;
    color: #9C9C9C;
    opacity: 0.5;
  }

  /* Enabled state */
  .carousel-button:not(:disabled) {
    background: #FFFFFF;
    color: #000000;
  }

  .carousel-button:hover:not(:disabled) {
    background: #000000;
    color: #FFFFFF;
    border-color: #000000;
  }

  /* RIGHT COLUMN: 65% - Carousel */
  .testimonials-right {
    flex: 1;
    position: relative;
    overflow: hidden;
    min-height: 288px;
  }

  /* Invisible hover zones */
  .carousel-zone {
    position: absolute;
    top: 0;
    height: 100%;
    width: 15%;
    opacity: 0;
    cursor: pointer;
    z-index: 10;
  }

  .carousel-zone-left {
    left: 0;
  }

  .carousel-zone-right {
    right: 0;
  }

  .carousel-zone:disabled,
  .carousel-zone[data-disabled] {
    pointer-events: none;
  }

  /* Carousel viewport */
  .carousel-viewport {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: 288px;
  }

  /* Track: flex row with cards */
  .carousel-track {
    position: absolute;
    left: 0;
    top: 0;
    display: flex;
    flex-direction: row;
    gap: 20px;
    transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Testimonial cards: horizontal layout with image left, content right */
  .testimonial-card {
    display: flex;
    width: 600px;
    height: 288px;
    background: #FFFFFF;
    border: 1px solid #E5E5E5;
    border-radius: 6px;
    overflow: visible;
    position: relative;
    box-sizing: border-box;
    padding: 16px;
    flex: 0 0 600px;
    opacity: 1;
    -webkit-font-smoothing: antialiased;
  }

  /* Card background image - LEFT side: Fixed dimensions with padding */
  .card-image {
    position: relative;
    width: 150px;
    height: 248px;
    z-index: 0;
    overflow: hidden;
    border-radius: 6px;
    display: block;
    flex: 0 0 150px;
    margin-right: 24px;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Card content - RIGHT side */
  .card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0;
    box-sizing: border-box;
    background: #FFFFFF;
    flex: 1;
    overflow: hidden;
  }

  /* Quote text - Large and prominent */
  .card-quote {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 26px;
    font-weight: 400;
    line-height: 31.2px;
    letter-spacing: -0.52px;
    color: #000000;
    margin: 0;
    padding: 0;
    text-align: start;
    background-color: transparent;
  }

  /* Footer: name, role, results */
  .card-footer {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 0;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .card-client-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2.8px;
    line-height: 19.6px;
    color: #000000;
    margin: 0;
    padding: 0;
    display: block;
    background-color: transparent;
  }

  .card-name {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 19.6px;
    color: rgba(0, 0, 0, 0.65);
    margin: 0;
    padding: 0;
  }

  .card-role {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 19.6px;
    color: rgba(0, 0, 0, 0.65);
    margin: 0;
    padding: 0;
    display: inline;
  }

  /* Results section */
  .card-results {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 0;
  }

  .results-label {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2.8px;
    line-height: 19.6px;
    color: #000000;
    margin: 0;
    padding: 0;
  }

  .results-value {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 19.6px;
    color: rgba(0, 0, 0, 0.65);
    margin: 0;
    padding: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .testimonials-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .testimonials-left {
      flex: 0 0 auto;
      max-width: 100%;
    }

    .testimonials-right {
      flex: 1;
      width: 100%;
    }
  }


  @media (max-width: 1024px) {
    .testimonials-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .testimonials-left {
      flex: 0 0 auto;
      max-width: 100%;
    }

    .testimonials-right {
      flex: 1;
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .testimonials {
      padding: 60px 20px;
    }

    .testimonials-heading {
      font-size: 24px;
    }

    .carousel-button {
      width: 60px;
      height: 60px;
      font-size: 12px;
    }

    .testimonial-card {
      flex: 0 0 100%;
    }
  }
</style>

<script is:inline>
  const initCarousel = () => {
    console.log('[Testimonials] initCarousel called');
    const track = document.querySelector('.carousel-track');
    const viewport = document.querySelector('.carousel-viewport');
    const cards = document.querySelectorAll('.testimonial-card');
    const prevBtn = document.querySelector('.carousel-button-prev');
    const nextBtn = document.querySelector('.carousel-button-next');
    const leftZone = document.querySelector('.carousel-zone-left');
    const rightZone = document.querySelector('.carousel-zone-right');

    console.log('[Testimonials] DOM check:', { track: !!track, viewport: !!viewport, cardsCount: cards.length, prevBtn: !!prevBtn, nextBtn: !!nextBtn, viewportWidth: viewport?.clientWidth });

    if (track && viewport && cards.length > 0 && prevBtn && nextBtn && viewport.clientWidth > 0) {
      console.log('[Testimonials] All DOM elements found, initializing...');

      // DEBUG: Check track CSS properties
      const trackStyle = window.getComputedStyle(track);
      console.log('[Testimonials] Track CSS (computed):', {
        position: trackStyle.position,
        left: trackStyle.left,
        top: trackStyle.top,
        transform: trackStyle.transform,
        transition: trackStyle.transition,
        display: trackStyle.display,
        zIndex: trackStyle.zIndex
      });
      console.log('[Testimonials] Track inline styles:', {
        position: track.style.position,
        left: track.style.left,
        top: track.style.top,
        transform: track.style.transform
      });

      // DEBUG: Check viewport dimensions
      console.log('[Testimonials] Viewport:', {
        clientWidth: viewport.clientWidth,
        clientHeight: viewport.clientHeight,
        offsetWidth: viewport.offsetWidth,
        offsetHeight: viewport.offsetHeight
      });

      // DEBUG: Check first card dimensions
      if (cards[0]) {
        console.log('[Testimonials] First card:', {
          offsetWidth: cards[0].offsetWidth,
          offsetHeight: cards[0].offsetHeight,
          clientWidth: cards[0].clientWidth,
          clientHeight: cards[0].clientHeight
        });
      }

      const GAP = 20;
      const CARD_WIDTH = cards[0]?.offsetWidth ?? 600; // FIXED: Get actual card width from DOM
      const CARD_PLUS_GAP = CARD_WIDTH + GAP;

      let currentPage = 0;
      let totalPages = 1;
      let cardsPerView = 1;
      const TOTAL_CARDS = cards.length;

      const calculatePaging = () => {
        const viewportWidth = viewport.clientWidth;
        cardsPerView = Math.max(1, Math.floor(viewportWidth / CARD_PLUS_GAP));
        totalPages = Math.max(1, Math.ceil(TOTAL_CARDS / cardsPerView));
        console.log('[Testimonials] calculatePaging():', {viewportWidth, CARD_PLUS_GAP, TOTAL_CARDS, cardsPerView, totalPages});
      };

      const updateTrackPosition = () => {
        const offset = currentPage * cardsPerView * CARD_PLUS_GAP;
        const transformValue = `translateX(-${offset}px)`;
        console.log('[Testimonials] updateTrackPosition:', {currentPage, cardsPerView, offset, transform: transformValue});
        console.log('[Testimonials]   BEFORE transform:', track.style.transform);
        track.style.transform = transformValue;
        console.log('[Testimonials]   AFTER transform:', track.style.transform);
        console.log('[Testimonials]   COMPUTED transform:', window.getComputedStyle(track).transform);
        updateButtonStates();
      };

      const updateButtonStates = () => {
        const isFirstPage = currentPage === 0;
        const isLastPage = currentPage === totalPages - 1;

        prevBtn.disabled = isFirstPage;
        nextBtn.disabled = isLastPage;
        if (leftZone) leftZone.style.pointerEvents = isFirstPage ? 'none' : 'auto';
        if (rightZone) rightZone.style.pointerEvents = isLastPage ? 'none' : 'auto';
      };

      let lastNavigateTime = 0;
      const NAVIGATE_COOLDOWN = 300; // FIXED: Add throttle to prevent rapid navigation

      const navigate = (direction) => {
        console.log(`[Testimonials] navigate('${direction}'): currentPage=${currentPage}, totalPages=${totalPages}`);
        if (direction === 'next' && currentPage < totalPages - 1) {
          currentPage++;
          console.log(`[Testimonials]   ✓ Moving NEXT → page ${currentPage}`);
          updateTrackPosition();
        } else if (direction === 'prev' && currentPage > 0) {
          currentPage--;
          console.log(`[Testimonials]   ✓ Moving PREV → page ${currentPage}`);
          updateTrackPosition();
        } else {
          console.log(`[Testimonials]   ✗ Cannot move in direction ${direction} (boundary reached)`);
        }
      };

    const throttledNavigate = (direction) => {
      const now = Date.now();
      if (now - lastNavigateTime >= NAVIGATE_COOLDOWN) {
        navigate(direction);
        lastNavigateTime = now;
      }
    };

    console.log('[Testimonials] === Initial Setup ===');
    console.log('[Testimonials] Calling calculatePaging()...');
    calculatePaging();
    console.log('[Testimonials] Calling updateButtonStates()...');
    updateButtonStates();
    console.log('[Testimonials] Initial state:', {currentPage, totalPages, cardsPerView});

    prevBtn.addEventListener('click', (e) => {
      console.log('[Testimonials] Prev button clicked, currentPage:', currentPage, 'totalPages:', totalPages);
      e.preventDefault();
      e.stopPropagation();
      navigate('prev');
    });
    nextBtn.addEventListener('click', (e) => {
      console.log('[Testimonials] Next button clicked, currentPage:', currentPage, 'totalPages:', totalPages);
      e.preventDefault();
      e.stopPropagation();
      navigate('next');
    });

    if (leftZone) leftZone.addEventListener('mouseenter', () => throttledNavigate('prev')); // FIXED: Use throttled version
    if (rightZone) rightZone.addEventListener('mouseenter', () => throttledNavigate('next')); // FIXED: Use throttled version

    window.addEventListener('resize', () => {
      calculatePaging();
      currentPage = Math.min(currentPage, totalPages - 1);
      updateTrackPosition();
    });

      console.log('[Testimonials] ✅ Carousel fully initialized');
    } else {
      console.error('[Testimonials] ❌ Carousel init FAILED - missing elements:');
      console.error('  track:', track ? '✓' : '✗');
      console.error('  viewport:', viewport ? '✓' : '✗');
      console.error('  cards.length > 0:', cards.length > 0 ? `✓ (${cards.length})` : `✗ (${cards.length})`);
      console.error('  prevBtn:', prevBtn ? '✓' : '✗');
      console.error('  nextBtn:', nextBtn ? '✓' : '✗');
      console.error('  viewport.clientWidth > 0:', viewport ? (viewport.clientWidth > 0 ? `✓ (${viewport.clientWidth}px)` : `✗ (${viewport.clientWidth}px)`) : 'N/A');
    }
  };

  // FIXED: Use more robust initialization timing
  console.log('[Testimonials] Initializing carousel...');
  if (document.readyState === 'loading') {
    console.log('[Testimonials] DOM loading, waiting for DOMContentLoaded...');
    document.addEventListener('DOMContentLoaded', () => {
      console.log('[Testimonials] DOMContentLoaded fired, calling initCarousel');
      initCarousel();
    });
  } else {
    console.log('[Testimonials] DOM ready, calling initCarousel immediately');
    initCarousel();
  }
</script>
