---
// Ramp What We Do - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions: 1791×485px, padding 40px

interface Service {
  name: string;
  percentage: number;
}

interface Props {
  services?: Service[];
}

const {
  services = [
    { name: "Marketing", percentage: 30 },
    { name: "Social Media", percentage: 50 },
    { name: "Coaching", percentage: 20 }
  ]
} = Astro.props;
---

<section class="what-we-do" id="what-we-do">
  <div class="container">
    <!-- LEFT: Label -->
    <div class="section-label">
      <h2>What we do</h2>
    </div>

    <!-- RIGHT: Content -->
    <div class="section-content">
      <p class="intro-text">We believe marketing doesn't have to be complicated. That's why we've built a creative hub filled with website templates, brand kits, free digital downloads and monthly support.</p>

      <div class="services-list">
        {services.map((service) => (
          <div class="service-item">
            <div class="service-row">
              <span class="service-name">{service.name}</span>
              <span class="service-percent">{service.percentage}%</span>
            </div>
            <div class="service-divider"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - TWO COLUMN LAYOUT */
  .what-we-do {
    background: #FFFFFF;
    width: 100%;
    max-width: 1791px;
    padding: 80px 40px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .container {
    max-width: 1711px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 100px;
    box-sizing: border-box;
    align-items: start;
  }

  .section-label {
    display: flex;
    align-items: flex-start;
    padding-top: 4px;
  }

  .section-label h2 {
    font-family: 'Azeret Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
    line-height: 1.4;
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .intro-text {
    font-size: 16px;
    line-height: 1.6;
    color: #575757;
    margin: 0;
    max-width: 100%;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .service-item {
    padding: 32px 0;
    border-bottom: 1px solid #E0E0E0;
  }

  .service-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .service-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0;
  }

  .service-name {
    font-size: 16px;
    font-weight: 400;
    color: #000000;
  }

  .service-percent {
    font-size: 16px;
    font-weight: 400;
    color: #000000;
  }

  .service-divider {
    display: none;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .what-we-do {
      padding: 60px 40px;
    }

    .container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .section-label {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .what-we-do {
      padding: 40px 20px;
    }

    .container {
      gap: 30px;
    }

    .intro-text {
      font-size: 14px;
    }

    .service-name,
    .service-percent {
      font-size: 14px;
    }
  }
</style>
