---
// Ramp What We Do - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions: 1791×485px, padding 40px

interface Service {
  name: string;
  percentage: number;
}

interface Props {
  services?: Service[];
}

const {
  services = [
    { name: "Marketing", percentage: 30 },
    { name: "Social Media", percentage: 50 },
    { name: "Coaching", percentage: 20 }
  ]
} = Astro.props;
---

<section class="what-we-do" id="what-we-do">
  <div class="container">
    <!-- LEFT: Label -->
    <div class="section-label">
      <h2>What we do</h2>
    </div>

    <!-- RIGHT: Content (554px flex column) -->
    <div class="section-content">
      <p class="intro-text">We believe marketing doesn't have to be complicated. That's why we've built a creative hub filled with website templates, brand kits, free digital downloads and monthly support.</p>

      <div class="breakdown">
        <ul class="services-list">
          {services.map((service, index) => (
            <>
              {index > 0 && <li class="service-divider"></li>}
              <li class="service-item">
                <span class="service-name">{service.name}</span>
                <span class="service-percent">{service.percentage}%</span>
              </li>
            </>
          ))}
          <li class="service-divider"></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - TWO COLUMN LAYOUT */
  .what-we-do {
    background: #FFFFFF;
    width: 100%;
    max-width: 1791px;
    padding: 80px 40px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .container {
    margin: 0 auto;
    width: 100%;
    max-width: 1711px;
    display: flex;
    flex-direction: row;
    box-sizing: border-box;
    gap: 80px;
    align-items: flex-start;
  }

  .section-label {
    flex: 0 0 auto;
    width: auto;
  }

  .section-label h2 {
    font-family: 'Azeret Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
    line-height: 1.4;
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 554px;
    box-sizing: border-box;
    align-items: flex-start;
    align-content: flex-start;
    justify-content: center;
    padding: 0;
  }

  .intro-text {
    font-size: 16px;
    line-height: 1.6;
    color: #575757;
    margin: 0;
  }

  .breakdown {
    width: 100%;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .service-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    list-style: none;
  }

  .service-name {
    font-size: 16px;
    font-weight: 400;
    color: #000000;
  }

  .service-percent {
    font-size: 16px;
    font-weight: 400;
    color: #000000;
  }

  .service-divider {
    height: 1px;
    background: #E0E0E0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .what-we-do {
      padding: 60px 40px;
    }

    .container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .section-label {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .what-we-do {
      padding: 40px 20px;
    }

    .container {
      gap: 30px;
    }

    .intro-text {
      font-size: 14px;
    }

    .service-name,
    .service-percent {
      font-size: 14px;
    }
  }
</style>
