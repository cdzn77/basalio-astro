---
// Ramp What We Do - 1:1 PIXEL-PERFECT SPEC MATCH
// Two-column layout: LEFT (35%, eyebrow) | RIGHT (65%, paragraph + stats)

interface Service {
  name: string;
  percentage: number;
}

interface Props {
  services?: Service[];
}

const {
  services = [
    { name: "Marketing", percentage: 30 },
    { name: "Social Media", percentage: 50 },
    { name: "Coaching", percentage: 20 }
  ]
} = Astro.props;
---

<section class="what-we-do">
  <!-- LEFT COLUMN: Eyebrow label (35%) -->
  <div class="column-left">
    <p class="eyebrow">What we do</p>
  </div>

  <!-- RIGHT COLUMN: Paragraph + Stats (65%) -->
  <div class="column-right">
    <!-- Block 1: Intro paragraph (max-width 800px) -->
    <div class="paragraph-block">
      <p class="intro-text">We believe marketing doesn't have to be complicated. That's why we've built a creative hub filled with website templates, brand kits, free digital downloads and monthly support.</p>
    </div>

    <!-- Block 2: Stats list (width 554px, with dividers) -->
    <div class="stats-block">
      <div class="divider"></div>
      {services.map((service) => (
        <>
          <div class="stat-row">
            <span class="stat-label">{service.name}</span>
            <span class="stat-percent">{service.percentage}%</span>
          </div>
          <div class="divider"></div>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  /* SECTION: flex row, 40px padding, #FAFAFA background */
  .what-we-do {
    display: flex;
    flex-direction: row;
    padding: 40px;
    background-color: #FAFAFA;
    width: 100%;
    box-sizing: border-box;
  }

  /* LEFT COLUMN: max-width 35%, flex: 1 1 0% */
  .column-left {
    flex: 1 1 0%;
    max-width: 35%;
  }

  /* Eyebrow label */
  .eyebrow {
    font-family: 'Azeret Mono', 'Courier New', monospace;
    font-size: 14px;
    font-weight: 500;
    line-height: 19.6px;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
  }

  /* RIGHT COLUMN: max-width 65%, flex: 1 1 0%, flex column, align-items flex-start, gap 100px */
  .column-right {
    flex: 1 1 0%;
    max-width: 65%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 100px;
  }

  /* Block 1: Paragraph (max-width 800px) */
  .paragraph-block {
    max-width: 800px;
  }

  .intro-text {
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 26.4px;
    letter-spacing: -0.22px;
    color: #000000;
    margin: 0;
  }

  /* Block 2: Stats (flex column, gap 20px, width 554px) */
  .stats-block {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 554px;
  }

  /* Divider: 1px, light gray to match original template */
  .divider {
    height: 1px;
    width: 100%;
    background-color: #E8E8E8;
  }

  /* Stat row: flex row, align-items center, width 100% */
  .stat-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 100%;
  }

  /* Stat label: flex-grow 1, flex-shrink 0, flex-basis 0 (pushes percentage to far right) */
  .stat-label {
    flex-grow: 1;
    flex-shrink: 0;
    flex-basis: 0;
    font-family: 'Switzer', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    letter-spacing: normal;
    color: rgb(87, 87, 87);
  }

  /* Stat percent: flex-grow 0, flex-shrink 0, width auto */
  .stat-percent {
    flex-grow: 0;
    flex-shrink: 0;
    width: auto;
    font-family: 'Azeret Mono', 'Courier New', monospace;
    font-size: 18px;
    font-weight: 400;
    line-height: 18px;
    letter-spacing: -0.72px;
    color: #000000;
  }
</style>
