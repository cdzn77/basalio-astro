---
// Ramp What We Do - 1:1 PIXEL-PERFECT REPLICA
// Exact dimensions: 1791×485px, padding 40px

interface Service {
  name: string;
  percentage: number;
}

interface Props {
  services?: Service[];
}

const {
  services = [
    { name: "Marketing", percentage: 30 },
    { name: "Social Media", percentage: 50 },
    { name: "Coaching", percentage: 20 }
  ]
} = Astro.props;
---

<section class="what-we-do" id="what-we-do">
  <div class="container">
    <div class="section-intro">
      <h2>What we do</h2>
      <p class="intro-text">We believe marketing doesn't have to be complicated. That's why we've built a creative hub filled with practical resources, hands-on courses, and personalized support to help you build sustainable marketing systems.</p>
    </div>

    <div class="services-list">
      {services.map((service) => (
        <div class="service-item">
          <div class="service-row">
            <span class="service-name">{service.name}</span>
            <span class="service-percent">{service.percentage}%</span>
          </div>
          <div class="service-divider"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* EXACT PIXEL SPECIFICATIONS - RESPONSIVE VERSION */
  .what-we-do {
    background: #FAFAFA;
    width: 100%;
    max-width: 1791px;
    height: 485px;
    padding: 40px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .container {
    max-width: 1711px;
    margin: 0;
    padding: 0;
    width: 100%;
    height: 405px;
    display: flex;
    flex-direction: column;
  }

  .section-intro {
    margin-bottom: 40px;
  }

  .section-intro h2 {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    color: #000000;
    margin: 0 0 16px 0;
  }

  .intro-text {
    font-size: 16px;
    line-height: 1.6;
    color: #575757;
    max-width: 700px;
    margin: 0;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .service-item {
    padding: 24px 0;
  }

  .service-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .service-name {
    font-size: 16px;
    font-weight: 400;
    color: #000000;
  }

  .service-percent {
    font-size: 16px;
    font-weight: 400;
    color: #000000;
  }

  .service-divider {
    height: 1px;
    background: #E0E0E0;
  }

  .service-item:last-child .service-divider {
    display: none;
  }

  /* RESPONSIVE OVERRIDES */
  @media (max-width: 1024px) {
    .what-we-do {
      width: 100%;
      height: auto;
    }

    .container {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .what-we-do {
      width: 100%;
      padding: 40px 20px;
    }

    .intro-text {
      font-size: 14px;
    }

    .service-name,
    .service-percent {
      font-size: 14px;
    }
  }
</style>
