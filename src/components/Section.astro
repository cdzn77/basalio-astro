---
// Section Component - Reusable section wrapper
interface Props {
  id?: string;
  title?: string;
  description?: string;
  class?: string;
}

const { id, title, description, class: className } = Astro.props;
---

<section {id} class={className}>
  <div class="container-content">
    {title && <h2>{title}</h2>}
    {description && <p class="text-lg text-secondary mb-4xl">{description}</p>}
    <slot />
  </div>
</section>
