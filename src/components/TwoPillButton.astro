---
// Wrapper component for Button - can be used interchangeably
// Imports the reusable Button component

import Button from './Button.astro';

interface Props {
  label: string;
  href: string;
  uppercase?: boolean;
  fontSize?: string;
  fontWeight?: string;
  letterSpacing?: string;
}

const {
  label,
  href,
  uppercase = true,
  fontSize = "14px",
  fontWeight = "500",
  letterSpacing = "2.8px"
} = Astro.props;
---

<Button
  label={label}
  href={href}
  uppercase={uppercase}
  fontSize={fontSize}
  fontWeight={fontWeight}
  letterSpacing={letterSpacing}
/>
