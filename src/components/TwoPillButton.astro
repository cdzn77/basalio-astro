---
// Dual-button component matching RampHero design
// Used across: header CTA, Courses View All, Resources View All, etc.

interface Props {
  label: string;
  href: string;
  uppercase?: boolean;
  fontSize?: string;
  fontWeight?: string;
  letterSpacing?: string;
}

const {
  label,
  href,
  uppercase = true,
  fontSize = "14px",
  fontWeight = "500",
  letterSpacing = "2.8px"
} = Astro.props;
---

<a href={href} class="view-button">
  <div class="btn-text-box">
    <div class="btn-text-wrapper">
      <p class="btn-text-content">{uppercase ? label.toUpperCase() : label}</p>
    </div>
  </div>
  <div class="btn-arrow-box">
    <div class="btn-arrow btn-arrow-left">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
        <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
        <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
      </svg>
    </div>
    <div class="btn-arrow btn-arrow-right">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
        <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
        <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
      </svg>
    </div>
  </div>
</a>

<style define:vars={{ fontSize, fontWeight, letterSpacing }}>
  .view-button {
    display: flex;
    flex-direction: row;
    height: 43.6px;
    cursor: pointer;
    position: relative;
    opacity: 1;
    background: transparent;
    border: none;
    padding: 0;
    text-decoration: none;
    -webkit-font-smoothing: antialiased;
  }

  .btn-text-box {
    background-color: #000000;
    border-radius: 8px;
    height: 43.6px;
    padding: 12px 16px;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    column-gap: 10px;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .btn-text-wrapper {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    box-sizing: border-box;
  }

  .btn-text-content {
    font-family: 'Azeret Mono', monospace;
    font-size: var(--fontSize);
    font-weight: var(--fontWeight);
    letter-spacing: var(--letterSpacing);
    line-height: 19.6px;
    text-transform: uppercase;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    white-space: nowrap;
    height: 19.6px;
  }

  .btn-arrow-box {
    background-color: #000000;
    border-radius: 8px;
    height: 43.6px;
    width: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    column-gap: 10px;
    flex-shrink: 0;
    position: relative;
    margin-left: 8px;
  }

  .btn-arrow {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 16px;
    width: 16px;
    position: absolute;
    will-change: transform;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .btn-arrow-left {
    opacity: 0;
    transform: translateX(-8px);
  }

  .btn-arrow-right {
    opacity: 1;
    transform: translateX(0);
  }

  .btn-arrow svg {
    height: 100%;
    width: 100%;
    stroke: #FFFFFF;
    stroke-width: 1.5px;
    fill: none;
    stroke-miterlimit: 10;
  }

  .view-button:hover .btn-arrow-left {
    opacity: 1;
  }

  .view-button:hover .btn-arrow-right {
    opacity: 0;
  }
</style>
