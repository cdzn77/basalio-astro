---
// Shared two-pill button component (text pill + icon pill)
// Used across: header CTA, Courses View All, Resources View All, Retainer Contact Us, Retainer Subscribe ×2

interface Props {
  label: string;
  href: string;
  uppercase?: boolean;
  fontSize?: string;
  fontWeight?: string;
  letterSpacing?: string;
}

const {
  label,
  href,
  uppercase = true,
  fontSize = "14px",
  fontWeight = "500",
  letterSpacing = "2.8px"
} = Astro.props;
---

<a href={href} class="two-pill-button">
  <span class="pill-text">{uppercase ? label.toUpperCase() : label}</span>
  <span class="pill-icon">
    <div class="pill-arrow pill-arrow-left">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
        <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
        <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
      </svg>
    </div>
    <div class="pill-arrow pill-arrow-right">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10">
        <line x1="21.5" y1="12" x2="0.5" y2="12"></line>
        <polyline points="13.86 4.36 21.5 12 13.86 19.64"></polyline>
      </svg>
    </div>
  </span>
</a>

<style>
  .two-pill-button {
    display: flex;
    flex-direction: row;
    gap: 0;
    text-decoration: none;
    width: fit-content;
    height: 44px;
  }

  .pill-text {
    background: var(--basalio-ink, #000000);
    color: var(--basalio-paper, #FFFFFF);
    border-radius: 8px 0 0 8px;
    padding: 12px 16px;
    font-size: v-bind(fontSize);
    font-weight: v-bind(fontWeight);
    letter-spacing: v-bind(letterSpacing);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    margin-right: -1px;
    position: relative;
    z-index: 1;
  }

  .pill-icon {
    background: var(--basalio-ink, #000000);
    color: var(--basalio-paper, #FFFFFF);
    border-radius: 0 8px 8px 0;
    width: 40px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 40px;
    position: relative;
  }

  .pill-arrow {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .pill-arrow-left {
    opacity: 0;
    transform: translateX(-8px);
  }

  .pill-arrow-right {
    opacity: 1;
    transform: translateX(0);
  }

  .pill-arrow svg {
    width: 100%;
    height: 100%;
    stroke: var(--basalio-paper, #FFFFFF);
    fill: none;
  }

  .two-pill-button:hover .pill-arrow-left {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }

  .two-pill-button:hover .pill-arrow-right {
    opacity: 0 !important;
    transform: translateX(8px) !important;
  }
</style>
