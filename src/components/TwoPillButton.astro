---
// Shared two-pill button component (text pill + icon pill)
// Used across: header CTA, Courses View All, Resources View All, Retainer Contact Us, Retainer Subscribe ×2

interface Props {
  label: string;
  href: string;
  uppercase?: boolean;
  fontSize?: string;
  fontWeight?: string;
  letterSpacing?: string;
}

const {
  label,
  href,
  uppercase = true,
  fontSize = "14px",
  fontWeight = "500",
  letterSpacing = "2.8px"
} = Astro.props;
---

<a href={href} class="two-pill-button">
  <span class="pill-text">{uppercase ? label.toUpperCase() : label}</span>
  <span class="pill-icon">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M6 2L12 8L6 14"></path>
    </svg>
  </span>
</a>

<style>
  .two-pill-button {
    display: flex;
    flex-direction: row;
    gap: 0;
    text-decoration: none;
    width: fit-content;
    height: 44px;
  }

  .pill-text {
    background: var(--basalio-ink, #000000);
    color: var(--basalio-paper, #FFFFFF);
    border-radius: 8px 0 0 8px;
    padding: 12px 16px;
    font-size: v-bind(fontSize);
    font-weight: v-bind(fontWeight);
    letter-spacing: v-bind(letterSpacing);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    margin-right: -1px;
    position: relative;
    z-index: 1;
  }

  .pill-icon {
    background: var(--basalio-ink, #000000);
    color: var(--basalio-paper, #FFFFFF);
    border-radius: 0 8px 8px 0;
    width: 40px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 40px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }

  .two-pill-button:hover .pill-icon {
    transform: translateX(4px);
  }
</style>
