---
// Ramp Studio Template Master Layout - EXACT REVERSE-ENGINEERED SPECS
// All colors, fonts, spacing, and styling from comprehensive reverse-engineering

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ramp Marketing Systems, Courses & Resources for Modern Teams",
  description = "Ramp helps marketers, founders, and creators build scalable marketing systems through practical courses, curated resources, and ongoing education."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Azeret+Mono:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #000000;
      background: #FFFFFF;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* TYPOGRAPHY - EXACT FROM SPECS */
    h1 {
      font-family: 'Manrope', sans-serif;
      font-size: 72px;
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: #000000;
    }

    h2 {
      font-family: 'Manrope', sans-serif;
      font-size: clamp(48px, 6vw, 64px);
      font-weight: 400;
      line-height: 1.2;
      letter-spacing: -0.01em;
      color: #000000;
    }

    h3 {
      font-family: 'Manrope', sans-serif;
      font-size: 28px;
      font-weight: 600;
      line-height: 1.3;
      color: #000000;
    }

    h4 {
      font-family: 'Manrope', sans-serif;
      font-size: 18px;
      font-weight: 600;
      line-height: 1.4;
      color: #000000;
    }

    p {
      font-family: 'Manrope', sans-serif;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.6;
      color: #000000;
    }

    .text-label {
      font-family: 'Azeret Mono', monospace;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #575757;
    }

    .text-small {
      font-size: 14px;
      font-weight: 400;
      line-height: 1.5;
    }

    /* COLORS - EXACT RGB VALUES */
    :root {
      --color-yellow: #FFEA00;
      --color-black: #000000;
      --color-white: #FFFFFF;
      --color-light-gray: #F5F5F5;
      --color-medium-gray: #999999;
      --color-dark-gray: #3C3C3C;
      --color-text-gray: #575757;
    }

    /* LAYOUT STRUCTURE */
    .ramp-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background: transparent;
      z-index: 1000;
      padding: 20px 40px;
      border-bottom: none;
      height: 80px;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      box-sizing: border-box;
      transition: backdrop-filter 0.3s ease, background 0.3s ease;
      backdrop-filter: blur(0px);
    }

    .ramp-header.scrolled {
      backdrop-filter: blur(10px);
    }

    .ramp-main {
      position: relative;
      z-index: 2;
    }

    .ramp-footer {
      position: sticky;
      bottom: 0;
      z-index: 1;
    }

    /* Last content section before footer: rounded bottom corners for curtain reveal effect */
    .ramp-main > section:last-child {
      border-radius: 0 0 40px 40px;
    }

    /* CONTAINER */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
    }

    /* BUTTONS - EXACT SPECS */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 12px 24px;
      background: #000000;
      color: #FFFFFF;
      border: none;
      border-radius: 6px;
      font-family: 'Manrope', sans-serif;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .btn:hover {
      opacity: 0.8;
      transform: translateY(-2px);
    }

    /* SECTIONS */
    section {
      padding: 80px 0;
    }

    section.yellow {
      background: #FFEA00;
      color: #000000;
    }

    section.white {
      background: #FFFFFF;
      color: #000000;
    }

    section.light-gray {
      background: #F5F5F5;
      color: #000000;
    }

    section.dark {
      background: #000000;
      color: #FFFFFF;
    }

    /* LINKS */
    a {
      color: inherit;
      text-decoration: none;
      transition: opacity 0.2s ease;
    }

    a:hover {
      opacity: 0.7;
    }

    /* GRID & FLEX */
    .grid {
      display: grid;
      gap: 32px;
    }

    .grid-2 {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }

    .flex {
      display: flex;
    }

    .flex-center {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .flex-between {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    /* ANIMATIONS */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes slideInLeft {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .animate-in {
      animation: fadeInUp 0.6s ease-out forwards;
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .grid-2,
      .grid-3 {
        grid-template-columns: 1fr;
      }

      section {
        padding: 60px 0;
      }

      .container {
        padding: 0 30px;
      }
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 48px;
      }

      h2 {
        font-size: clamp(36px, 5vw, 48px);
      }

      section {
        padding: 40px 0;
      }

      .container {
        padding: 0 20px;
      }

      .btn {
        font-size: 11px;
        padding: 10px 20px;
      }
    }
  </style>
</head>

<body>
  <header class="ramp-header">
    <slot name="header" />
  </header>

  <main class="ramp-main">
    <slot />
  </main>

  <footer class="ramp-footer">
    <slot name="footer" />
  </footer>

  <script>
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        const href = this.getAttribute('href');
        if (href !== '#' && document.querySelector(href)) {
          e.preventDefault();
          document.querySelector(href).scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    // Mobile menu toggle
    const menuBtn = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('active');
      });

      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('active');
        });
      });
    }
  </script>
</body>
</html>
