---
// Course Detail Page - Dynamic route for individual courses
import RampTemplateLayout from '../../layouts/RampTemplateLayout.astro';
import RampHeader from '../../components/RampHeader.astro';
import RampFooter from '../../components/RampFooter.astro';
import { courses, getCourse } from '../../data/courses';

export async function getStaticPaths() {
  return Object.values(courses).map(course => ({
    params: { slug: course.slug },
    props: { course }
  }));
}

interface Props {
  course: typeof courses[keyof typeof courses];
}

const { course } = Astro.props as Props;

const title = `${course.title} — Ramp Studio`;
const description = course.fullDescription;
---

<RampTemplateLayout title={title} description={description}>
  <!-- HEADER: Navigation bar -->
  <Fragment slot="header">
    <RampHeader />
  </Fragment>

  <!-- BREADCRUMB: Full-width, separate from header -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/index-ramp-rebuild">HOME</a>
    <span aria-hidden="true">/</span>
    <a href="/courses">COURSES</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">{course.title.toUpperCase()}</span>
  </nav>

  <!-- HERO SECTION: Yellow background with course info -->
  <section class="hero-section">
    <!-- LEFT: Description and CTA -->
    <div class="hero-left">
      <h1 class="course-title">{course.title}</h1>
      <p class="course-full-description">{course.fullDescription}</p>
      <button class="enroll-btn">
        <span class="enroll-text">{course.enrollLabel}</span>
        <span class="enroll-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 8H15M15 8L8 1M15 8L8 15"></path>
          </svg>
        </span>
      </button>

      <!-- Description meta -->
      <div class="description-meta">
        <p class="description-label">Got a question?</p>
        <p class="description-text">{course.descriptionText}</p>
      </div>
    </div>

    <!-- RIGHT: Highlights -->
    <div class="hero-right">
      <div class="highlights">
        {course.highlights.map(highlight => (
          <div class="highlight-item">
            <p class="highlight-title">{highlight}</p>
            <p class="highlight-description">Learn the exact strategic systems marketers use to turn content into sales.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HERO IMAGE -->
  <section class="hero-image-section">
    <img src={course.heroImage} alt="{course.title} hero image" class="hero-image" />
  </section>

  <!-- WHO IS THIS FOR SECTION -->
  <section class="who-is-this-for-section">
    <div class="who-is-this-for-left">
      <h2 class="section-heading">WHO IS THIS FOR</h2>
    </div>
    <div class="who-is-this-for-container">
      <div class="audience-grid">
        {course.whoIsThisFor.map(audience => (
          <div class="audience-card">
            <h3 class="audience-title">{audience.title}</h3>
            <p class="audience-description">{audience.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COURSE OVERVIEW SECTION -->
  <section class="course-overview-section">
    <div class="course-overview-left">
      <h2 class="section-heading">{course.courseOverviewHeading}</h2>
    </div>
    <div class="overview-container">
      <div class="overview-header">
        <p class="overview-description">{course.courseOverviewDescription}</p>
        <button class="download-btn">
          <span class="download-text">{course.downloadLabel}</span>
          <span class="download-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 8H15M15 8L8 1M15 8L8 15"></path>
            </svg>
          </span>
        </button>
      </div>

      <!-- ACCORDION: Course Modules -->
      <div class="modules-accordion">
        {course.modules.map(module => (
          <div class="accordion-item">
            <button class="accordion-header" data-module-id={module.number}>
              <span class="module-number">{String(module.number).padStart(2, '0')}</span>
              <span class="module-title">{module.title}</span>
              <span class="accordion-icon" aria-hidden="true">+</span>
            </button>
            <div class="accordion-content" data-module-id={module.number}>
              <p>Learn the comprehensive strategies and implementation tactics for {module.title.toLowerCase()}.</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MODULE IMAGE -->
  <section class="module-image-section">
    <img src={course.moduleImage} alt="Course module image" class="module-image" />
  </section>

  <!-- TOOLS SECTION -->
  <section class="tools-section">
    <div class="tools-header">
      <div class="tools-left">
        <h2 class="section-heading">Tools</h2>
      </div>
      <div class="tools-container">
        <div class="tools-grid">
          {course.tools.map(tool => (
            <div class="tool-card">
              <h3 class="tool-title">{tool.title}</h3>
              <p class="tool-description">{tool.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- INSTRUCTOR SECTION: Yellow background -->
  <section class="instructor-section">
    <div class="instructor-header">
      <div class="instructor-left">
        <h2 class="section-heading">INSTRUCTOR</h2>
      </div>
    </div>

    <div class="instructor-content-wrapper">
      <!-- LEFT: Image with name/title below -->
      <div class="instructor-image-section">
        <div class="instructor-image-wrapper">
          <img src={course.instructor.image} alt={course.instructor.name} class="instructor-image" />
        </div>
        <div class="instructor-info">
          <h3 class="instructor-name">{course.instructor.name}</h3>
          <p class="instructor-title">{course.instructor.title}</p>
        </div>
      </div>

      <!-- RIGHT: Stats and bio -->
      <div class="instructor-details">
        <div class="instructor-dot"></div>
        <div class="instructor-stats">
          <div class="stat">
            <p class="stat-label">YEARS</p>
            <p class="stat-value">{course.instructor.years}+ years of experience</p>
          </div>
          <div class="stat">
            <p class="stat-label">EXPERTISE</p>
            <p class="stat-value">{course.instructor.expertise}</p>
          </div>
          <div class="stat">
            <p class="stat-label">INDUSTRY</p>
            <p class="stat-value">{course.instructor.industry}</p>
          </div>
        </div>
        <p class="instructor-bio">{course.instructor.bio}</p>
      </div>
    </div>

    <img src={course.instructorImage} alt="Instructor background image" class="instructor-bg-image" />
  </section>

  <!-- TOOLS IMAGE -->
  <section class="tools-image-section">
    <img src={course.toolsImage} alt="Tools image" class="tools-image" />
  </section>

  <!-- CLOSING IMAGE -->
  <section class="closing-image-section">
    <img src={course.closingImage} alt="Course closing image" class="closing-image" />
  </section>

  <!-- FOOTER: Reused from homepage -->
  <Fragment slot="footer">
    <RampFooter address="Østerbrogade 45, 2100 København Ø, Copenhagen, Denmark" />
  </Fragment>
</RampTemplateLayout>

