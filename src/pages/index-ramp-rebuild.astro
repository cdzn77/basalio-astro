---
// Ramp Studio Homepage - Complete rebuild in Astro
// Exact replica of the Ramp Studio template

import RampTemplateLayout from '../layouts/RampTemplateLayout.astro';
import RampHeader from '../components/RampHeader.astro';
import RampHero from '../components/RampHero.astro';
import RampWhatWeDo from '../components/RampWhatWeDo.astro';
import RampCourses from '../components/RampCourses.astro';
import RampResources from '../components/RampResources.astro';
import RampRetainer from '../components/RampRetainer.astro';
import RampTestimonials from '../components/RampTestimonials.astro';
import RampFAQ from '../components/RampFAQ.astro';
import RampFooter from '../components/RampFooter.astro';

const title = "Basalio - WordPress Portfolio Modules";
const description = "Nine curated interaction modules for portfolio and case-study sites. Built for WordPress, not Framer.";
---

<RampTemplateLayout title={title} description={description}>
  <!-- HEADER: Navigation bar (universal across all pages) -->
  <Fragment slot="header">
    <RampHeader />
  </Fragment>

  <!-- Hero Section -->
  <RampHero
    courseLabel="For WordPress • Not a page builder"
    courseText="Give your work a foundation to stand on. Nine curated interaction modules, from grid reveals to case-study transitions to scroll-tied sequences, built only for portfolio and case-study sites. Nothing you'd need Framer for. Nothing you don't."
    courseButton="EXPLORE MODULES"
    courseLink="#modules"
    heroImage="https://framerusercontent.com/images/WAxIIZFwFsal6BUSuk7mft7nN7U.png"
  />

  <!-- What We Do Section -->
  <RampWhatWeDo
    eyebrow="Positioning • 01"
    introText="Nine curated interaction modules, built only for portfolio and case-study sites. Each module solves one specific problem—no bloat, no learning curve."
    services={[
      { value: 9, description: "Modules, not 90" },
      { value: 1, description: "Plugin, zero page-builder lock-in" },
      { value: 0, description: "Generic presets, only opinionated ones" }
    ]}
  />

  <!-- Modules Section -->
  <RampCourses
    sectionLabel="OUR MODULES"
    sectionHeading="Nine Interaction Modules"
    ctaLabel="Explore All"
    courses={[
      {
        title: "Grid Reveal",
        description: "Reveal content in a cascading grid pattern as users scroll down the page",
        link: "/modules/grid-reveal"
      },
      {
        title: "Case Study Transition",
        description: "Smooth transitions between case studies with parallax and fade effects",
        link: "/modules/case-study-transition"
      },
      {
        title: "Scroll Sequence",
        description: "Trigger animations based on scroll position for synchronized storytelling",
        link: "/modules/scroll-sequence"
      },
      {
        title: "Image Counter",
        description: "Animate numerical counters that respond to viewport interactions",
        link: "/modules/image-counter"
      },
      {
        title: "Timeline",
        description: "Interactive timeline component for process documentation and milestones",
        link: "/modules/timeline"
      },
      {
        title: "Hover Image Grid",
        description: "Dynamic image grid that responds to hover states and interactions",
        link: "/modules/hover-image-grid"
      },
      {
        title: "Magnetic Button",
        description: "Button that follows cursor with magnetic snap-to-center behavior",
        link: "/modules/magnetic-button"
      },
      {
        title: "Parallax Content",
        description: "Multi-layer parallax effect for depth and visual hierarchy",
        link: "/modules/parallax-content"
      },
      {
        title: "Scroll Lock",
        description: "Lock viewport scroll while showcasing full-width content sequences",
        link: "/modules/scroll-lock"
      }
    ]}
    ctaLink="#modules"
  />

  <!-- Resources Section -->
  <RampResources
    resources={[
      { title: "Client Onboarding", description: "Complete onboarding templates and checklists for new clients" },
      { title: "Branding Framework", description: "Step-by-step framework for building a cohesive brand identity" },
      { title: "AI Prompts for Marketing", description: "Ready-to-use prompts for content creation and strategy" }
    ]}
  />

  <!-- Monthly Retainer Section -->
  <RampRetainer />

  <!-- Testimonials Section -->
  <RampTestimonials />

  <!-- FAQ Section -->
  <RampFAQ
    faqs={[
      {
        question: "What does Ramp Studio do?",
        answer: "Ramp Studio helps brands build momentum through practical marketing education, hands-on execution, and ongoing support. We offer courses, resources, and retainer services designed specifically for digital creatives and entrepreneurs."
      },
      {
        question: "Who is Ramp Studio for?",
        answer: "We serve marketers, founders, content creators, and small business owners who want to build scalable marketing systems without feeling overwhelmed. Our content is accessible to beginners while remaining valuable for experienced professionals."
      },
      {
        question: "How do your courses work?",
        answer: "Our courses are self-paced, comprehensive programs that combine video lessons, worksheets, templates, and community support. You get lifetime access to course materials and can work through them at your own pace."
      },
      {
        question: "What is the subscription marketing retainer?",
        answer: "Our retainer service provides ongoing support including design updates, content creation, strategy calls, and email support. We offer Essentials and Premium tiers depending on your needs."
      },
      {
        question: "Do I need to choose between courses, resources, or the retainer?",
        answer: "No! Many clients use a combination of our offerings. You might take a course to learn fundamentals, use resources to accelerate your work, and hire us for retainer support for ongoing execution."
      },
      {
        question: "What makes Ramp Studio different from other marketing agencies?",
        answer: "We combine education with execution. Rather than just doing the work for you, we teach you how to build sustainable systems. Plus, we're transparent about our pricing and focused on serving creative entrepreneurs specifically."
      }
    ]}
  />

  <Fragment slot="footer">
    <RampFooter address="Østerbrogade 45, 2100 København Ø, Copenhagen, Denmark" />
  </Fragment>
</RampTemplateLayout>
