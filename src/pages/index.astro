---
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Basalio - WordPress Portfolio Modules</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@1,9..144,500&display=swap" rel="stylesheet">
	<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cpolygon points='8,56 56,56 46,44 18,44' fill='%23F6F4EF'/%3E%3Crect x='23' y='20' width='18' height='24' fill='%23DFFF00'/%3E%3C/svg%3E">
	<style>
		* { box-sizing: border-box; }
		html { scroll-behavior: smooth; }
		body {
			margin: 0;
			font-family: 'Inter', sans-serif;
			font-size: 16px;
			line-height: 1.5;
			-webkit-font-smoothing: antialiased;
		}
		a { color: inherit; text-decoration: none; }
		a:focus, button:focus, input:focus, select:focus, textarea:focus {
			outline: 2px solid #000;
			outline-offset: 2px;
		}

		/* Animations */
		@keyframes riseIn { to { opacity: 1; transform: translateY(0); } }
		@keyframes benchPulse { 0%,100% { box-shadow: 0 4px 14px rgba(0,0,0,0.4), 0 0 0 0 rgba(0,0,0,0.4); } 50% { box-shadow: 0 4px 14px rgba(0,0,0,0.4), 0 0 0 16px rgba(0,0,0,0); } }
		@keyframes fillBar { from { width: 0; } to { width: var(--bar-width); } }
		@keyframes moveKnob { from { left: 0; } to { left: var(--knob-position); } }
		@keyframes countUp { from { opacity: 0; } to { opacity: 1; } }
		@keyframes slideUp { from { opacity: 0; transform: translateY(100%); } to { opacity: 1; transform: translateY(0); } }

		.bench-bar { animation: fillBar 2s cubic-bezier(.16,1,.3,1) forwards; }
		.bench-knob { animation: moveKnob 2s cubic-bezier(.16,1,.3,1) forwards; }
		.bench-stat { animation: countUp 1s ease-out forwards; }
		.text-reveal-word { animation: slideUp .6s cubic-bezier(.16,1,.3,1) forwards; }
		.text-reveal-word:nth-child(1) { animation-delay: 0.1s; }
		.text-reveal-word:nth-child(2) { animation-delay: 0.2s; }
		.text-reveal-word:nth-child(3) { animation-delay: 0.3s; }

		/* Navigation */
		nav {
			position: fixed;
			top: 14px;
			left: 0;
			right: 0;
			z-index: 50;
			padding: 0 20px;
			pointer-events: none;
		}
		nav > div {
			max-width: 1120px;
			margin: 0 auto;
			background: rgba(255, 255, 255, 0.95);
			backdrop-filter: blur(14px);
			border: 1px solid rgba(0, 0, 0, 0.08);
			border-radius: 999px;
			padding: 8px 8px 8px 22px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.15);
			pointer-events: auto;
		}
		nav a {
			font-family: 'Space Grotesk', sans-serif;
			font-size: 18px;
			font-weight: 700;
			display: flex;
			align-items: center;
			gap: 8px;
			color: #000;
		}
		nav svg { flex: none; }
		nav > div > div {
			display: flex;
			gap: 26px;
			align-items: center;
		}
		nav > div > div > a {
			font-size: 14px;
			font-weight: 500;
			color: #666;
			transition: color .15s ease;
		}
		nav > div > div > a:hover {
			color: #000;
		}
		nav .btn-primary {
			display: inline-flex;
			align-items: center;
			font-family: 'Space Grotesk', sans-serif;
			font-weight: 600;
			font-size: 13px;
			padding: 9px 18px;
			border-radius: 999px;
			background: #000;
			color: #fff;
			transition: all .18s ease;
		}
		nav .btn-primary:hover {
			transform: translateY(-2px);
		}

		#mobileMenuBtn {
			display: none;
			background: none;
			border: none;
			color: #000;
			cursor: pointer;
			padding: 0;
			width: 44px;
			height: 44px;
		}
		#mobileMenu {
			display: none;
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			width: 100%;
			height: 100vh;
			background: #fff;
			overflow-y: auto;
			z-index: 48;
			flex-direction: column;
			padding-top: 80px;
		}
		#mobileMenu.open { display: flex; }
		#mobileMenu a {
			display: block;
			padding: 16px 20px;
			border-bottom: 1px solid rgba(0, 0, 0, 0.08);
			color: #666;
			font-size: 16px;
			font-weight: 500;
		}
		#mobileMenu a:hover { background: rgba(0, 0, 0, 0.05); color: #000; }

		/* Hero Section - Yellow */
		.hero {
			width: 100%;
			min-height: 100vh;
			background: #DFFF00;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 120px 40px 60px;
			text-align: center;
		}
		.hero-content {
			max-width: 1200px;
		}
		.hero p {
			font-family: 'IBM Plex Mono', monospace;
			font-size: 12px;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: #000;
			margin: 0 0 40px;
		}
		.hero h1 {
			font-family: 'Space Grotesk', sans-serif;
			font-weight: 700;
			font-size: clamp(48px, 8vw, 96px);
			line-height: 1.1;
			margin: 0 0 40px;
			color: #000;
			letter-spacing: -0.02em;
		}
		.hero h1 em {
			font-family: 'Fraunces', serif;
			font-style: italic;
			font-weight: 500;
		}
		.hero > div > p:last-of-type {
			font-size: clamp(16px, 2.5vw, 20px);
			color: #000;
			max-width: 65ch;
			margin: 0 auto 40px;
			line-height: 1.6;
		}
		.hero-cta {
			display: flex;
			gap: 16px;
			align-items: center;
			justify-content: center;
			flex-wrap: wrap;
		}
		.btn {
			font-family: 'Space Grotesk', sans-serif;
			font-weight: 600;
			font-size: 14px;
			padding: 15px 32px;
			border-radius: 0;
			border: 2px solid #000;
			cursor: pointer;
			transition: all .2s ease;
		}
		.btn-dark {
			background: #000;
			color: #DFFF00;
		}
		.btn-dark:hover {
			transform: scale(1.02);
		}
		.btn-light {
			background: #DFFF00;
			color: #000;
			border-color: #000;
		}
		.btn-light:hover {
			transform: scale(1.02);
		}

		/* Sections */
		section {
			width: 100%;
			padding: 100px 40px;
		}
		section > div {
			max-width: 1200px;
			margin: 0 auto;
		}
		.eyebrow {
			font-family: 'IBM Plex Mono', monospace;
			font-size: 12px;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			margin: 0 0 20px;
		}
		h2 {
			font-family: 'Space Grotesk', sans-serif;
			font-weight: 700;
			font-size: clamp(32px, 6vw, 72px);
			line-height: 1.1;
			margin: 0 0 40px;
			letter-spacing: -0.02em;
		}

		/* Modules Section - White */
		.modules {
			background: #fff;
			color: #000;
		}
		.modules-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 32px;
			margin-top: 60px;
		}
		.module-card {
			padding: 32px;
			border: 1px solid rgba(0, 0, 0, 0.1);
			background: #f9f9f9;
			transition: all .3s ease;
		}
		.module-card:hover {
			border-color: #000;
			background: #fff;
		}
		.module-card h3 {
			font-family: 'Space Grotesk', sans-serif;
			font-weight: 700;
			font-size: 20px;
			margin: 0 0 12px;
			color: #000;
		}
		.module-card p {
			font-size: 16px;
			line-height: 1.6;
			color: #666;
			margin: 0;
		}

		/* Performance Section - Dark */
		.performance {
			background: #1C1917;
			color: #F6F4EF;
		}
		.performance .eyebrow {
			color: #D4CABE;
		}
		.performance h2 {
			color: #F6F4EF;
		}
		.performance p {
			color: #D4CABE;
			font-size: 18px;
			max-width: 65ch;
			line-height: 1.6;
		}
		.stats-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 32px;
			margin-top: 60px;
		}
		.stat-box {
			padding: 32px;
			border: 1px solid rgba(255, 255, 255, 0.1);
			background: rgba(255, 255, 255, 0.02);
		}
		.stat-box .label {
			font-family: 'IBM Plex Mono', monospace;
			font-size: 12px;
			color: #DFFF00;
			text-transform: uppercase;
			margin: 0 0 16px;
		}
		.stat-box .value {
			font-family: 'Space Grotesk', sans-serif;
			font-size: 48px;
			font-weight: 700;
			color: #F6F4EF;
			margin: 0 0 8px;
		}
		.stat-box .desc {
			font-size: 14px;
			color: #D4CABE;
			margin: 0;
		}

		/* CTA Section - Yellow */
		.cta-section {
			background: #DFFF00;
			color: #000;
			text-align: center;
			padding: 120px 40px;
		}
		.cta-section h2 {
			color: #000;
		}
		.cta-section p {
			color: #000;
			font-size: 18px;
			max-width: 65ch;
			margin: 0 auto 40px;
		}

		/* Back to Top */
		#backToTop {
			position: fixed;
			bottom: 32px;
			right: 32px;
			z-index: 40;
			width: 44px;
			height: 44px;
			border-radius: 0;
			background: #000;
			color: #fff;
			border: 0;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: 'Space Grotesk', sans-serif;
			font-weight: 700;
			opacity: 0;
			pointer-events: none;
			transition: opacity .3s ease;
		}
		#backToTop.show { opacity: 1; pointer-events: auto; }
		#backToTop:hover { transform: scale(1.1); }

		/* Responsive */
		@media (max-width: 1024px) {
			.modules-grid { grid-template-columns: repeat(2, 1fr); }
		}
		@media (max-width: 768px) {
			nav { padding: 0 12px; }
			nav > div { padding: 8px; }
			#mobileMenuBtn { display: block; }
			nav > div > div { display: none; }
			section { padding: 60px 20px; }
			.hero { padding: 100px 20px 40px; }
			.modules-grid { grid-template-columns: 1fr; gap: 16px; }
			.stats-grid { grid-template-columns: 1fr; }
			.cta-section { padding: 80px 20px; }
		}
		@media (max-width: 480px) {
			.hero h1 { font-size: 32px; }
			section { padding: 40px 16px; }
			h2 { font-size: 28px; }
		}
		@media (prefers-reduced-motion: reduce) { * { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; } }
	</style>
</head>
<body>

<nav>
	<div>
		<a href="/">
			<svg width="14" height="14" viewBox="0 0 64 64" aria-hidden="true"><polygon points="8,56 56,56 46,44 18,44" fill="#000"></polygon><rect x="23" y="20" width="18" height="24" fill="#DFFF00"></rect></svg>
			Basalio
		</a>
		<button id="mobileMenuBtn" aria-label="Toggle menu"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg></button>
		<div>
			<a href="#modules">Modules</a>
			<a href="#performance">Performance</a>
			<a href="/roadmap">Roadmap</a>
			<a href="/pricing">Pricing</a>
			<a href="/support">Support</a>
			<a href="#waitlist" class="btn-primary">Join the beta</a>
		</div>
	</div>
</nav>

<div id="mobileMenu">
	<a href="#modules">Modules</a>
	<a href="#performance">Performance</a>
	<a href="/roadmap">Roadmap</a>
	<a href="/pricing">Pricing</a>
	<a href="/support">Support</a>
	<a href="#waitlist">Join the beta</a>
</div>

<!-- Hero Section -->
<div class="hero">
	<div class="hero-content">
		<p>For WordPress • Not a page builder</p>
		<h1>Give your work <em>a foundation</em> to stand on.</h1>
		<p>Nine curated interaction modules, from grid reveals to case-study transitions to scroll-tied sequences, built only for portfolio and case-study sites. Nothing you'd need Framer for. Nothing you don't.</p>
		<div class="hero-cta">
			<button class="btn btn-dark" onclick="document.getElementById('waitlist').scrollIntoView({behavior:'smooth'})">Join the beta →</button>
			<button class="btn btn-light" onclick="document.getElementById('modules').scrollIntoView({behavior:'smooth'})">See the modules</button>
		</div>
	</div>
</div>

<!-- Modules Section -->
<section id="modules" class="modules">
	<div>
		<p class="eyebrow">Positioning • 01</p>
		<h2>Nine modules. Zero friction.</h2>
		<div class="modules-grid">
			<div class="module-card">
				<h3>Grid Reveal</h3>
				<p>Stagger grid items on scroll with customizable timing and easing curves.</p>
			</div>
			<div class="module-card">
				<h3>Case Study Transition</h3>
				<p>Smooth scroll-triggered transitions between case study sections.</p>
			</div>
			<div class="module-card">
				<h3>Scroll Sequence</h3>
				<p>Tie animations to scroll progress for immersive storytelling.</p>
			</div>
			<div class="module-card">
				<h3>Parallax Depth</h3>
				<p>Layer content at different scroll speeds for visual depth.</p>
			</div>
			<div class="module-card">
				<h3>Image Counter</h3>
				<p>Count up values as images load with smooth animations.</p>
			</div>
			<div class="module-card">
				<h3>Text Reveal</h3>
				<p>Animate text on scroll with word-by-word stagger.</p>
			</div>
			<div class="module-card">
				<h3>Hover Zoom</h3>
				<p>Subtle zoom effects on hover for interactive feedback.</p>
			</div>
			<div class="module-card">
				<h3>Click Expand</h3>
				<p>Expand content on click with smooth modal transitions.</p>
			</div>
			<div class="module-card">
				<h3>Scroll Lock</h3>
				<p>Freeze sections while hero elements animate in sequence.</p>
			</div>
		</div>
	</div>
</section>

<!-- Performance Section -->
<section id="performance" class="performance">
	<div>
		<p class="eyebrow">Performance • 02</p>
		<h2>Lightweight by default.</h2>
		<p>Each module is optimized for performance. No bloat. No frameworks. Pure vanilla JavaScript compiled to less than 12KB gzipped.</p>
		<div class="stats-grid">
			<div class="stat-box">
				<p class="label">Bundle Size</p>
				<p class="value">11.8 KB</p>
				<p class="desc">Gzipped. All 9 modules.</p>
			</div>
			<div class="stat-box">
				<p class="label">LCP Impact</p>
				<p class="value">+0ms</p>
				<p class="desc">Loaded async, no blocking.</p>
			</div>
		</div>
	</div>
</section>

<!-- CTA Section -->
<section id="waitlist" class="cta-section">
	<div>
		<h2>Ready to ship.</h2>
		<p>Join the beta. Three modules, one site, zero cost.</p>
		<button class="btn btn-dark">Get early access →</button>
	</div>
</section>

<Footer />

<button id="backToTop" aria-label="Back to top">↑</button>

<script>
	const mobileMenuBtn = document.getElementById('mobileMenuBtn');
	const mobileMenu = document.getElementById('mobileMenu');
	mobileMenuBtn.addEventListener('click', () => {
		mobileMenu.classList.toggle('open');
	});
	mobileMenu.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => {
			mobileMenu.classList.remove('open');
		});
	});

	const backToTop = document.getElementById('backToTop');
	window.addEventListener('scroll', () => {
		backToTop.classList.toggle('show', window.scrollY > 300);
	});
	backToTop.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});
</script>

</body>
</html>
