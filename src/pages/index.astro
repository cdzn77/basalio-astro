<button id="backToTop" aria-label="Back to top">↑</button>

<script>
document.addEventListener('DOMContentLoaded', () => {
	// Mobile Menu Toggle
	const mobileMenuBtn = document.getElementById('mobileMenuBtn');
	const mobileMenu = document.getElementById('mobileMenu');
	if (mobileMenuBtn) {
		mobileMenuBtn.addEventListener('click', () => {
			mobileMenu.classList.toggle('open');
		});
		mobileMenu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				mobileMenu.classList.remove('open');
			});
		});
	}

	// Back to top button
	const backToTopBtn = document.getElementById('backToTop');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 300) {
			backToTopBtn.classList.add('show');
		} else {
			backToTopBtn.classList.remove('show');
		}
	});
	backToTopBtn.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});

	// Grid tile interactivity
	const tiles = document.querySelectorAll('div[style*="aspect-ratio:3/4"]');
	tiles.forEach(tile => {
		const caption = tile.querySelector('div[style*="gradient"]');
		tile.addEventListener('mouseenter', () => {
			if (caption) {
				caption.style.transform = 'translateY(0)';
				caption.style.opacity = '1';
			}
		});
		tile.addEventListener('mouseleave', () => {
			if (caption) {
				caption.style.transform = 'translateY(60%)';
				caption.style.opacity = '0';
			}
		});
	});

	// Text Reveal animation
	const playReplayAnimation = () => {
		const words = document.querySelectorAll('.text-reveal-word');
		words.forEach(word => {
			word.style.animation = 'none';
			void word.offsetHeight; // Force reflow
			word.style.animation = '';
		});
	};

	// Replay button
	const replayBtn = document.querySelector('button:has(+ :nth-child(999))');
	if (!replayBtn) {
		// Find button by text content
		const buttons = Array.from(document.querySelectorAll('button'));
		const replayBtnAlt = buttons.find(btn => btn.textContent.includes('Replay'));
		if (replayBtnAlt) {
			replayBtnAlt.addEventListener('click', (e) => {
				e.preventDefault();
				playReplayAnimation();
			});
			// Play animation on load
			setTimeout(playReplayAnimation, 300);
		}
	} else {
		replayBtn.addEventListener('click', playReplayAnimation);
		setTimeout(playReplayAnimation, 300);
	}
});
</script>

