							</div>
							<div style="margin-bottom: 16px;">
								<label style="display: block; font-size: 12px; color: #BBB; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">Description</label>
								<textarea style="width: 100%; padding: 10px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #FFF; font-family: inherit; font-size: 13px; resize: none; height: 80px;">A comprehensive brand system including logo, typography, and color guidelines.</textarea>
							</div>
							<div style="display: flex; gap: 12px;">
								<button onclick="closeExpandCard()" style="flex: 1; padding: 12px 16px; min-height: 44px; background: #DFFF00; color: #000; border: 2px solid #DFFF00; cursor: pointer; font-weight: 600; font-size: 13px; transition: all 0.2s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.2);">Save</button>
								<button onclick="closeExpandCard()" style="flex: 1; padding: 12px 16px; min-height: 44px; background: rgba(255,255,255,0.1); color: #FFF; border: 2px solid rgba(255,255,255,0.2); cursor: pointer; font-weight: 600; font-size: 13px; transition: all 0.2s ease;">Cancel</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Row 6: Scroll Lock (full-bleed light single) -->
		<div class="module-row full-bleed">
			<div class="module-full-bleed bg-light">
				<div class="module-content">
					<h3>Scroll Lock</h3>
					<p>Freeze sections while hero elements animate in sequence.</p>
				</div>
				<div class="module-image" style="width: 100%; aspect-ratio: 16 / 9; position: relative; border-radius: 12px; overflow: hidden;">
					<div style="background: linear-gradient(135deg, #E8E8E8 0%, #DDD 50%, #D0D0D0 100%); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #0A0A0A; gap: 24px; padding: 60px 40px; position: relative;">
						<div class="scroll-lock-item" style="flex: 1; padding: 48px 32px; background: rgba(100,100,100,0.15); text-align: center; font-weight: 600; opacity: 0; transform: translateX(-30px); transition: opacity 0.6s ease-out, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);">Hero Frame 1</div>
						<div class="scroll-lock-item" style="flex: 1; padding: 48px 32px; background: rgba(100,100,100,0.1); text-align: center; font-weight: 600; opacity: 0; transform: translateX(-30px); transition: opacity 0.6s ease-out 0.15s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s;">Hero Frame 2</div>
						<div class="scroll-lock-item" style="flex: 1; padding: 48px 32px; background: rgba(100,100,100,0.05); text-align: center; font-weight: 600; opacity: 0; transform: translateX(-30px); transition: opacity 0.6s ease-out 0.3s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;">Hero Frame 3</div>
					</div>
					<button id="scrollLockBtn" onclick="triggerScrollLock()" style="position: absolute; bottom: 20px; right: 20px; padding: 12px 24px; min-height: 44px; min-width: 44px; background: #0A0A0A; color: #FFF; border: 2px solid #0A0A0A; cursor: pointer; font-size: 12px; font-weight: 600; z-index: 10; transition: all 0.2s ease; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.15);" aria-label="Play scroll lock sequence animation">Play Sequence</button>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Performance Section -->
<section id="performance" class="performance">
	<div>
		<p class="eyebrow">Performance • 02</p>
		<h2>Lightweight by default.</h2>
		<p>Each module is optimized for performance. No bloat. No frameworks. Pure vanilla JavaScript compiled to less than 12KB gzipped.</p>
		<div class="stats-grid">
			<div class="stat-box">
				<p class="label">Bundle Size</p>
				<p class="value">11.8 KB</p>
				<p class="desc">Gzipped. All 9 modules.</p>
			</div>
			<div class="stat-box">
				<p class="label">LCP Impact</p>
				<p class="value">+0ms</p>
				<p class="desc">Loaded async, no blocking.</p>
			</div>
		</div>
	</div>
</section>

<!-- CTA Section -->
<section id="waitlist" class="cta-section">
	<div>
		<h2>Ready to ship.</h2>
		<p>Join the beta. Three modules, one site, zero cost.</p>
		<button class="btn btn-dark">Get early access →</button>
	</div>
</section>

<Footer />

<Animations />

<button id="backToTop" aria-label="Back to top">↑</button>

<script>
	const mobileMenuBtn = document.getElementById('mobileMenuBtn');
	const mobileMenu = document.getElementById('mobileMenu');
	mobileMenuBtn.addEventListener('click', () => {
		mobileMenu.classList.toggle('open');
	});
	mobileMenu.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => {
			mobileMenu.classList.remove('open');
		});
	});

	const backToTop = document.getElementById('backToTop');
	window.addEventListener('scroll', () => {
		backToTop.classList.toggle('show', window.scrollY > 300);
	});
	backToTop.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});

	// Grid Reveal
	function triggerGridReveal() {
		const items = document.querySelectorAll('.grid-reveal-item');
		items.forEach((item, i) => {
			item.style.opacity = '0';
			item.style.transform = 'scale(0.8)';
			setTimeout(() => {
				item.style.transition = 'all 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
				item.style.opacity = '1';
				item.style.transform = 'scale(1)';
			}, i * 80);
		});
	}

	// Keyboard support for grid items
	document.querySelectorAll('.grid-reveal-item').forEach(item => {
		item.addEventListener('keydown', e => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				triggerGridReveal();
			}
		});
	});

	// Case Study Transition
	let currentCase = 1;
	function transitionCase(direction) {
		const slides = document.querySelectorAll('.case-slide');
		const dots = document.querySelectorAll('.case-slide').parentElement?.querySelectorAll('button') || [];
		currentCase = Math.max(0, Math.min(2, currentCase + direction));
		slides.forEach((slide, i) => {
			if (i === currentCase - 1) slide.style.left = '-100%';
			else if (i === currentCase) slide.style.left = '0%';
			else slide.style.left = '100%';
		});
	}

	// Scroll Sequence
	function updateScrollSequence(value) {
		const percent = (value / 100) * 100;
		document.getElementById('scrollSeqProgress').style.width = percent + '%';
		document.getElementById('scrollSeqProgress2').style.width = Math.max(0, percent - 20) + '%';
		document.getElementById('scrollSeqProgress3').style.width = Math.max(0, percent - 40) + '%';
	}

	// Counter Animation
	function triggerCounterAnimation() {
		const counterValue = document.getElementById('counterValue');
		let count = 0;
		const target = 2847;
		const duration = 1000;
		const steps = 60;
		const increment = target / steps;
		const stepDuration = duration / steps;

		const interval = setInterval(() => {
			count += increment;
			if (count >= target) {
				counterValue.textContent = target.toLocaleString();
				clearInterval(interval);
			} else {
				counterValue.textContent = Math.floor(count).toLocaleString();
			}
		}, stepDuration);
	}

	// Parallax Effect
	function updateParallax(event) {
		const container = event.currentTarget;
		const rect = container.getBoundingClientRect();
		const x = event.clientX - rect.left;
		const y = event.clientY - rect.top;
		const centerX = rect.width / 2;
		const centerY = rect.height / 2;
		const rotateX = ((y - centerY) / centerY) * 15;
		const rotateY = ((centerX - x) / centerX) * 15;

		const layers = container.querySelectorAll('.parallax-layer');
		layers.forEach((layer, i) => {
			const offset = (i + 1) * 5;
			layer.style.transform = `translateY(${rotateX * (i + 1) * 0.5}px) translateX(${rotateY * (i + 1) * 0.5}px)`;
		});
	}

	function resetParallax() {
		const layers = document.querySelectorAll('.parallax-layer');
		layers.forEach(layer => {
			layer.style.transform = 'translateY(0) translateX(0)';
		});
	}

	// Text Reveal
	function triggerTextReveal() {
		const words = document.querySelectorAll('.text-reveal-word');
		words.forEach(word => {
			word.style.transition = 'none';
			word.style.opacity = '0';
			word.style.transform = 'translateY(10px)';
		});
		setTimeout(() => {
			words.forEach((word, i) => {
				setTimeout(() => {
					word.style.transition = 'all 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
					word.style.opacity = '1';
					word.style.transform = 'translateY(0)';
				}, i * 100);
			});
		}, 50);
	}

	// Click Expand
	let currentModal = null;
	function expandCard(index) {
		currentModal = index;
		const modal = document.getElementById(`expandedModal${index}`);
		modal.style.display = 'flex';
		document.body.style.overflow = 'hidden';
		// Focus the first input in the modal for better accessibility
		const firstInput = modal.querySelector('input, textarea');
		if (firstInput) setTimeout(() => firstInput.focus(), 100);
	}

	function closeExpandCard(event) {
		if (event && event.target.id && !event.target.id.startsWith('expandedModal')) return;
		const modals = document.querySelectorAll('[id^="expandedModal"]');
		modals.forEach(modal => modal.style.display = 'none');
		document.body.style.overflow = 'auto';
		currentModal = null;
	}

	// ESC key support for closing modals
	document.addEventListener('keydown', e => {
		if (e.key === 'Escape' && currentModal !== null) {
			closeExpandCard();
		}
	});

	// Scroll Lock
	function triggerScrollLock() {
		const items = document.querySelectorAll('.scroll-lock-item');
		const btn = document.getElementById('scrollLockBtn');
		btn.disabled = true;
		btn.style.opacity = '0.6';

		items.forEach(item => {
			item.style.transition = 'none';
			item.style.opacity = '0';
			item.style.transform = 'translateX(-30px)';
		});
		setTimeout(() => {
			items.forEach((item, i) => {
				item.style.transition = `opacity 0.6s ease-out ${i * 0.15}s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${i * 0.15}s`;
				item.style.opacity = '1';
				item.style.transform = 'translateX(0)';
			});
		}, 50);

		// After animation completes, show replay button
		const totalDuration = 300 + 600; // last item delay + duration
		setTimeout(() => {
			btn.textContent = 'Replay';
			btn.disabled = false;
			btn.style.opacity = '1';
		}, totalDuration + 100);
	}

	// Make functions globally accessible for onclick handlers
	window.triggerGridReveal = triggerGridReveal;
	window.transitionCase = transitionCase;
	window.updateScrollSequence = updateScrollSequence;
	window.triggerCounterAnimation = triggerCounterAnimation;
	window.updateParallax = updateParallax;
	window.resetParallax = resetParallax;
	window.triggerTextReveal = triggerTextReveal;
	window.expandCard = expandCard;
	window.closeExpandCard = closeExpandCard;
	window.triggerScrollLock = triggerScrollLock;
</script>

</body>
</html>
