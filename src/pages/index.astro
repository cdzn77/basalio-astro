<script>
document.addEventListener('DOMContentLoaded', () => {
	// Grid tile interactivity
	const tiles = document.querySelectorAll('div[style*="aspect-ratio:3/4"]');
	tiles.forEach(tile => {
		const caption = tile.querySelector('div[style*="gradient"]');
		tile.addEventListener('mouseenter', () => {
			if (caption) {
				caption.style.transform = 'translateY(0)';
				caption.style.opacity = '1';
			}
		});
		tile.addEventListener('mouseleave', () => {
			if (caption) {
				caption.style.transform = 'translateY(60%)';
				caption.style.opacity = '0';
			}
		});
	});
});
</script>

