		}
		#backToTop:active {
			transform: translateY(-2px);
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
		}

		/* Responsive */
		@media (max-width: 1024px) {
			.module-row {
				padding: 0 40px;
			}
