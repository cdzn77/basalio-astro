						<div style="position:absolute;left:0;right:0;bottom:0;padding:10px 12px;background:linear-gradient(to top, rgba(0,0,0,0.72), rgba(0,0,0,0));transform:translateY(60%);opacity:0;transition:transform .35s cubic-bezier(.16,1,.3,1), opacity .35s ease;"><div style="color:#fff;font-size:13px;font-weight:500;">Mercer Studio</div><div style="color:rgba(255,255,255,0.7);font-family:'IBM Plex Mono',monospace;font-size:10px;">Web &middot; 2026</div></div>
