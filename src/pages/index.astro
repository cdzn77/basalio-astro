						<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="#FF6B4A" stroke-width="1.6"></circle><path d="M12 4v3M12 17v3M4 12h3M17 12h3" stroke="#FF6B4A" stroke-width="1.6" stroke-linecap="round"></path></svg>
					</span>
				</div>
