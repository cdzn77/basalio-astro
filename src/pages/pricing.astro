<section id="faq" style="padding:80px 0;border-top:1px solid #3A352E;background:#1C1917;">
	<div style="max-width:900px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#D4CABE;margin:0;">Licensing & updates</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(28px,3.4vw,42px);margin:14px 0 36px;">The questions worth answering before you buy.</h2>

		<div style="display:grid;gap:0;">
			<button class="accordion-button open" style="border-bottom:1px solid #3A352E;padding:18px 0;display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;color:#F6F4EF;">
				Is Basalio a subscription?
				<span class="toggle-icon" style="flex-shrink:0;transform:rotate(45deg);">−</span>
			</button>
			<div class="accordion-content open" style="padding:16px 0 32px;">
				<p style="font-size:14px;color:#D4CABE;margin:0;line-height:1.6;">No. It's a one-time payment, and every tier includes lifetime updates. You're buying a license, not renting access. Nothing expires and nothing rebills.</p>
			</div>

			<button class="accordion-button" style="border-bottom:1px solid #3A352E;padding:18px 0;display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;color:#F6F4EF;">
				What exactly do "lifetime updates" cover?
				<span class="toggle-icon">+</span>
			</button>
			<div class="accordion-content" style="padding:0;">
				<p style="font-size:14px;color:#D4CABE;padding:16px 0 32px;margin:0;line-height:1.6;">All bug fixes, performance improvements, and new modules as they release. Major version updates included. You're always current, always supported.</p>
			</div>

			<button class="accordion-button" style="border-bottom:1px solid #3A352E;padding:18px 0;display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;color:#F6F4EF;">
				It's pre-launch. What does joining the beta cost?
				<span class="toggle-icon">+</span>
			</button>
			<div class="accordion-content" style="padding:0;">
				<p style="font-size:14px;color:#D4CABE;padding:16px 0 32px;margin:0;line-height:1.6;">Nothing. Beta seats are free for real, live portfolio sites. When paid launch happens, existing beta members keep their free access.</p>
			</div>

			<button class="accordion-button" style="border-bottom:1px solid #3A352E;padding:18px 0;display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;color:#F6F4EF;">
				Can I use one license across client projects?
				<span class="toggle-icon">+</span>
			</button>
			<div class="accordion-content" style="padding:0;">
				<p style="font-size:14px;color:#D4CABE;padding:16px 0 32px;margin:0;line-height:1.6;">Studio and Agency tiers can. Personal tier is one site only. Agency tier includes client-transfer licenses—hand off to clients with no extra cost.</p>
			</div>

			<button class="accordion-button" style="border-bottom:1px solid #3A352E;padding:18px 0;display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;color:#F6F4EF;">
				What if I outgrow my tier?
				<span class="toggle-icon">+</span>
			</button>
			<div class="accordion-content" style="padding:0;">
				<p style="font-size:14px;color:#D4CABE;padding:16px 0 32px;margin:0;line-height:1.6;">Reach out and we'll help. Upgrades are pro-rated. Most folks land on Studio or Agency for client work—we can work out what fits.</p>
			</div>

			<button class="accordion-button" style="border-bottom:1px solid #3A352E;padding:18px 0;display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;color:#F6F4EF;">
				How are licenses and updates delivered?
				<span class="toggle-icon">+</span>
			</button>
			<div class="accordion-content" style="padding:0;">
				<p style="font-size:14px;color:#D4CABE;padding:16px 0 32px;margin:0;line-height:1.6;">You'll get a license key via email after purchase. Drop it into Basalio settings to activate. Updates pull automatically—no manual steps needed.</p>
			</div>

			<button class="accordion-button" style="border-bottom:1px solid #3A352E;padding:18px 0;display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;color:#F6F4EF;">
				Do you offer refunds?
				<span class="toggle-icon">+</span>
			</button>
			<div class="accordion-content" style="padding:0;">
				<p style="font-size:14px;color:#D4CABE;padding:16px 0 32px;margin:0;line-height:1.6;">Yes. 14-day money-back guarantee, no questions asked. Just reach out within two weeks if it's not right for you.</p>
			</div>
		</div>
	</div>
</section>

<section style="position:relative;overflow:hidden;padding:100px 0;text-align:center;background:linear-gradient(100deg,#DFFF00,#2BC7A6 55%,#FF6B4A);background-size:200% 200%;animation:driftGrad 18s ease-in-out infinite;">
	<div style="max-width:1200px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.85);margin:0;">Beta</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(28px,4vw,42px);max-width:640px;margin:14px auto 16px;color:#fff;">No checkout yet, just early access.</h2>
		<p style="color:rgba(255,255,255,0.85);max-width:44ch;margin:0 auto 32px;">Paid licenses open after beta. For now, seats are free for real, live portfolio sites.</p>
		<script>
			const mobileMenuBtn = document.getElementById('mobileMenuBtn');
			const mobileMenu = document.getElementById('mobileMenu');
			if (mobileMenuBtn) {
				mobileMenuBtn.addEventListener('click', () => {
					mobileMenu.classList.toggle('open');
				});
				mobileMenu.querySelectorAll('a').forEach(link => {
					link.addEventListener('click', () => {
						mobileMenu.classList.remove('open');
					});
				});
			}
		</script>
		<form style="display:flex;gap:10px;max-width:440px;margin:0 auto;">
			<input type="email" required placeholder="you@yourstudio.com" aria-label="Email address" style="flex:1;padding:13px 18px;border:0;border-radius:999px;font-family:'Inter',sans-serif;font-size:14px;background:rgba(255,255,255,0.95);">
			<button type="submit" style="display:inline-flex;align-items:center;gap:8px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:14px;padding:13px 22px;border:0;border-radius:999px;background:#17171A;color:#F6F4EF;cursor:pointer;white-space:nowrap;">Request access</button>
		</form>
	</div>
</section>

<Footer />

<script>
	const tiersData = [
		{ name: 'Personal', price: '$79', sites: '1 site' },
		{ name: 'Studio', price: '$149', sites: '5 sites' },
		{ name: 'Agency', price: '$299', sites: 'Unlimited sites' },
	];

	let activeTier = 0;

	const pricingCardsHtml = [
		{
			name: 'Personal',
			price: '$79',
			sites: '1 site',
			features: ['All 3 beta modules', 'Roadmap modules as released', 'Email support'],
			highlighted: false,
		},
		{
			name: 'Studio',
			price: '$149',
			sites: '5 sites',
			features: ['Everything in Personal', 'Use on client sites', 'Priority support', 'Early roadmap access'],
			highlighted: true,
		},
		{
			name: 'Agency',
			price: '$299',
			sites: 'Unlimited sites',
			features: ['Everything in Studio', 'Client site-transfer license', 'Direct roadmap input'],
			highlighted: false,
		},
	];

	function renderPricingCards() {
		const container = document.getElementById('pricingCards');
		container.innerHTML = pricingCardsHtml.map((card, idx) => {
			const borderColor = card.highlighted ? 'rgba(223,255,0,0.35)' : '#3A352E';
			const bgColor = card.highlighted ? 'linear-gradient(165deg, rgba(223,255,0,0.14), #26221E 60%)' : '#26221E';
			const shadowStyle = card.highlighted ? 'box-shadow:0 24px 50px -24px rgba(0,0,0,0.5);' : '';
			return `
				<div style="position:relative;border:1px solid ${borderColor};background:${bgColor};padding:32px;border-radius:10px;display:flex;flex-direction:column;overflow:hidden;${shadowStyle}">
					<span style="position:absolute;top:8px;right:16px;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:48px;color:rgba(255,255,255,0.06);">${idx + 1}</span>
					<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#D4CABE;text-transform:uppercase;letter-spacing:.06em;margin:0;">${card.name}</p>
					<p style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:34px;margin:12px 0 4px;color:#F6F4EF;">${card.price} <span style="font-size:14px;color:#D4CABE;font-family:'Inter',sans-serif;font-weight:400;">one-time</span></p>
					<p style="color:#D4CABE;font-size:14px;margin:0 0 20px;">${card.sites}</p>
					<ul style="list-style:none;margin:0 0 24px;padding:0;flex:1;">
						${card.features.map(f => `<li style="font-size:14px;padding:7px 0;border-top:1px solid ${card.highlighted ? 'rgba(255,255,255,0.12)' : '#3A352E'};color:#F6F4EF;">${f}</li>`).join('')}
					</ul>
					<a href="/#waitlist" style="display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:14px;padding:12px 20px;border-radius:999px;${card.highlighted ? 'background:#DFFF00;color:#17171A;' : 'border:1px solid rgba(255,255,255,0.4);background:transparent;color:#F6F4EF;'}transition:transform .18s ease;">Join the beta</a>
				</div>
			`;
		}).join('');
	}

	document.querySelectorAll('.tier-btn').forEach(btn => {
		btn.addEventListener('click', function() {
			activeTier = parseInt(this.dataset.tier);
			updateTierDisplay();
		});
	});

	function updateTierDisplay() {
		// Update buttons
		document.querySelectorAll('.tier-btn').forEach((btn, idx) => {
			if (idx === activeTier) {
				btn.style.background = '#DFFF00';
				btn.style.color = '#17171A';
			} else {
				btn.style.background = 'transparent';
				btn.style.color = '#D4CABE';
			}
		});

		// Update focal tier card
		const tier = tiersData[activeTier];
		const focalCard = document.getElementById('focalTier');
		if (activeTier === 1) {
			focalCard.style.background = 'linear-gradient(165deg, rgba(223,255,0,0.14), #26221E 60%)';
			focalCard.style.border = '1px solid rgba(223,255,0,0.35)';
		} else {
			focalCard.style.background = '#26221E';
			focalCard.style.border = '1px solid #3A352E';
		}
		focalCard.innerHTML = `
			<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#D4CABE;text-transform:uppercase;letter-spacing:.06em;margin:0;">${tier.name}</p>
			<p style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:42px;margin:12px 0 2px;color:#F6F4EF;">${tier.price}</p>
			<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#D4CABE;margin:0 0 16px;">one-time</p>
			<p style="font-size:13px;color:#F6F4EF;margin:0;">${tier.sites}</p>
		`;
	}

	renderPricingCards();
	updateTierDisplay();

	// Accordion functionality
	const accordionButtons = document.querySelectorAll('.accordion-button');
	accordionButtons.forEach((button) => {
		button.addEventListener('click', function() {
			const section = this.closest('section');
			const isOpen = this.classList.contains('open');
			const content = this.nextElementSibling;

			// Close all other accordions in this section
			section.querySelectorAll('.accordion-button.open').forEach(otherBtn => {
				if (otherBtn !== this) {
					otherBtn.classList.remove('open');
					otherBtn.nextElementSibling.classList.remove('open');
				}
			});

			// Toggle this accordion
			if (isOpen) {
				this.classList.remove('open');
				content.classList.remove('open');
			} else {
				this.classList.add('open');
				content.classList.add('open');
			}
		});
	});

	// Back to top button
	const backToTopBtn = document.getElementById('backToTop');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 300) {
			backToTopBtn.classList.add('show');
		} else {
			backToTopBtn.classList.remove('show');
		}
	});
	backToTopBtn.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});
</script>

<button id="backToTop" aria-label="Back to top">↑</button>

</body>
</html>
