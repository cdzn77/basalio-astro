---
// Resources Page - Explore practical resources from free essentials to paid systems

import RampTemplateLayout from '../layouts/RampTemplateLayout.astro';
import RampHeader from '../components/RampHeader.astro';
import RampFooter from '../components/RampFooter.astro';

const title = "Resources — Ramp Studio";
const description = "Explore practical resources we use in real client work, from free essentials to in-depth, paid systems.";

const resources = [
  {
    title: "Pricing Toolkit",
    description: "It reduces ambiguity, sets expectations early, and supports confident client conversations.",
    tag: "TOOLKITS",
    type: "FREE",
    image: "/assets/course-1.png"
  },
  {
    title: "Analytics Toolkit",
    description: "It focuses on clarity and insights — not vanity metrics.",
    tag: "TOOLKITS",
    type: "FREE",
    image: "/assets/course-2.png"
  },
  {
    title: "AI Prompts for Marketing",
    description: "Prompts are structured to support strategy, writing, and planning — not replace thinking.",
    tag: "TEMPLATES",
    type: "FREE",
    image: "/assets/course-3.png"
  },
  {
    title: "Internal Agency Framework",
    description: "It supports consistency, onboarding, and long-term scalability.",
    tag: "FRAMEWORK",
    type: "FREE",
    image: "/assets/course-4.png"
  },
  {
    title: "Rapid Offer Toolkit",
    description: "Clarify your offer before building your website.",
    tag: "TOOLKITS",
    type: "FREE",
    image: "/assets/pdj0idpbqdqskgu0uiqstv5gwpu.png"
  },
  {
    title: "Campaign Landing Page",
    description: "Launch marketing campaign pages in hours.",
    tag: "TEMPLATES",
    type: "FREE",
    image: "/assets/upmbf6f02u2lakjunuvoy3tpsk.png"
  },
  {
    title: "Premium Strategy Course",
    description: "Deep-dive into advanced marketing strategy and implementation tactics.",
    tag: "COURSES",
    type: "PAID",
    image: "/assets/course-1.png"
  },
  {
    title: "Client Acquisition Playbook",
    description: "Complete system for attracting and converting high-value clients.",
    tag: "TEMPLATES",
    type: "PAID",
    image: "/assets/course-2.png"
  },
  {
    title: "Brand Positioning Framework",
    description: "Establish a unique market position that commands premium pricing.",
    tag: "FRAMEWORK",
    type: "PAID",
    image: "/assets/course-3.png"
  },
  {
    title: "Sales Funnel Masterclass",
    description: "Build a high-converting sales funnel from awareness to loyalty.",
    tag: "COURSES",
    type: "PAID",
    image: "/assets/course-4.png"
  },
  {
    title: "Financial Modeling Toolkit",
    description: "Advanced financial planning and forecasting for growing agencies.",
    tag: "TOOLKITS",
    type: "PAID",
    image: "/assets/pdj0idpbqdqskgu0uiqstv5gwpu.png"
  },
  {
    title: "Client Communication Templates",
    description: "Professional templates for proposals, contracts, and presentations.",
    tag: "TEMPLATES",
    type: "PAID",
    image: "/assets/upmbf6f02u2lakjunuvoy3tpsk.png"
  },
  {
    title: "Advanced Analytics Dashboard",
    description: "Track and optimize every metric that matters for your business.",
    tag: "TOOLKITS",
    type: "PAID",
    image: "/assets/course-1.png"
  },
  {
    title: "Team Leadership Program",
    description: "Build and manage a high-performing team culture.",
    tag: "COURSES",
    type: "PAID",
    image: "/assets/course-2.png"
  },
  {
    title: "Premium Client Retention System",
    description: "Strategies to increase lifetime value and client satisfaction.",
    tag: "FRAMEWORK",
    type: "PAID",
    image: "/assets/course-3.png"
  }
];
---

<RampTemplateLayout title={title} description={description}>
  <!-- HEADER: Navigation bar -->
  <Fragment slot="header">
    <RampHeader />
  </Fragment>

  <!-- HERO SECTION -->
  <section class="hero-section">
    <div class="resources-label">OUR RESOURCES</div>
    <h1 class="hero-heading">Explore practical resources we use in real client work, from free essentials to in-depth, paid systems.</h1>
  </section>

  <!-- FILTER SECTION -->
  <section class="filter-section">
    <div class="filter-buttons">
      <button class="filter-btn active" data-filter="FREE">FREE</button>
      <button class="filter-btn" data-filter="PAID">PAID</button>
    </div>
  </section>

  <!-- RESOURCES GRID SECTION -->
  <section class="resources-section">
    <div class="resources-grid">
      {resources.map((resource) => (
        <div class="resource-card" data-type={resource.type}>
          <div class="resource-image-wrapper">
            <img src={resource.image} alt={resource.title} class="resource-image" />
          </div>
          <div>
            <h3 class="resource-title">{resource.title}</h3>
            <p class="resource-description">{resource.description}</p>
            <div class="resource-meta">
              <span class="resource-type">{resource.type}</span>
              <span class="resource-tag">{resource.tag}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FOOTER: Reused from homepage -->
  <Fragment slot="footer">
    <RampFooter address="Østerbrogade 45, 2100 København Ø, Copenhagen, Denmark" />
  </Fragment>
</RampTemplateLayout>

<style>
  /* HERO SECTION */
  .hero-section {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 1786px;
    padding: 120px 40px;
    background: #FFFFFF;
    box-sizing: border-box;
    gap: 20px;
    margin: 0 auto;
    align-items: flex-start;
  }

  .resources-label {
    background-color: #FFED00;
    color: #000000;
    font-family: 'Azeret Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    padding: 8px 12px;
    display: inline-block;
  }

  .hero-heading {
    font-family: Switzer, sans-serif;
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.96px;
    line-height: 52.8px;
    color: #000000;
    margin: 0;
    padding: 0;
    text-wrap: balance;
    max-width: 800px;
  }

  /* FILTER SECTION */
  .filter-section {
    display: flex;
    width: 100%;
    max-width: 1786px;
    padding: 40px 40px;
    background: #FFFFFF;
    box-sizing: border-box;
    margin: 0 auto;
    align-items: center;
    justify-content: flex-start;
  }

  .filter-buttons {
    display: flex;
    gap: 12px;
  }

  .filter-btn {
    font-family: 'Azeret Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    padding: 12px 20px;
    border: 1px solid #000000;
    background: transparent;
    color: #000000;
    cursor: pointer;
    border-radius: 6px;
    transition: all 200ms ease;
  }

  .filter-btn:hover {
    background: #000000;
    color: #FFFFFF;
  }

  .filter-btn.active {
    background: #000000;
    color: #FFFFFF;
  }

  /* RESOURCES SECTION */
  .resources-section {
    display: flex;
    width: 100%;
    max-width: 1786px;
    padding: 60px 40px 200px 40px;
    background: #FFFFFF;
    box-sizing: border-box;
    margin: 0 auto;
    border-bottom-left-radius: 40px;
    border-bottom-right-radius: 40px;
    position: relative;
    z-index: 2;
    margin-bottom: -40px;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    width: 100%;
  }

  .resource-card {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: stretch;
    position: relative;
  }

  .resource-image-wrapper {
    width: 150px;
    height: 190px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .resource-image {
    width: 100%;
    height: 100%;
    object-fit: fill;
    display: block;
    transition: transform 300ms ease;
  }

  .resource-card:hover .resource-image {
    transform: scale(1.08);
  }

  .resource-card > div:not(.resource-icon):not(.resource-image-wrapper) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    justify-content: space-between;
  }

  .resource-title {
    background-color: rgba(0, 0, 0, 0);
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
    box-sizing: border-box;
    color: rgb(0, 0, 0);
    cursor: pointer;
    display: block;
    font-family: Switzer, "Switzer Placeholder", sans-serif;
    font-size: 20px;
    font-weight: 500;
    height: 28px;
    letter-spacing: normal;
    line-height: 28px;
    margin: 0;
    padding: 0;
    text-align: start;
    text-decoration: none;
    text-decoration-color: rgb(0, 0, 0);
    text-decoration-line: none;
    text-decoration-skip-ink: auto;
    text-decoration-style: solid;
    text-decoration-thickness: auto;
    text-transform: none;
    text-underline-offset: auto;
    text-wrap-mode: wrap;
    unicode-bidi: isolate;
    width: 330px;
    -webkit-font-smoothing: antialiased;
    -webkit-text-stroke-color: rgb(0, 0, 0);
    -webkit-text-stroke-width: 0px;
  }

  .resource-description {
    background-color: rgba(0, 0, 0, 0);
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
    box-sizing: border-box;
    color: rgb(87, 87, 87);
    cursor: pointer;
    display: block;
    font-family: Switzer, "Switzer Placeholder", sans-serif;
    font-size: 14px;
    font-weight: 400;
    height: 39.2031px;
    letter-spacing: normal;
    line-height: 19.6px;
    margin: 0;
    padding: 0;
    text-align: start;
    text-decoration: none;
    text-decoration-color: rgb(87, 87, 87);
    text-decoration-line: none;
    text-decoration-skip-ink: auto;
    text-decoration-style: solid;
    text-decoration-thickness: auto;
    text-transform: none;
    text-underline-offset: auto;
    text-wrap-mode: wrap;
    unicode-bidi: isolate;
    width: 330px;
    -webkit-font-smoothing: antialiased;
    -webkit-text-stroke-color: rgb(87, 87, 87);
    -webkit-text-stroke-width: 0px;
  }

  .resource-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    font-family: 'Azeret Mono', monospace;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: #666666;
    margin-top: 0;
  }

  .resource-type {
    background-color: rgba(0, 0, 0, 0);
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
    box-sizing: border-box;
    color: rgb(136, 136, 136);
    cursor: pointer;
    display: block;
    font-family: "Azeret Mono", monospace;
    font-size: 10px;
    font-weight: 500;
    height: 14px;
    letter-spacing: 2px;
    line-height: 14px;
    margin: 0;
    padding: 0;
    text-align: start;
    text-decoration: none;
    text-decoration-color: rgb(136, 136, 136);
    text-decoration-line: none;
    text-decoration-skip-ink: auto;
    text-decoration-style: solid;
    text-decoration-thickness: auto;
    text-transform: uppercase;
    text-underline-offset: auto;
    text-wrap-mode: nowrap;
    unicode-bidi: isolate;
    width: 34px;
    -webkit-font-smoothing: antialiased;
    -webkit-text-stroke-color: rgb(136, 136, 136);
    -webkit-text-stroke-width: 0px;
  }

  .resource-tag {
    background-color: #E8E8E8;
    color: rgb(136, 136, 136);
    padding: 6px 12px;
    border-radius: 6px;
    font-family: "Azeret Mono", monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-block;
    margin: 0;
    transition: all 200ms ease;
  }

  .resource-tag:hover {
    background-color: #D0D0D0;
    color: rgb(80, 80, 80);
  }

  /* FILTER FUNCTIONALITY */
  .resource-card {
    display: flex;
  }

  .resource-card[data-type="PAID"] {
    display: none;
  }

  .resource-card[data-type="PAID"].show {
    display: flex;
  }

  .resource-card[data-type="FREE"].hide {
    display: none;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-section,
    .filter-section,
    .resources-section {
      flex-direction: column;
      gap: 40px;
      padding: 60px 20px;
    }

    .hero-left,
    .hero-right,
    .filter-left,
    .filter-right,
    .resources-left,
    .resources-right {
      flex: 0 0 auto;
    }

    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-heading {
      font-size: 36px;
    }
  }

  @media (max-width: 768px) {
    .hero-section,
    .filter-section,
    .resources-section {
      flex-direction: column;
      gap: 40px;
      padding: 40px 20px;
    }

    .hero-heading {
      font-size: 28px;
    }

    .resources-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Filter functionality
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const resourceCards = document.querySelectorAll('.resource-card');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filterType = button.getAttribute('data-filter');

        // Update active button state
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // Filter resource cards
        resourceCards.forEach(card => {
          const cardType = card.getAttribute('data-type');

          if (cardType === filterType) {
            card.classList.remove('hide');
            card.classList.add('show');
          } else {
            card.classList.add('hide');
            card.classList.remove('show');
          }
        });
      });
    });
  });
</script>
