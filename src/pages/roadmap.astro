<Footer />

<script>
document.addEventListener('DOMContentLoaded', () => {
	// Mobile menu
	const mobileMenuBtn = document.getElementById('mobileMenuBtn');
	const mobileMenu = document.getElementById('mobileMenu');
	if (mobileMenuBtn) {
		mobileMenuBtn.addEventListener('click', () => {
			mobileMenu.classList.toggle('open');
		});
		mobileMenu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				mobileMenu.classList.remove('open');
			});
		});
	}

	const stack = document.getElementById('cardStack');
	if (!stack) return;

	const cards = stack.querySelectorAll('.stack-card');
	const cardArray = Array.from(cards);

	cards.forEach((card, index) => {
		card.addEventListener('click', () => {
			// Rotate stack: move clicked card to front
			const currentOrder = cardArray.slice();
			const clickedIndex = currentOrder.indexOf(card);

			// Reorder array to put clicked card first
			const newOrder = [card, ...currentOrder.filter((_, i) => i !== clickedIndex)];

			// Update visual positions
			newOrder.forEach((c, i) => {
				const offsetY = i * 12;
				const rotation = i === 0 ? 0 : (i % 2 === 0 ? -1.5 : 1.5);
				c.style.transform = `translateY(${offsetY}px) rotate(${rotation}deg)`;
				c.style.zIndex = 10 - i;
			});

			// Update reference array
			cardArray.length = 0;
			cardArray.push(...newOrder);
		});
	});
});

// Back to top button
const backToTopBtn = document.getElementById('backToTop');
window.addEventListener('scroll', () => {
	if (window.scrollY > 300) {
		backToTopBtn.classList.add('show');
	} else {
		backToTopBtn.classList.remove('show');
	}
});
backToTopBtn.addEventListener('click', () => {
	window.scrollTo({ top: 0, behavior: 'smooth' });
});
</script>

<button id="backToTop" aria-label="Back to top">↑</button>

</body>
</html>
