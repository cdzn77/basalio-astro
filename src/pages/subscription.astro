<script>
  // FAQ Accordion functionality - single-open pattern
  const faqItems = document.querySelectorAll('.faq-item');

  faqItems.forEach((item) => {
    const header = item.querySelector('.faq-header');
    const toggle = item.querySelector('.faq-toggle');

    if (header) {
      header.addEventListener('click', () => {
        const isCurrentlyActive = item.classList.contains('active');

        // If clicking an open item, close it
        if (isCurrentlyActive) {
          item.classList.remove('active');
          toggle.textContent = '+';
          toggle.setAttribute('aria-label', 'Expand answer');
        } else {
          // Close all other items
          faqItems.forEach((otherItem) => {
            const otherToggle = otherItem.querySelector('.faq-toggle');
            otherItem.classList.remove('active');
            if (otherToggle) {
              otherToggle.textContent = '+';
              otherToggle.setAttribute('aria-label', 'Expand answer');
            }
          });

          // Open the clicked item
          item.classList.add('active');
          toggle.textContent = '×';
          toggle.setAttribute('aria-label', 'Close answer');
        }
      });
    }
  });
</script>
