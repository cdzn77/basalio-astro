---
// Basalio Support page with search filtering and accordion FAQs
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Basalio - Support & Help Center</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@1,9..144,500&display=swap" rel="stylesheet">
	<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cpolygon points='8,56 56,56 46,44 18,44' fill='%23F6F4EF'/%3E%3Crect x='23' y='20' width='18' height='24' fill='%23DFFF00'/%3E%3C/svg%3E">
	<style>
		html{scroll-behavior:smooth;}
		body{margin:0;background:#1C1917;color:#F6F4EF;font-family:'Inter',sans-serif;font-size:16px;line-height:1.5;-webkit-font-smoothing:antialiased;}
		a{color:inherit;text-decoration:none;}
		a:hover{color:#F6F4EF;}
		@keyframes driftGrad{0%{background-position:0% 50%;}50%{background-position:100% 50%;}100%{background-position:0% 50%;}}
		@media (prefers-reduced-motion: reduce){ *{animation-duration:0.001ms !important; transition-duration:0.001ms !important;} }
	</style>
</head>
<body>

<nav style="position:sticky;top:14px;z-index:50;padding:0 20px;">
	<div style="max-width:1160px;margin:0 auto;background:rgba(28,25,23,0.92);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,0.08);border-radius:999px;padding:8px 8px 8px 22px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 24px 48px -24px rgba(0,0,0,0.55);">
		<a href="/" style="font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;display:flex;align-items:center;gap:8px;color:#F6F4EF;">
			<svg width="14" height="14" viewBox="0 0 64 64" aria-hidden="true" style="flex:none;"><polygon points="8,56 56,56 46,44 18,44" fill="#F6F4EF"></polygon><rect x="23" y="20" width="18" height="24" fill="#DFFF00"></rect></svg>
			Basalio
		</a>
		<div style="display:flex;gap:22px;align-items:center;">
			<a href="/#exhibits" style="font-size:14px;color:#A39C8E;transition:color .15s ease;">Modules</a>
			<a href="/#bench" style="font-size:14px;color:#A39C8E;transition:color .15s ease;">Performance</a>
			<a href="/roadmap" style="font-size:14px;color:#A39C8E;transition:color .15s ease;">Roadmap</a>
			<a href="/pricing" style="font-size:14px;color:#A39C8E;transition:color .15s ease;">Pricing</a>
			<a href="/support" style="font-size:14px;color:#F6F4EF;">Support</a>
			<a href="/#waitlist" style="display:inline-flex;align-items:center;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:13px;padding:9px 18px;border-radius:999px;background:#DFFF00;color:#17171A;transition:transform .18s ease;">Join the beta</a>
		</div>
	</div>
</nav>

<header style="position:relative;overflow:hidden;background:#1C1917;padding:80px 0 40px;">
	<div aria-hidden="true" style="position:absolute;top:-180px;right:-160px;width:520px;height:520px;border-radius:50%;background:radial-gradient(circle,rgba(223,255,0,0.12),transparent 70%);filter:blur(10px);pointer-events:none;"></div>
	<div style="position:relative;max-width:900px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#A39C8E;margin:0;">Support</p>
		<h1 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.02em;line-height:1.05;font-size:clamp(32px,4.2vw,50px);margin:16px 0 16px;color:#F6F4EF;">When something looks off, start here.</h1>
		<p style="color:#A39C8E;font-size:17px;max-width:60ch;margin:0 0 32px;">Every symptom we've seen in beta, its likely cause, and the fix. If yours isn't listed, email us and we'll add it.</p>

		<div style="position:relative;max-width:520px;">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="position:absolute;left:16px;top:50%;transform:translateY(-50%);pointer-events:none;"><circle cx="11" cy="11" r="7" stroke="#7A756C" stroke-width="1.8"></circle><path d="M20 20l-4.3-4.3" stroke="#7A756C" stroke-width="1.8" stroke-linecap="round"></path></svg>
			<input type="text" placeholder="Search troubleshooting" aria-label="Search troubleshooting" id="searchInput" style="width:100%;box-sizing:border-box;padding:13px 16px 13px 42px;border-radius:999px;border:1px solid rgba(255,255,255,0.16);background:rgba(255,255,255,0.05);color:#F6F4EF;font-family:'Inter',sans-serif;font-size:14px;">
		</div>

		<div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:22px;">
			<a href="#installation" style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#A39C8E;border:1px solid #3A352E;border-radius:999px;padding:6px 14px;transition:border-color .15s ease,color .15s ease;">Installation</a>
			<a href="#modules" style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#A39C8E;border:1px solid #3A352E;border-radius:999px;padding:6px 14px;transition:border-color .15s ease,color .15s ease;">Module behavior</a>
			<a href="#performance" style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#A39C8E;border:1px solid #3A352E;border-radius:999px;padding:6px 14px;transition:border-color .15s ease,color .15s ease;">Performance &amp; conflicts</a>
			<a href="#accessibility" style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#A39C8E;border:1px solid #3A352E;border-radius:999px;padding:6px 14px;transition:border-color .15s ease,color .15s ease;">Accessibility</a>
			<a href="#licensing" style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#A39C8E;border:1px solid #3A352E;border-radius:999px;padding:6px 14px;transition:border-color .15s ease,color .15s ease;">Licensing</a>
			<a href="#hacks" style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#17171A;background:#DFFF00;border:1px solid #DFFF00;border-radius:999px;padding:6px 14px;">Power-user hacks</a>
		</div>
	</div>
</header>

<section id="installation" style="padding:56px 0;border-top:1px solid #3A352E;background:#1C1917;">
	<div style="max-width:900px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#A39C8E;margin:0;">01 Getting started</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(24px,2.8vw,32px);margin:14px 0 28px;">Installation</h2>

		<div class="faq-section">
			<div class="faq-item">
				<button class="faq-toggle" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:16px;background:none;border:0;padding:20px 0;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#F6F4EF;border-bottom:1px solid #3A352E;">
					Where do I download Basalio?
					<span style="font-family:'Inter',sans-serif;font-weight:400;font-size:20px;color:#A39C8E;flex:none;">+</span>
				</button>
				<div class="faq-content" style="overflow:hidden;max-height:0;transition:max-height .3s ease;">
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;padding-bottom:26px;">
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Likely cause</p>
							<ul style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">You're in the closed beta</li></ul>
						</div>
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Fix</p>
							<ol style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Join the waitlist on the homepage</li></ol>
						</div>
					</div>
				</div>
			</div>

			<div class="faq-item">
				<button class="faq-toggle" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:16px;background:none;border:0;padding:20px 0;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#F6F4EF;border-bottom:1px solid #3A352E;">
					How do I activate my license on multiple sites?
					<span style="font-family:'Inter',sans-serif;font-weight:400;font-size:20px;color:#A39C8E;flex:none;">+</span>
				</button>
				<div class="faq-content" style="overflow:hidden;max-height:0;transition:max-height .3s ease;">
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;padding-bottom:26px;">
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Likely cause</p>
							<ul style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">License tier doesn't support multiple sites</li></ul>
						</div>
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Fix</p>
							<ol style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Upgrade to Studio (5 sites) or Agency (unlimited)</li></ol>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<section id="modules" style="padding:56px 0;border-top:1px solid #3A352E;background:#1C1917;">
	<div style="max-width:900px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#A39C8E;margin:0;">02 Using Basalio</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(24px,2.8vw,32px);margin:14px 0 28px;">Module behavior</h2>

		<div class="faq-section">
			<div class="faq-item">
				<button class="faq-toggle" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:16px;background:none;border:0;padding:20px 0;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#F6F4EF;border-bottom:1px solid #3A352E;">
					Grid Reveal isn't showing captions on hover
					<span style="font-family:'Inter',sans-serif;font-weight:400;font-size:20px;color:#A39C8E;flex:none;">+</span>
				</button>
				<div class="faq-content" style="overflow:hidden;max-height:0;transition:max-height .3s ease;">
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;padding-bottom:26px;">
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Likely cause</p>
							<ul style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Custom CSS hiding or overriding captions</li><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Module not initialized on page</li></ul>
						</div>
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Fix</p>
							<ol style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Check for conflicting CSS in inspector</li><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Ensure Grid Reveal module is enabled in Basalio settings</li></ol>
						</div>
					</div>
				</div>
			</div>

			<div class="faq-item">
				<button class="faq-toggle" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:16px;background:none;border:0;padding:20px 0;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#F6F4EF;border-bottom:1px solid #3A352E;">
					Animations stutter on mobile
					<span style="font-family:'Inter',sans-serif;font-weight:400;font-size:20px;color:#A39C8E;flex:none;">+</span>
				</button>
				<div class="faq-content" style="overflow:hidden;max-height:0;transition:max-height .3s ease;">
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;padding-bottom:26px;">
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Likely cause</p>
							<ul style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Low-end device or background apps consuming CPU</li><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Reduced motion preference enabled</li></ul>
						</div>
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Fix</p>
							<ol style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Check Settings &gt; Accessibility for reduced motion</li><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Disable large image grids on mobile</li></ol>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<section id="performance" style="padding:56px 0;border-top:1px solid #3A352E;background:#1C1917;">
	<div style="max-width:900px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#A39C8E;margin:0;">03 Performance</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(24px,2.8vw,32px);margin:14px 0 28px;">Performance &amp; conflicts</h2>

		<div class="faq-section">
			<div class="faq-item">
				<button class="faq-toggle" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:16px;background:none;border:0;padding:20px 0;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#F6F4EF;border-bottom:1px solid #3A352E;">
					Page loads slowly after adding Basalio
					<span style="font-family:'Inter',sans-serif;font-weight:400;font-size:20px;color:#A39C8E;flex:none;">+</span>
				</button>
				<div class="faq-content" style="overflow:hidden;max-height:0;transition:max-height .3s ease;">
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;padding-bottom:26px;">
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Likely cause</p>
							<ul style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Module loaded on all pages, not just where needed</li><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Large image assets in Grid Reveal</li></ul>
						</div>
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Fix</p>
							<ol style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Only enable Basalio on pages that use it</li><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Optimize images to &lt;200KB each</li></ol>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<section id="accessibility" style="padding:56px 0;border-top:1px solid #3A352E;background:#1C1917;">
	<div style="max-width:900px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#A39C8E;margin:0;">04 Accessibility</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(24px,2.8vw,32px);margin:14px 0 28px;">Accessibility</h2>

		<div class="faq-section">
			<div class="faq-item">
				<button class="faq-toggle" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:16px;background:none;border:0;padding:20px 0;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#F6F4EF;border-bottom:1px solid #3A352E;">
					Screen reader skipping captions in Grid Reveal
					<span style="font-family:'Inter',sans-serif;font-weight:400;font-size:20px;color:#A39C8E;flex:none;">+</span>
				</button>
				<div class="faq-content" style="overflow:hidden;max-height:0;transition:max-height .3s ease;">
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;padding-bottom:26px;">
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Likely cause</p>
							<ul style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Captions hidden from screen readers by CSS</li></ul>
						</div>
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Fix</p>
							<ol style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Ensure aria-label attributes are present on all tiles</li></ol>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<section id="licensing" style="padding:56px 0;border-top:1px solid #3A352E;background:#1C1917;">
	<div style="max-width:900px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#A39C8E;margin:0;">05 Licensing</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(24px,2.8vw,32px);margin:14px 0 28px;">Licensing &amp; billing</h2>

		<div class="faq-section">
			<div class="faq-item">
				<button class="faq-toggle" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:16px;background:none;border:0;padding:20px 0;cursor:pointer;text-align:left;font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#F6F4EF;border-bottom:1px solid #3A352E;">
					Can I use my license on client sites?
					<span style="font-family:'Inter',sans-serif;font-weight:400;font-size:20px;color:#A39C8E;flex:none;">+</span>
				</button>
				<div class="faq-content" style="overflow:hidden;max-height:0;transition:max-height .3s ease;">
					<div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;padding-bottom:26px;">
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Likely cause</p>
							<ul style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#A39C8E;margin-bottom:6px;">Personal or Studio license restrictions</li></ul>
						</div>
						<div>
							<p style="font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#7A756C;margin:0 0 10px;">Fix</p>
							<ol style="margin:0;padding-left:18px;"><li style="font-size:14px;color:#F6F4EF;margin-bottom:6px;">Upgrade to Agency license for client transfer rights</li></ol>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<section id="hacks" style="padding:64px 0;border-top:1px solid #3A352E;background:#1C1917;">
	<div style="max-width:1200px;margin:0 auto;padding:0 32px;">
		<p style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#A39C8E;margin:0;">Power-user hacks</p>
		<h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.01em;line-height:1.1;font-size:clamp(26px,3.2vw,36px);margin:14px 0 12px;">Five ways to bend it, if you know where to look.</h2>
		<p style="color:#A39C8E;font-size:16px;max-width:60ch;margin:0 0 40px;">None of this is required. It's here for the studios who want a little more control.</p>

		<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;">
			<div style="background:#211E1A;border:1px solid rgba(223,255,0,0.16);border-radius:14px;padding:26px 28px;">
				<span style="display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;color:#17171A;background:#DFFF00;border-radius:999px;padding:3px 10px;margin-bottom:14px;">Hack</span>
				<h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:17px;margin:0 0 10px;color:#F6F4EF;">Custom reveal timing</h3>
